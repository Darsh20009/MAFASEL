<%- include('../partials/header') %>
<div class="main-content">
  <div class="container">
    <div class="page-header">
      <h1><i class="fas fa-bell"></i> الإشعارات</h1>
      <button class="btn btn-outline" onclick="markAllRead()">تعيين الكل كمقروء</button>
    </div>
    <% if (notifications.length > 0) { %>
    <div class="list-items">
      <% notifications.forEach(n => { %>
      <div class="list-item notif-item <%= n.read ? '' : 'unread' %>" onclick="<% if(n.link) { %>markRead('<%= n._id %>'); window.location='<%= n.link %>'<% } else { %>markRead('<%= n._id %>', this)<% } %>">
        <div class="notif-icon notif-<%= n.type %>">
          <i class="fas fa-<%= n.type === 'success' ? 'check-circle' : n.type === 'warning' ? 'exclamation-triangle' : n.type === 'error' ? 'times-circle' : 'info-circle' %>"></i>
        </div>
        <div class="list-item-info">
          <strong><%= n.title %></strong>
          <p><%= n.body %></p>
          <span class="text-muted"><%= new Date(n.createdAt).toLocaleDateString('ar-SA', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
        </div>
      </div>
      <% }) %>
    </div>
    <% } else { %>
    <div class="empty-state-lg">
      <i class="fas fa-bell-slash"></i>
      <h3>لا توجد إشعارات</h3>
    </div>
    <% } %>
  </div>
</div>
<script>
  async function markRead(id, el) {
    await fetch('/notifications/read/' + id, { method: 'POST' });
    if (el) el.classList.remove('unread');
  }
  async function markAllRead() {
    await fetch('/notifications/read-all', { method: 'POST' });
    document.querySelectorAll('.unread').forEach(el => el.classList.remove('unread'));
  }
</script>
<%- include('../partials/footer') %>
