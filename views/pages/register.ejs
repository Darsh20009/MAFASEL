<%- include('../partials/header') %>
<div class="auth-page">
  <div class="auth-card">
    <div class="auth-header">
      <img src="/icons/logo.png" alt="مفاصل" class="auth-logo">
      <h1>إنشاء حساب جديد</h1>
      <p>انضم إلى منصة مفاصل الطبية</p>
    </div>
    <form method="POST" action="/register" class="auth-form">
      <div class="form-group">
        <label><i class="fas fa-user"></i> الاسم الكامل</label>
        <input type="text" name="name" required placeholder="أدخل اسمك الكامل">
      </div>
      <div class="form-group">
        <label><i class="fas fa-envelope"></i> البريد الإلكتروني</label>
        <input type="email" name="email" required placeholder="أدخل بريدك الإلكتروني">
      </div>
      <div class="form-group">
        <label><i class="fas fa-phone"></i> رقم الهاتف</label>
        <input type="tel" name="phone" required placeholder="05xxxxxxxx">
      </div>
      <div class="form-group">
        <label><i class="fas fa-user-tag"></i> نوع الحساب</label>
        <select name="role">
          <option value="patient">مريض</option>
          <option value="doctor">طبيب</option>
          <option value="pharmacist">صيدلي</option>
        </select>
      </div>
      <div class="form-group">
        <label><i class="fas fa-lock"></i> كلمة المرور</label>
        <input type="password" name="password" required placeholder="أدخل كلمة المرور" minlength="6">
      </div>
      <div class="form-group">
        <label><i class="fas fa-lock"></i> تأكيد كلمة المرور</label>
        <input type="password" name="confirmPassword" required placeholder="أعد إدخال كلمة المرور">
      </div>
      <button type="submit" class="btn btn-primary btn-block">إنشاء حساب</button>
    </form>
    <div class="auth-footer">
      <p>لديك حساب؟ <a href="/login">تسجيل الدخول</a></p>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
