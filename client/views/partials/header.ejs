<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'ar' %>" dir="<%= typeof dir !== 'undefined' ? dir : 'rtl' %>" data-theme="<%= user && user.darkMode ? 'dark' : 'light' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= title %> | <%= typeof t === 'function' ? t('site_name') : 'مفاصل' %></title>
  <% var seoDesc = typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : 'منصة مفاصل الطبية الرقمية المتكاملة - استشارات طبية، صيدلية إلكترونية، تأمين صحي، مساعد ذكي، مواعيد وتذكيرات أدوية'; %>
  <% var seoUrl = typeof canonicalUrl !== 'undefined' && canonicalUrl ? canonicalUrl : ''; %>
  <% var seoImage = typeof metaImage !== 'undefined' && metaImage ? metaImage : '/icons/icon-512.png'; %>
  <meta name="description" content="<%= seoDesc %>">
  <meta name="keywords" content="مفاصل, منصة طبية, استشارات طبية, صيدلية إلكترونية, تأمين صحي, مواعيد طبية, تذكير أدوية, أخصائي علاج طبيعي, صيدلي, السعودية, رعاية صحية رقمية">
  <meta name="author" content="مفاصل">
  <meta name="robots" content="<%= typeof metaRobots !== 'undefined' && metaRobots ? metaRobots : 'index, follow' %>">
  <link rel="canonical" href="<%= seoUrl %>">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="مفاصل - منصة طبية رقمية">
  <meta property="og:title" content="<%= title %> | مفاصل">
  <meta property="og:description" content="<%= seoDesc %>">
  <meta property="og:image" content="<%= seoImage %>">
  <meta property="og:url" content="<%= seoUrl %>">
  <meta property="og:locale" content="ar_SA">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= title %> | مفاصل">
  <meta name="twitter:description" content="<%= seoDesc %>">
  <meta name="twitter:image" content="<%= seoImage %>">
  <link rel="icon" href="/icons/logo.png">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#12a99b">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="مفاصل">
  <link rel="apple-touch-icon" href="/icons/icon-192.png">
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <% if (typeof schemaMarkup !== 'undefined' && schemaMarkup) { %>
  <script type="application/ld+json"><%- JSON.stringify(schemaMarkup) %></script>
  <% } %>
</head>
<body>
<nav class="navbar">
  <div class="nav-container">
    <a href="/dashboard" class="nav-logo">
      <img src="/icons/logo.png" alt="<%= typeof t === 'function' ? t('site_name') : 'مفاصل' %>" class="nav-logo-img">
      <span><%= typeof t === 'function' ? t('site_name') : 'مفاصل' %></span>
    </a>
    <button class="nav-toggle" id="navToggle" aria-label="القائمة">
      <i class="fas fa-bars"></i>
    </button>
    <div class="nav-menu" id="navMenu">
      <a href="/dashboard" class="nav-link"><i class="fas fa-home"></i> <%= typeof t === 'function' ? t('nav.home') : 'الرئيسية' %></a>
      <% if (user) { %>
        <% var r = user.role; %>
        <% if (r === 'patient') { %>
          <a href="/physiotherapy" class="nav-link"><i class="fas fa-hand-holding-medical"></i> <%= typeof t === 'function' ? t('nav.physiotherapy') : 'العلاج الطبيعي' %></a>
          <a href="/consultations" class="nav-link"><i class="fas fa-stethoscope"></i> <%= typeof t === 'function' ? t('nav.consultations') : 'الاستشارات' %></a>
          <a href="/medical-profile" class="nav-link"><i class="fas fa-heartbeat"></i> <%= typeof t === 'function' ? t('nav.medical_profile') : 'الملف الطبي' %></a>
          <a href="/pharmacy" class="nav-link"><i class="fas fa-pills"></i> <%= typeof t === 'function' ? t('nav.pharmacy') : 'الصيدلية' %></a>
          <a href="/insurance" class="nav-link"><i class="fas fa-shield-alt"></i> <%= typeof t === 'function' ? t('nav.insurance') : 'التأمين' %></a>
