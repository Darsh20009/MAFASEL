          <a href="/meetings" class="nav-link"><i class="fas fa-video"></i> <%= typeof t === 'function' ? t('nav.meetings') : 'الاجتماعات' %></a>
          <a href="/ai" class="nav-link"><img src="/icons/logo.png" alt="" style="width:16px;height:16px;vertical-align:middle;margin-left:4px;"> <%= typeof t === 'function' ? t('nav.ai_assistant') : 'مساعد مفاصل' %></a>
        <% } else { %>
          <a href="/consultations" class="nav-link"><i class="fas fa-stethoscope"></i> <%= typeof t === 'function' ? t('nav.consultations') : 'الاستشارات' %></a>
          <a href="/pharmacy" class="nav-link"><i class="fas fa-pills"></i> <%= typeof t === 'function' ? t('nav.pharmacy') : 'الصيدلية' %></a>
          <a href="/insurance" class="nav-link"><i class="fas fa-shield-alt"></i> <%= typeof t === 'function' ? t('nav.insurance') : 'التأمين' %></a>
          <a href="/maps" class="nav-link"><i class="fas fa-map-marked-alt"></i> <%= typeof t === 'function' ? t('nav.maps') : 'الخريطة' %></a>
          <a href="/chat" class="nav-link"><i class="fas fa-comments"></i> <%= typeof t === 'function' ? t('nav.chat') : 'المحادثات' %></a>
          <a href="/meetings" class="nav-link"><i class="fas fa-video"></i> <%= typeof t === 'function' ? t('nav.meetings') : 'الاجتماعات' %></a>
          <a href="/complaints" class="nav-link"><i class="fas fa-headset"></i> <%= typeof t === 'function' ? t('nav.support') : 'الدعم' %></a>
        <% } %>
        <% if (r === 'admin' || r === 'moderator') { %>
        <a href="/admin" class="nav-link nav-admin"><i class="fas fa-shield-halved"></i> <%= typeof t === 'function' ? t('nav.admin') : 'الإدارة' %></a>
        <% } %>
      <% } %>
    </div>
    <div class="nav-actions">
      <% if (user) { %>
      <button class="nav-icon-btn pwa-install-btn" id="pwaInstallBtn" onclick="installPWA()" title="تثبيت التطبيق" style="display:none">
        <i class="fas fa-download"></i>
      </button>
      <a href="/notifications" class="nav-icon-btn" id="notifBtn" title="<%= typeof t === 'function' ? t('nav.notifications') : 'الإشعارات' %>">
        <i class="fas fa-bell"></i>
        <span class="notif-badge" id="notifBadge" style="display:none">0</span>
      </a>
      <button class="nav-icon-btn" id="darkToggle" title="الوضع الليلي">
        <i class="fas fa-moon"></i>
      </button>
      <button class="nav-icon-btn lang-toggle-btn" id="langToggle" onclick="toggleLanguage()" title="<%= typeof t === 'function' ? t('common.language') : 'اللغة' %>">
        <i class="fas fa-globe"></i>
        <span class="lang-label"><%= (typeof lang !== 'undefined' && lang === 'en') ? 'ع' : 'EN' %></span>
      </button>
      <div class="nav-user-dropdown">
        <button class="nav-user-btn">
          <i class="fas fa-user-circle"></i>
          <span class="nav-user-name"><%= user.name %></span>
          <i class="fas fa-chevron-down"></i>
        </button>
        <div class="dropdown-menu">
          <a href="/profile"><i class="fas fa-user"></i> <%= typeof t === 'function' ? t('nav.profile') : 'الملف الشخصي' %></a>
          <a href="/logout"><i class="fas fa-sign-out-alt"></i> <%= typeof t === 'function' ? t('nav.logout') : 'تسجيل الخروج' %></a>
        </div>
      </div>
      <% } else { %>
      <button class="nav-icon-btn lang-toggle-btn" id="langToggleGuest" onclick="toggleLanguage()" title="<%= typeof t === 'function' ? t('common.language') : 'اللغة' %>">
        <i class="fas fa-globe"></i>
        <span class="lang-label"><%= (typeof lang !== 'undefined' && lang === 'en') ? 'ع' : 'EN' %></span>
      </button>
      <a href="/login" class="btn btn-primary btn-sm nav-login-btn"><i class="fas fa-sign-in-alt"></i> <%= typeof t === 'function' ? t('nav.login') : 'دخول' %></a>
      <% } %>
