<%- include('../partials/header') %>
<%
var priorityColors = { urgent:'#ef4444', high:'#f97316', medium:'#ca8a04', normal:'#94a3b8' };
var priorityLabel = PRIORITY_LABELS[room.priority] || 'عادي';
var priorityColor = priorityColors[room.priority] || '#94a3b8';
var roleMap = { patient:'مريض', doctor:'طبيب', pharmacist:'صيدلي', admin:'مدير', moderator:'مشرف', company:'شركة', employee:'موظف', insurance_agent:'وكيل تأمين' };
%>

<div class="support-layout">

  <!-- ══ RIGHT: Chat Panel ══════════════════════════ -->
  <div class="support-chat-panel">

    <!-- Header -->
    <div class="support-chat-header">
      <a href="/admin/support" class="btn btn-outline btn-sm"><i class="fas fa-arrow-right"></i></a>
      <div class="sch-info">
        <strong><%= patient ? patient.name : room.title %></strong>
        <span class="sch-sub">
          <span class="priority-dot" style="background:<%= priorityColor %>"></span>
          <%= priorityLabel %>
          <% if (room.assignedTo) { %> · مُعيَّن لـ <%= room.assignedTo.name %><% } %>
          <% if (!room.isActive) { %> · <span style="color:#ef4444;">مغلقة</span><% } %>
        </span>
      </div>
      <div class="sch-actions">
        <% if (room.isActive) { %>
        <form method="POST" action="/admin/support/room/<%= room._id %>/close" onsubmit="return confirm('إغلاق المحادثة؟')">
          <button class="btn btn-outline btn-sm" style="color:#ef4444;border-color:#ef4444;"><i class="fas fa-times-circle"></i> إغلاق</button>
        </form>
        <% } else { %>
        <form method="POST" action="/admin/support/room/<%= room._id %>/reopen">
          <button class="btn btn-sm" style="background:var(--secondary);color:#fff;"><i class="fas fa-redo"></i> إعادة فتح</button>
        </form>
        <% } %>
      </div>
    </div>

    <!-- Messages -->
    <div class="support-messages" id="chatMessages">
      <% messages.forEach(function(msg) { %>
      <% var isAdmin = msg.sender && ['admin','moderator'].includes(msg.sender.role); %>
      <% var isMe = msg.sender && msg.sender._id && msg.sender._id.toString() === user._id.toString(); %>

      <% if (msg.type === 'system') { %>
      <div class="chat-system-msg">
        <span><%= msg.text %></span>
        <small><%= new Date(msg.createdAt).toLocaleString('ar-SA',{hour:'2-digit',minute:'2-digit'}) %></small>
      </div>
      <% } else { %>
      <div class="chat-msg <%= isAdmin ? 'chat-msg-me' : 'chat-msg-other' %>">
        <% if (!isAdmin) { %>
        <div class="chat-msg-avatar">
          <% if (msg.sender && msg.sender.avatar) { %><img src="<%= msg.sender.avatar %>" alt=""><% } else { %><div class="chat-msg-avatar-ph"><i class="fas fa-user"></i></div><% } %>
        </div>
        <% } %>
        <div class="chat-msg-content">
          <% if (!isAdmin && msg.sender) { %><div class="chat-msg-sender"><%= msg.sender.name %></div><% } %>
          <div class="chat-bubble">
            <% if (msg.attachments && msg.attachments.length > 0) { %>
            <div class="chat-attachments">
              <% msg.attachments.forEach(function(att) { %>
              <% if (att.type && att.type.startsWith('image/')) { %>
              <a href="<%= att.url %>" target="_blank" class="chat-img-attach"><img src="<%= att.url %>" loading="lazy"></a>
              <% } else { %>
              <a href="<%= att.url %>" target="_blank" class="chat-file-attach" download>
                <div class="chat-file-icon <%= att.type&&att.type.includes('pdf')?'pdf-icon':'' %>"><i class="fas <%= att.type&&att.type.includes('pdf')?'fa-file-pdf':'fa-file-alt' %>"></i></div>
                <div class="chat-file-info"><span class="chat-file-name"><%= att.name||'ملف' %></span><% if(att.size){%><small class="chat-file-size"><%= (att.size/1024).toFixed(0) %> KB</small><%}%></div>
                <i class="fas fa-download chat-file-dl"></i>
              </a>
              <% } %>
              <% }) %>
            </div>
            <% } %>
            <% if (msg.text && msg.type !== 'image') { %><p><%= msg.text %></p><% } %>
            <div class="chat-msg-time">
              <%= new Date(msg.createdAt).toLocaleString('ar-SA',{hour:'2-digit',minute:'2-digit'}) %>
              <% if (isAdmin) { %><i class="fas fa-check-double" style="opacity:0.7;"></i><% } %>
            </div>
          </div>
        </div>
      </div>
      <% } %>
      <% }) %>

      <div class="chat-typing-indicator" id="typingIndicator" style="display:none">
        <div class="chat-bubble chat-typing-bubble"><span></span><span></span><span></span></div>
      </div>
    </div>

    <!-- AI Suggestion -->
    <div id="aiSuggestionBar" style="display:none" class="ai-suggestion-bar">
      <div class="ai-sug-label"><i class="fas fa-robot"></i> اقتراح AI:</div>
      <div class="ai-sug-text" id="aiSugText"></div>
      <button class="btn btn-sm" style="background:var(--secondary);color:#fff;flex-shrink:0;" onclick="useSuggestion()">استخدام</button>
      <button class="btn btn-outline btn-sm" style="flex-shrink:0;" onclick="closeSuggestion()"><i class="fas fa-times"></i></button>
    </div>

    <!-- Input -->
    <% if (room.isActive) { %>
    <div class="support-input-area">
      <div class="sia-tools">
        <button class="sia-tool-btn" onclick="aiSuggest()" title="اقتراح AI"><i class="fas fa-robot"></i> AI</button>
      </div>
      <div class="sia-form-wrap">
        <textarea id="supportReplyInput" placeholder="اكتب ردك هنا..." rows="2"></textarea>
        <button class="sia-send-btn" id="sendBtn" onclick="sendReply()"><i class="fas fa-paper-plane"></i></button>
      </div>
    </div>
    <% } else { %>
    <div class="support-closed-notice"><i class="fas fa-lock"></i> المحادثة مغلقة</div>
    <% } %>
  </div>

  <!-- ══ LEFT: User Info Panel ══════════════════════ -->
  <div class="support-info-panel" id="infoPanel">

    <!-- Tabs -->
    <div class="sip-tabs">
      <button class="sip-tab active" onclick="showTab('userTab',this)"><i class="fas fa-user"></i> المستخدم</button>
      <button class="sip-tab" onclick="showTab('requestsTab',this)"><i class="fas fa-list"></i> الطلبات</button>
      <button class="sip-tab" onclick="showTab('healthTab',this)"><i class="fas fa-heartbeat"></i> الصحة</button>
      <button class="sip-tab" onclick="showTab('notesTab',this)"><i class="fas fa-sticky-note"></i> ملاحظات <% if(room.internalNotes && room.internalNotes.length>0){%><span class="notes-count"><%= room.internalNotes.length %></span><%}%></button>
      <button class="sip-tab" onclick="showTab('settingsTab',this)"><i class="fas fa-cog"></i> إعدادات</button>
    </div>

    <!-- TAB: User Info -->
    <div class="sip-tab-content active" id="userTab">
      <% if (patient) { %>
      <div class="user-card-mini">
        <% if (patient.avatar) { %><img src="<%= patient.avatar %>" class="ucm-avatar" alt=""><% } else { %><div class="ucm-avatar ucm-avatar-ph"><i class="fas fa-user"></i></div><% } %>
        <div>
          <strong><%= patient.name %></strong>
          <div class="ucm-role"><span class="badge badge-primary"><%= roleMap[patient.role] || patient.role %></span></div>
        </div>
      </div>

      <div class="info-section">
        <div class="info-row">
          <span class="info-label"><i class="fas fa-envelope"></i> البريد</span>
          <span class="info-val"><%= patient.email || '—' %></span>
        </div>
        <div class="info-row">
          <span class="info-label"><i class="fas fa-phone"></i> الجوال</span>
          <span class="info-val"><%= patient.phone || '—' %></span>
        </div>
        <div class="info-row">
          <span class="info-label"><i class="fas fa-venus-mars"></i> الجنس</span>
          <span class="info-val"><%= patient.gender === 'male' ? 'ذكر' : patient.gender === 'female' ? 'أنثى' : '—' %></span>
        </div>
        <div class="info-row">
          <span class="info-label"><i class="fas fa-birthday-cake"></i> تاريخ الميلاد</span>
          <span class="info-val"><%= patient.dateOfBirth ? new Date(patient.dateOfBirth).toLocaleDateString('ar-SA') : '—' %></span>
        </div>
        <div class="info-row">
          <span class="info-label"><i class="fas fa-sign-in-alt"></i> طريقة الدخول</span>
          <span class="info-val"><%= { local:'كلمة مرور', google:'Google', apple:'Apple', nafath:'نفاذ', phone:'رقم الجوال' }[patient.authProvider] || patient.authProvider %></span>
        </div>
        <div class="info-row">
          <span class="info-label"><i class="fas fa-clock"></i> آخر نشاط</span>
          <span class="info-val"><%= patient.lastLogin ? new Date(patient.lastLogin).toLocaleString('ar-SA',{dateStyle:'short',timeStyle:'short'}) : '—' %></span>
        </div>
        <div class="info-row">
          <span class="info-label"><i class="fas fa-calendar-plus"></i> تاريخ التسجيل</span>
          <span class="info-val"><%= new Date(patient.createdAt).toLocaleDateString('ar-SA') %></span>
        </div>
        <div class="info-row">
          <span class="info-label"><i class="fas fa-check-circle"></i> الحالة</span>
          <span class="info-val">
            <% if (patient.isVerified) { %><span style="color:#22c55e;">✔ موثّق</span><% } else { %><span style="color:#f59e0b;">غير موثّق</span><% } %>
            &nbsp;
            <% if (patient.isActive) { %><span style="color:#22c55e;">نشط</span><% } else { %><span style="color:#ef4444;">موقوف</span><% } %>
          </span>
        </div>
      </div>
      <% } else { %>
      <p style="color:var(--text-muted);padding:1rem;">لا توجد بيانات مستخدم</p>
      <% } %>
    </div>

    <!-- TAB: Requests -->
    <div class="sip-tab-content" id="requestsTab">
      <div class="sip-section-title"><i class="fas fa-stethoscope"></i> الاستشارات (<%= consultations.length %>)</div>
      <% if (consultations.length === 0) { %><p class="sip-empty">لا توجد استشارات</p><% } %>
      <% consultations.forEach(function(c) { %>
      <div class="req-card">
        <div class="req-card-title"><%= c.specialty %></div>
        <div class="req-card-sub"><%= c.symptoms ? c.symptoms.substring(0,60) : '' %></div>
        <div class="req-card-foot">
          <span class="badge badge-<%= c.status==='completed'?'success':c.status==='pending'?'warning':'primary' %>">
            <%= {pending:'قيد الانتظار',assigned:'مُعيَّنة',in_progress:'جارية',completed:'مكتملة',cancelled:'ملغية'}[c.status]||c.status %>
          </span>
          <small><%= new Date(c.createdAt).toLocaleDateString('ar-SA') %></small>
        </div>
      </div>
      <% }) %>

      <div class="sip-section-title" style="margin-top:1rem;"><i class="fas fa-pills"></i> الطلبات (<%= orders.length %>)</div>
      <% if (orders.length === 0) { %><p class="sip-empty">لا توجد طلبات</p><% } %>
      <% orders.forEach(function(o) { %>
      <div class="req-card">
        <div class="req-card-title"><%= o.items && o.items.length > 0 ? o.items[0].name + (o.items.length>1?' + '+(o.items.length-1)+' أخرى':'') : 'طلب دواء' %></div>
        <div class="req-card-sub"><%= o.totalPrice ? o.totalPrice + ' ريال' : '' %></div>
        <div class="req-card-foot">
          <span class="badge badge-<%= o.status==='delivered'?'success':o.status==='cancelled'?'error':'warning' %>">
            <%= {pending:'قيد الانتظار',confirmed:'مؤكد',preparing:'جاري التحضير',delivering:'في الطريق',delivered:'تم التوصيل',cancelled:'ملغي'}[o.status]||o.status %>
          </span>
          <small><%= new Date(o.createdAt).toLocaleDateString('ar-SA') %></small>
        </div>
      </div>
      <% }) %>
    </div>

    <!-- TAB: Health -->
    <div class="sip-tab-content" id="healthTab">
      <% if (patient && patient.medicalProfile) {
        var mp = patient.medicalProfile;
      %>
      <div class="health-grid">
        <div class="health-card">
          <div class="hc-icon" style="background:rgba(239,68,68,0.1);color:#ef4444;"><i class="fas fa-tint"></i></div>
          <div class="hc-info"><small>فصيلة الدم</small><strong><%= mp.bloodType || '—' %></strong></div>
        </div>
        <div class="health-card">
          <div class="hc-icon" style="background:rgba(18,169,155,0.1);color:var(--secondary);"><i class="fas fa-ruler-vertical"></i></div>
          <div class="hc-info"><small>الطول</small><strong><%= mp.height ? mp.height + ' سم' : '—' %></strong></div>
        </div>
        <div class="health-card">
          <div class="hc-icon" style="background:rgba(249,115,22,0.1);color:#f97316;"><i class="fas fa-weight"></i></div>
          <div class="hc-info"><small>الوزن</small><strong><%= mp.weight ? mp.weight + ' كج' : '—' %></strong></div>
        </div>
      </div>

      <% if (mp.chronicDiseases && mp.chronicDiseases.length > 0) { %>
      <div class="health-section">
        <div class="hs-title"><i class="fas fa-disease" style="color:#ef4444;"></i> الأمراض المزمنة</div>
        <div class="hs-tags"><% mp.chronicDiseases.forEach(function(d){%><span class="hs-tag tag-red"><%= d %></span><%}) %></div>
      </div>
      <% } %>
      <% if (mp.allergies && mp.allergies.length > 0) { %>
      <div class="health-section">
        <div class="hs-title"><i class="fas fa-allergies" style="color:#f97316;"></i> الحساسية</div>
        <div class="hs-tags"><% mp.allergies.forEach(function(a){%><span class="hs-tag tag-orange"><%= a %></span><%}) %></div>
      </div>
      <% } %>
      <% if (mp.medications && mp.medications.length > 0) { %>
      <div class="health-section">
        <div class="hs-title"><i class="fas fa-pills" style="color:#8b5cf6;"></i> الأدوية الحالية</div>
        <div class="hs-tags"><% mp.medications.forEach(function(m){%><span class="hs-tag tag-purple"><%= m %></span><%}) %></div>
      </div>
      <% } %>
      <% if (mp.surgeries && mp.surgeries.length > 0) { %>
      <div class="health-section">
        <div class="hs-title"><i class="fas fa-cut" style="color:#64748b;"></i> العمليات السابقة</div>
        <div class="hs-tags"><% mp.surgeries.forEach(function(s){%><span class="hs-tag tag-gray"><%= s %></span><%}) %></div>
      </div>
      <% } %>
      <% if (mp.emergencyContact && mp.emergencyContact.name) { %>
      <div class="health-section">
        <div class="hs-title"><i class="fas fa-phone-alt" style="color:#22c55e;"></i> جهة الطوارئ</div>
        <div class="info-row"><span class="info-label">الاسم</span><span class="info-val"><%= mp.emergencyContact.name %></span></div>
        <div class="info-row"><span class="info-label">الهاتف</span><span class="info-val"><%= mp.emergencyContact.phone || '—' %></span></div>
        <div class="info-row"><span class="info-label">الصلة</span><span class="info-val"><%= mp.emergencyContact.relation || '—' %></span></div>
      </div>
      <% } %>
      <% } else { %>
      <p class="sip-empty">لا يوجد ملف صحي مكتمل</p>
      <% } %>
    </div>

    <!-- TAB: Internal Notes -->
    <div class="sip-tab-content" id="notesTab" id="notes">
      <div class="notes-list" id="notesList">
        <% if (!room.internalNotes || room.internalNotes.length === 0) { %>
        <p class="sip-empty">لا توجد ملاحظات داخلية بعد</p>
        <% } %>
        <% (room.internalNotes || []).forEach(function(note) { %>
        <div class="note-card">
          <div class="note-header">
            <% if (note.author && note.author.avatar) { %><img src="<%= note.author.avatar %>" class="note-avatar" alt=""><% } else { %><div class="note-avatar note-avatar-ph"><i class="fas fa-user"></i></div><% } %>
            <strong><%= note.author ? note.author.name : 'مجهول' %></strong>
            <small><%= new Date(note.createdAt).toLocaleString('ar-SA',{dateStyle:'short',timeStyle:'short'}) %></small>
          </div>
          <p class="note-text"><%= note.text %></p>
        </div>
        <% }) %>
      </div>
      <form method="POST" action="/admin/support/room/<%= room._id %>/note" class="note-form">
        <textarea name="text" placeholder="أضف ملاحظة داخلية... (لا يراها العميل)" rows="3" required></textarea>
        <button type="submit" class="btn btn-sm" style="background:var(--secondary);color:#fff;"><i class="fas fa-plus"></i> إضافة ملاحظة</button>
      </form>
    </div>

    <!-- TAB: Settings -->
    <div class="sip-tab-content" id="settingsTab">
      <!-- Priority -->
      <div class="settings-section">
        <div class="ss-title"><i class="fas fa-flag"></i> أولوية المحادثة</div>
        <div class="priority-btns">
          <% ['normal','medium','high','urgent'].forEach(function(p) {
            var labels = {normal:'عادي',medium:'متوسط',high:'مرتفع',urgent:'عاجل'};
            var colors = {normal:'#94a3b8',medium:'#ca8a04',high:'#f97316',urgent:'#ef4444'};
          %>
          <button onclick="setPriority('<%= p %>')" class="priority-btn <%= room.priority===p?'active':'' %>" style="border-color:<%= colors[p] %>;color:<%= colors[p] %>;" data-p="<%= p %>"><%= labels[p] %></button>
          <% }) %>
        </div>
      </div>

      <!-- Transfer -->
      <div class="settings-section">
        <div class="ss-title"><i class="fas fa-exchange-alt"></i> تحويل المحادثة</div>
        <form method="POST" action="/admin/support/room/<%= room._id %>/transfer" class="transfer-form">
          <select name="agentId" required>
            <option value="">اختر الموظف...</option>
            <% agents.forEach(function(a) { %>
            <option value="<%= a._id %>" <%= room.assignedTo && room.assignedTo._id && room.assignedTo._id.toString()===a._id.toString()?'selected':'' %>><%= a.name %></option>
            <% }) %>
          </select>
          <button type="submit" class="btn btn-sm" style="background:var(--secondary);color:#fff;"><i class="fas fa-exchange-alt"></i> تحويل</button>
        </form>
      </div>

      <!-- Room info -->
      <div class="settings-section">
        <div class="ss-title"><i class="fas fa-info-circle"></i> معلومات المحادثة</div>
        <div class="info-row"><span class="info-label">النوع</span><span class="info-val">دعم فني</span></div>
        <div class="info-row"><span class="info-label">تاريخ الفتح</span><span class="info-val"><%= new Date(room.createdAt).toLocaleString('ar-SA',{dateStyle:'short',timeStyle:'short'}) %></span></div>
        <% if (!room.isActive && room.closedAt) { %>
        <div class="info-row"><span class="info-label">تاريخ الإغلاق</span><span class="info-val"><%= new Date(room.closedAt).toLocaleString('ar-SA',{dateStyle:'short',timeStyle:'short'}) %></span></div>
        <% } %>
        <div class="info-row"><span class="info-label">ID</span><span class="info-val" style="font-size:0.72rem;word-break:break-all;"><%= room._id %></span></div>
      </div>
    </div>

  </div><!-- /info-panel -->
</div><!-- /support-layout -->

<!-- Mobile info panel toggle -->
<button class="sip-mobile-toggle" id="sipToggle" onclick="toggleInfoPanel()">
  <i class="fas fa-user-circle"></i>
</button>

<style>
.support-layout {
  display: flex;
  height: calc(100vh - 64px);
  overflow: hidden;
  flex-direction: row-reverse;
}

/* ── Chat Panel ─────────────────────────── */
.support-chat-panel {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  border-left: 1px solid var(--border);
}

.support-chat-header {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.75rem 1rem;
  border-bottom: 1px solid var(--border);
  background: var(--card-bg);
  flex-shrink: 0;
}
.sch-info { flex: 1; min-width: 0; }
.sch-info strong { display: block; font-size: 0.95rem; }
.sch-sub { font-size: 0.78rem; color: var(--text-muted); display: flex; align-items: center; gap: 0.35rem; }
.priority-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; flex-shrink: 0; }
.sch-actions { flex-shrink: 0; }

.support-messages {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  padding: 1rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  scroll-behavior: smooth;
}

/* ── AI Suggestion Bar ─────────────────── */
.ai-suggestion-bar {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  padding: 0.75rem 1rem;
  background: linear-gradient(135deg, rgba(18,169,155,0.06), rgba(18,169,155,0.02));
  border-top: 1px solid rgba(18,169,155,0.2);
  border-bottom: 1px solid rgba(18,169,155,0.2);
  flex-shrink: 0;
}
.ai-sug-label { font-size: 0.8rem; font-weight: 700; color: var(--secondary); flex-shrink: 0; display: flex; align-items: center; gap: 0.35rem; }
.ai-sug-text { flex: 1; font-size: 0.85rem; line-height: 1.5; color: var(--text); }

/* ── Input Area ──────────────────────── */
.support-input-area {
  padding: 0.75rem 1rem;
  border-top: 1px solid var(--border);
  background: var(--card-bg);
  flex-shrink: 0;
}
.sia-tools { display: flex; gap: 0.5rem; margin-bottom: 0.5rem; }
.sia-tool-btn {
  display: flex; align-items: center; gap: 0.35rem;
  padding: 0.3rem 0.75rem;
  border: 1px solid var(--border);
  border-radius: 20px;
  background: var(--bg);
  color: var(--secondary);
  font-size: 0.8rem;
  font-family: 'Tajawal', sans-serif;
  cursor: pointer;
  transition: all 0.2s;
}
.sia-tool-btn:hover { background: var(--secondary); color: #fff; border-color: var(--secondary); }
.sia-form-wrap { display: flex; gap: 0.5rem; align-items: flex-end; }
#supportReplyInput {
  flex: 1;
  padding: 0.7rem 1rem;
  border: 1px solid var(--border);
  border-radius: 14px;
  background: var(--bg);
  color: var(--text);
  font-family: 'Tajawal', sans-serif;
  font-size: 0.9rem;
  resize: none;
  outline: none;
  max-height: 120px;
  overflow-y: auto;
  line-height: 1.5;
}
#supportReplyInput:focus { border-color: var(--secondary); }
.sia-send-btn {
  width: 42px; height: 42px;
  border-radius: 50%;
  background: var(--secondary);
  color: #fff;
  border: none;
  font-size: 1rem;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  transition: opacity 0.2s;
}
.sia-send-btn:hover { opacity: 0.85; }
.support-closed-notice {
  padding: 1rem;
  text-align: center;
  color: var(--text-muted);
  font-size: 0.85rem;
  border-top: 1px solid var(--border);
  flex-shrink: 0;
}

/* ── Info Panel ─────────────────────── */
.support-info-panel {
  width: 320px;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: var(--card-bg);
  border-left: 1px solid var(--border);
}

.sip-tabs {
  display: flex;
  overflow-x: auto;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
  scrollbar-width: none;
}
.sip-tabs::-webkit-scrollbar { display: none; }
.sip-tab {
  flex-shrink: 0;
  padding: 0.65rem 0.85rem;
  border: none;
  background: none;
  font-family: 'Tajawal', sans-serif;
  font-size: 0.78rem;
  color: var(--text-muted);
  cursor: pointer;
  border-bottom: 2px solid transparent;
  display: flex; align-items: center; gap: 0.3rem;
  transition: all 0.2s;
  white-space: nowrap;
}
.sip-tab.active { color: var(--secondary); border-bottom-color: var(--secondary); }
.notes-count { background: var(--secondary); color: #fff; border-radius: 50%; width: 16px; height: 16px; font-size: 0.65rem; display: flex; align-items: center; justify-content: center; }

.sip-tab-content { display: none; flex: 1; overflow-y: auto; padding: 1rem; }
.sip-tab-content.active { display: block; }

/* User card mini */
.user-card-mini { display: flex; align-items: center; gap: 0.75rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border); margin-bottom: 1rem; }
.ucm-avatar { width: 52px; height: 52px; border-radius: 50%; object-fit: cover; flex-shrink: 0; }
.ucm-avatar-ph { background: var(--secondary); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 1.4rem; }
.ucm-role { margin-top: 0.25rem; }

/* Info rows */
.info-section { display: flex; flex-direction: column; gap: 0.15rem; }
.info-row { display: flex; justify-content: space-between; align-items: flex-start; padding: 0.4rem 0; border-bottom: 1px solid var(--border); gap: 0.5rem; }
.info-row:last-child { border-bottom: none; }
.info-label { font-size: 0.78rem; color: var(--text-muted); display: flex; align-items: center; gap: 0.3rem; flex-shrink: 0; }
.info-val { font-size: 0.82rem; font-weight: 600; text-align: left; word-break: break-word; }

/* Requests */
.sip-section-title { font-size: 0.8rem; font-weight: 700; color: var(--text-muted); margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.35rem; }
.sip-empty { font-size: 0.83rem; color: var(--text-muted); padding: 0.5rem 0; }
.req-card { padding: 0.65rem; background: var(--bg); border-radius: 10px; border: 1px solid var(--border); margin-bottom: 0.5rem; }
.req-card-title { font-size: 0.85rem; font-weight: 700; }
.req-card-sub { font-size: 0.78rem; color: var(--text-muted); margin: 0.2rem 0; }
.req-card-foot { display: flex; justify-content: space-between; align-items: center; margin-top: 0.35rem; }

/* Health */
.health-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 0.5rem; margin-bottom: 1rem; }
.health-card { padding: 0.65rem; background: var(--bg); border-radius: 10px; border: 1px solid var(--border); display: flex; align-items: center; gap: 0.5rem; }
.hc-icon { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 0.9rem; flex-shrink: 0; }
.hc-info small { display: block; font-size: 0.65rem; color: var(--text-muted); }
.hc-info strong { font-size: 0.82rem; }
.health-section { margin-bottom: 0.75rem; }
.hs-title { font-size: 0.78rem; font-weight: 700; margin-bottom: 0.4rem; display: flex; align-items: center; gap: 0.3rem; }
.hs-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; }
.hs-tag { padding: 0.2rem 0.6rem; border-radius: 20px; font-size: 0.75rem; font-weight: 600; }
.tag-red { background: rgba(239,68,68,0.1); color: #ef4444; }
.tag-orange { background: rgba(249,115,22,0.1); color: #f97316; }
.tag-purple { background: rgba(139,92,246,0.1); color: #8b5cf6; }
.tag-gray { background: rgba(100,116,139,0.1); color: #64748b; }

/* Notes */
.notes-list { margin-bottom: 1rem; display: flex; flex-direction: column; gap: 0.65rem; }
.note-card { background: rgba(234,179,8,0.06); border: 1px solid rgba(234,179,8,0.25); border-radius: 10px; padding: 0.75rem; }
.note-header { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; }
.note-avatar { width: 26px; height: 26px; border-radius: 50%; object-fit: cover; }
.note-avatar-ph { background: var(--secondary); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 0.7rem; }
.note-header small { color: var(--text-muted); font-size: 0.72rem; margin-right: auto; }
.note-text { font-size: 0.83rem; margin: 0; line-height: 1.5; }
.note-form { display: flex; flex-direction: column; gap: 0.5rem; }
.note-form textarea { padding: 0.65rem; border: 1px solid var(--border); border-radius: 10px; background: var(--bg); color: var(--text); font-family: 'Tajawal', sans-serif; font-size: 0.85rem; resize: vertical; }

/* Settings */
.settings-section { margin-bottom: 1.25rem; padding-bottom: 1.25rem; border-bottom: 1px solid var(--border); }
.settings-section:last-child { border-bottom: none; }
.ss-title { font-size: 0.8rem; font-weight: 700; color: var(--text-muted); margin-bottom: 0.65rem; display: flex; align-items: center; gap: 0.35rem; }
.priority-btns { display: flex; flex-wrap: wrap; gap: 0.4rem; }
.priority-btn { padding: 0.3rem 0.75rem; border-radius: 20px; border: 1px solid; background: transparent; font-family: 'Tajawal', sans-serif; font-size: 0.8rem; cursor: pointer; transition: all 0.2s; }
.priority-btn.active { color: #fff !important; }
.priority-btn[data-p="normal"].active { background: #94a3b8; border-color: #94a3b8; }
.priority-btn[data-p="medium"].active { background: #ca8a04; border-color: #ca8a04; }
.priority-btn[data-p="high"].active { background: #f97316; border-color: #f97316; }
.priority-btn[data-p="urgent"].active { background: #ef4444; border-color: #ef4444; }
.transfer-form { display: flex; flex-direction: column; gap: 0.5rem; }
.transfer-form select { padding: 0.5rem 0.75rem; border: 1px solid var(--border); border-radius: 8px; background: var(--bg); color: var(--text); font-family: 'Tajawal', sans-serif; font-size: 0.85rem; }

/* Mobile toggle */
.sip-mobile-toggle {
  display: none;
  position: fixed;
  bottom: 80px;
  left: 16px;
  width: 44px; height: 44px;
  border-radius: 50%;
  background: var(--secondary);
  color: #fff;
  border: none;
  font-size: 1.2rem;
  cursor: pointer;
  z-index: 100;
  box-shadow: 0 4px 14px rgba(18,169,155,0.4);
  align-items: center; justify-content: center;
}

@media (max-width: 768px) {
  .support-layout { flex-direction: column; }
  .support-info-panel {
    width: 100%;
    height: 50vh;
    border-left: none;
    border-top: 1px solid var(--border);
    display: none;
  }
  .support-info-panel.open { display: flex; }
  .sip-mobile-toggle { display: flex; }
}

/* Typing indicator reuse */
.chat-typing-bubble { display:flex;align-items:center;gap:4px;padding:0.65rem 1rem !important; }
.chat-typing-bubble span { width:7px;height:7px;border-radius:50%;background:var(--text-muted);animation:typingDot 1.2s infinite; }
.chat-typing-bubble span:nth-child(2){animation-delay:.2s}
.chat-typing-bubble span:nth-child(3){animation-delay:.4s}
@keyframes typingDot{0%,60%,100%{transform:translateY(0);opacity:.4}30%{transform:translateY(-5px);opacity:1}}

.chat-msg-avatar-ph {
  width:36px;height:36px;border-radius:50%;background:var(--secondary);
  display:flex;align-items:center;justify-content:center;color:#fff;font-size:0.85rem;
}
</style>

<script>
var roomId = '<%= room._id %>';
var myId = '<%= user._id %>';
var chatArea = document.getElementById('chatMessages');

/* ── Scroll ── */
function scrollBottom(smooth) {
  chatArea.scrollTo({ top: chatArea.scrollHeight, behavior: smooth ? 'smooth' : 'instant' });
}
scrollBottom(false);
setTimeout(function(){ scrollBottom(false); }, 200);
window.addEventListener('load', function(){ scrollBottom(false); });
chatArea.querySelectorAll('img').forEach(function(img){
  img.addEventListener('load', function(){ scrollBottom(false); });
});

/* ── Tabs ── */
function showTab(tabId, btn) {
  document.querySelectorAll('.sip-tab-content').forEach(function(el){ el.classList.remove('active'); });
  document.querySelectorAll('.sip-tab').forEach(function(el){ el.classList.remove('active'); });
  document.getElementById(tabId).classList.add('active');
  btn.classList.add('active');
}

/* ── Mobile toggle ── */
function toggleInfoPanel() {
  document.querySelector('.support-info-panel').classList.toggle('open');
}

/* ── Send Reply ── */
async function sendReply() {
  var input = document.getElementById('supportReplyInput');
  var text = input.value.trim();
  if (!text) return;
  var btn = document.getElementById('sendBtn');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';

  try {
    var res = await fetch('/admin/support/room/' + roomId + '/reply', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ text: text })
    });
    var data = await res.json();
    if (data.success) {
      input.value = '';
      input.style.height = 'auto';
      addAdminMsg(data.message);
      closeSuggestion();
    } else {
      alert(data.error || 'خطأ في الإرسال');
    }
  } catch(err) { console.error(err); }
  btn.disabled = false;
  btn.innerHTML = '<i class="fas fa-paper-plane"></i>';
}

/* ── Add message to DOM ── */
function addAdminMsg(msg) {
  var div = document.createElement('div');
  div.className = 'chat-msg chat-msg-me';
  var now = new Date();
  div.innerHTML = '<div class="chat-msg-content">' +
    '<div class="chat-bubble"><p>' + escHtml(msg.text) + '</p>' +
    '<div class="chat-msg-time">' + now.toLocaleString('ar-SA',{hour:'2-digit',minute:'2-digit'}) +
    ' <i class="fas fa-check-double" style="opacity:0.7;"></i></div></div></div>';
  var typi = document.getElementById('typingIndicator');
  chatArea.insertBefore(div, typi || null);
  scrollBottom(true);
}

function addUserMsg(msg) {
  var div = document.createElement('div');
  div.className = 'chat-msg chat-msg-other';
  var senderName = msg.sender ? msg.sender.name : '';
  div.innerHTML = '<div class="chat-msg-content">' +
    '<div class="chat-msg-sender">' + escHtml(senderName) + '</div>' +
    '<div class="chat-bubble"><p>' + escHtml(msg.text) + '</p>' +
    '<div class="chat-msg-time">' + new Date(msg.createdAt||Date.now()).toLocaleString('ar-SA',{hour:'2-digit',minute:'2-digit'}) + '</div>' +
    '</div></div>';
  var typi = document.getElementById('typingIndicator');
  chatArea.insertBefore(div, typi || null);
  scrollBottom(true);
}

function escHtml(s) {
  var d = document.createElement('div');
  d.textContent = s || '';
  return d.innerHTML;
}

/* ── Enter to send ── */
var replyInput = document.getElementById('supportReplyInput');
if (replyInput) {
  replyInput.addEventListener('keydown', function(e){
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendReply(); }
  });
  replyInput.addEventListener('input', function(){
    this.style.height = 'auto';
    this.style.height = Math.min(this.scrollHeight, 120) + 'px';
  });
}

/* ── AI Suggest ── */
async function aiSuggest() {
  var btn = document.querySelector('.sia-tool-btn');
  var origHtml = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري التفكير...';

  try {
    var res = await fetch('/admin/support/room/' + roomId + '/ai-suggest', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
    var data = await res.json();
    if (data.suggestion) {
      document.getElementById('aiSugText').textContent = data.suggestion;
      document.getElementById('aiSuggestionBar').style.display = 'flex';
    } else {
      alert('لم يتمكن الذكاء الاصطناعي من توليد اقتراح الآن');
    }
  } catch(err) { console.error(err); }
  btn.disabled = false;
  btn.innerHTML = origHtml;
}

function useSuggestion() {
  var text = document.getElementById('aiSugText').textContent;
  if (replyInput) { replyInput.value = text; replyInput.focus(); }
  closeSuggestion();
}

function closeSuggestion() {
  document.getElementById('aiSuggestionBar').style.display = 'none';
}

/* ── Priority ── */
async function setPriority(p) {
  try {
    var res = await fetch('/admin/support/room/' + roomId + '/priority', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ priority: p })
    });
    var data = await res.json();
    if (data.success) {
      document.querySelectorAll('.priority-btn').forEach(function(btn){ btn.classList.remove('active'); });
      document.querySelector('.priority-btn[data-p="' + p + '"]').classList.add('active');
    }
  } catch(err) { console.error(err); }
}

/* ── Socket.io real-time ── */
if (typeof io !== 'undefined') {
  var socket = io();
  var typingTimer;

  socket.on('chat_message', function(data) {
    if (data.roomId.toString() === roomId) {
      if (data.message.sender && !['admin','moderator'].includes(data.message.sender.role)) {
        hideTyping();
        addUserMsg(data.message);
      }
    }
  });

  socket.on('chat_typing', function(data) {
    if (data.roomId.toString() === roomId && data.userId !== myId) {
      showTyping();
      clearTimeout(typingTimer);
      typingTimer = setTimeout(hideTyping, 3000);
    }
  });

  if (replyInput) {
    replyInput.addEventListener('input', function(){
      socket.emit('typing', { roomId: roomId });
    });
  }
}

function showTyping() {
  var el = document.getElementById('typingIndicator');
  if (el) { el.style.display = 'flex'; scrollBottom(true); }
}
function hideTyping() {
  var el = document.getElementById('typingIndicator');
  if (el) el.style.display = 'none';
}

/* ── Handle hash scroll to notes ── */
if (window.location.hash === '#notes') {
  setTimeout(function(){ document.querySelector('[onclick="showTab(\'notesTab\',this)"]').click(); }, 100);
}
</script>
<%- include('../partials/footer') %>
