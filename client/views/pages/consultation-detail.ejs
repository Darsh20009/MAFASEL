<%- include('../partials/header') %>
<div class="main-content">
  <div class="container">
    <div class="page-header">
      <h1><i class="fas fa-stethoscope"></i> تفاصيل الاستشارة</h1>
      <a href="/consultations" class="btn btn-outline">العودة</a>
    </div>

    <div class="detail-grid">
      <div class="detail-info">
        <div class="card">
          <h3>معلومات الاستشارة</h3>
          <div class="info-row"><span>التخصص:</span><strong><%= consultation.specialty %></strong></div>
          <div class="info-row"><span>الأولوية:</span><span class="badge badge-<%= consultation.priority === 'urgent' ? 'error' : 'warning' %>"><%= consultation.priority === 'urgent' ? 'عاجلة' : consultation.priority === 'high' ? 'مرتفعة' : consultation.priority === 'medium' ? 'متوسطة' : 'منخفضة' %></span></div>
          <div class="info-row"><span>الحالة:</span><span class="badge badge-<%= consultation.status === 'completed' ? 'success' : 'primary' %>"><%= consultation.status === 'pending' ? 'معلقة' : consultation.status === 'assigned' ? 'تم التعيين' : consultation.status === 'in_progress' ? 'جارية' : consultation.status === 'completed' ? 'مكتملة' : 'ملغاة' %></span></div>
          <% if (consultation.price) { %>
          <div class="info-row">
            <span>السعر:</span>
            <strong style="color:var(--teal)"><%= consultation.price %> ر.س</strong>
          </div>
          <div class="info-row">
            <span>الدفع:</span>
            <span class="badge badge-<%= consultation.paymentStatus === 'paid' ? 'success' : 'warning' %>">
              <i class="fas fa-<%= consultation.paymentStatus === 'paid' ? 'check-circle' : 'clock' %>"></i>
              <%= consultation.paymentStatus === 'paid' ? 'مدفوعة' : 'غير مدفوعة' %>
              <% if (consultation.paymentMethod && consultation.paymentStatus === 'paid') { %>
              — <%= consultation.paymentMethod === 'card' ? 'بطاقة' : consultation.paymentMethod === 'apple_pay' ? 'Apple Pay' : consultation.paymentMethod === 'insurance' ? 'تأمين' : consultation.paymentMethod === 'health_card' ? 'بطاقة صحية' : 'نقد' %>
              <% } %>
            </span>
          </div>
          <% if (consultation.insuranceDiscount > 0) { %>
          <div class="info-row">
            <span>خصم التأمين:</span>
            <strong style="color:#16a34a"><%= consultation.insuranceDiscount %> ر.س</strong>
          </div>
          <% } %>
          <% } %>
          <% if (consultation.doctor) { %>
          <div class="info-row"><span>الأخصائي:</span><strong><%= consultation.doctor.name %></strong></div>
          <% } %>
          <div class="info-row"><span>التاريخ:</span><strong><%= new Date(consultation.createdAt).toLocaleDateString('ar-SA') %></strong></div>
          <h4>الأعراض</h4>
          <p><%= consultation.symptoms %></p>
          <% if (consultation.diagnosis) { %>
          <h4>التشخيص</h4>
          <p><%= consultation.diagnosis %></p>
          <% } %>
          <% if (consultation.prescription) { %>
          <h4>الوصفة الطبية</h4>
          <p><%= consultation.prescription %></p>
          <% } %>
        </div>
      </div>

      <div class="chat-section">
        <div class="card">
          <h3><i class="fas fa-comments"></i> المحادثة</h3>
          <% if (consultation.status === 'pending' && (!consultation.doctor)) { %>
          <div style="text-align:center;padding:2rem;color:var(--muted,#6b7280)">
            <i class="fas fa-hourglass-half" style="font-size:2.5rem;margin-bottom:0.8rem;display:block;color:var(--teal)"></i>
            <h4 style="margin-bottom:0.3rem">بانتظار تعيين أخصائي</h4>
            <p style="font-size:0.85rem">سيتم تعيين أخصائي لك قريباً وستتمكن من التواصل معه هنا</p>
          </div>
          <% } else { %>
          <div class="chat-messages" id="chatMessages">
            <% consultation.messages.forEach(function(msg) { %>
            <div class="chat-msg <%= msg.sender && msg.sender._id.toString() === user._id.toString() ? 'msg-sent' : 'msg-received' %>">
              <div class="msg-header">
                <strong><%= msg.sender ? msg.sender.name : 'مجهول' %></strong>
                <span class="msg-time"><%= new Date(msg.createdAt).toLocaleTimeString('ar-SA', {hour: '2-digit', minute: '2-digit'}) %></span>
              </div>
              <p><%= msg.text %></p>
            </div>
            <% }) %>
          </div>
          <% if (consultation.status !== 'completed' && consultation.status !== 'cancelled') { %>
          <form class="chat-input" id="chatForm">
            <input type="text" id="chatText" placeholder="اكتب رسالتك..." required>
            <button type="submit" class="btn btn-primary"><i class="fas fa-paper-plane"></i></button>
          </form>
          <% } %>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  var chatForm = document.getElementById('chatForm');
  if (chatForm) {
    chatForm.addEventListener('submit', async function(e) {
      e.preventDefault();
      var text = document.getElementById('chatText').value.trim();
      if (!text) return;
      try {
        var res = await fetch('/consultations/<%= consultation._id %>/message', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ text: text })
        });
        if (res.ok) {
          var msgDiv = document.createElement('div');
          msgDiv.className = 'chat-msg msg-sent';
          var header = document.createElement('div');
          header.className = 'msg-header';
          var strong = document.createElement('strong');
          strong.textContent = '<%= user.name %>';
          var timeSpan = document.createElement('span');
          timeSpan.className = 'msg-time';
          timeSpan.textContent = 'الآن';
          header.appendChild(strong);
          header.appendChild(timeSpan);
          var p = document.createElement('p');
          p.textContent = text;
          msgDiv.appendChild(header);
          msgDiv.appendChild(p);
          document.getElementById('chatMessages').appendChild(msgDiv);
          document.getElementById('chatText').value = '';
          msgDiv.scrollIntoView({ behavior: 'smooth' });
        }
      } catch(err) { console.error(err); }
    });
  }
</script>
<%- include('../partials/footer') %>
