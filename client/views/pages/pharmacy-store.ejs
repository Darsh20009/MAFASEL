<%- include('../partials/header') %>
<div class="main-content">
  <div class="container">
    <div style="margin-bottom:1.25rem;">
      <a href="/pharmacy" style="color:var(--text-muted);text-decoration:none;font-size:0.85rem;"><i class="fas fa-arrow-right"></i> العودة للصيدليات</a>
    </div>

    <div class="card" style="padding:0;border-radius:16px;overflow:hidden;margin-bottom:1.5rem;">
      <div style="height:140px;background:linear-gradient(135deg,#0f1923,#1a2736);display:flex;align-items:center;justify-content:center;position:relative;">
        <% if (pharmacy.cover) { %>
        <img src="<%= pharmacy.cover %>" style="width:100%;height:100%;object-fit:cover;opacity:0.6;">
        <% } %>
        <div style="position:absolute;bottom:0;left:0;right:0;padding:1rem 1.25rem;background:linear-gradient(transparent,rgba(0,0,0,0.7));">
          <div style="display:flex;align-items:center;gap:0.75rem;">
            <div style="width:50px;height:50px;border-radius:14px;background:var(--card-bg);display:flex;align-items:center;justify-content:center;border:2px solid var(--secondary);flex-shrink:0;">
              <% if (pharmacy.logo) { %>
              <img src="<%= pharmacy.logo %>" style="width:46px;height:46px;border-radius:12px;object-fit:cover;">
              <% } else { %>
              <i class="fas fa-prescription-bottle-alt" style="color:var(--secondary);font-size:1.2rem;"></i>
              <% } %>
            </div>
            <div>
              <h1 style="margin:0;font-size:1.2rem;"><%= pharmacy.name %></h1>
              <div style="font-size:0.78rem;color:#cbd5e1;margin-top:2px;">
                <i class="fas fa-map-marker-alt"></i> <%= pharmacy.location.city || 'الرياض' %>
                &middot; <i class="fas fa-star" style="color:#f59e0b;"></i> <%= pharmacy.rating.toFixed(1) %>
                &middot; <i class="fas fa-clock"></i> <%= pharmacy.workingHours %>
              </div>
            </div>
          </div>
        </div>
      </div>
      <% if (pharmacy.description) { %>
      <div style="padding:0.85rem 1.25rem;font-size:0.82rem;color:var(--text-muted);border-bottom:1px solid rgba(255,255,255,0.05);"><%= pharmacy.description %></div>
      <% } %>
      <div style="padding:0.65rem 1.25rem;display:flex;gap:1rem;font-size:0.78rem;color:var(--text-muted);">
        <% if (pharmacy.phone) { %><span><i class="fas fa-phone"></i> <%= pharmacy.phone %></span><% } %>
        <% if (pharmacy.deliveryFee > 0) { %><span><i class="fas fa-truck"></i> توصيل: <%= pharmacy.deliveryFee %> ر.س</span><% } else { %><span style="color:var(--secondary);"><i class="fas fa-truck"></i> توصيل مجاني</span><% } %>
        <% if (pharmacy.freeDeliveryAbove > 0) { %><span>مجاني فوق <%= pharmacy.freeDeliveryAbove %> ر.س</span><% } %>
        <% if (pharmacy.insuranceSupported) { %><span style="color:var(--secondary);"><i class="fas fa-shield-alt"></i> يدعم التأمين</span><% } %>
      </div>
    </div>

    <div class="tabs">
      <button class="tab-btn active" onclick="switchTab('drugs', this)"><i class="fas fa-capsules"></i> الأدوية (<%= drugs.length %>)</button>
      <button class="tab-btn" onclick="switchTab('cart', this)"><i class="fas fa-shopping-cart"></i> السلة <span id="cartCount" class="badge badge-primary" style="font-size:0.7rem;">0</span></button>
    </div>

    <div id="tab-drugs" class="tab-content active">
      <% if (categories.length > 1) { %>
      <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1rem;">
        <button class="btn btn-sm btn-outline cat-btn active" onclick="filterCat('all', this)" style="font-size:0.75rem;">الكل</button>
        <% categories.forEach(function(c) { %>
        <button class="btn btn-sm btn-outline cat-btn" onclick="filterCat('<%= c %>', this)" style="font-size:0.75rem;"><%= c %></button>
        <% }) %>
      </div>
      <% } %>

      <div id="drugsGrid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:1rem;">
        <% drugs.forEach(function(d) { %>
        <div class="card drug-card" data-category="<%= d.category %>" style="padding:1rem;border-radius:14px;position:relative;">
          <% if (d.prescription) { %>
          <span style="position:absolute;top:8px;left:8px;background:#f59e0b20;color:#f59e0b;font-size:0.65rem;padding:2px 8px;border-radius:6px;font-weight:600;"><i class="fas fa-file-medical"></i> بوصفة</span>
          <% } %>
          <% if (d.insuranceSupported) { %>
          <span style="position:absolute;top:8px;right:8px;background:var(--secondary)15;color:var(--secondary);font-size:0.65rem;padding:2px 8px;border-radius:6px;font-weight:600;"><i class="fas fa-shield-alt"></i> تأمين</span>
          <% } %>
          <div style="text-align:center;padding:0.75rem 0;">
            <% if (d.image) { %>
            <img src="<%= d.image %>" style="height:70px;border-radius:8px;object-fit:contain;">
            <% } else { %>
            <div style="width:60px;height:60px;border-radius:14px;background:var(--secondary)10;display:flex;align-items:center;justify-content:center;margin:0 auto;">
              <i class="fas fa-pills" style="color:var(--secondary);font-size:1.4rem;"></i>
            </div>
            <% } %>
          </div>
          <strong style="display:block;font-size:0.9rem;margin-bottom:2px;"><%= d.name %></strong>
          <div style="font-size:0.75rem;color:var(--text-muted);margin-bottom:4px;"><%= d.category %><% if (d.dosage) { %> &middot; <%= d.dosage %><% } %></div>
          <% if (d.description) { %>
          <p style="font-size:0.78rem;color:var(--text-muted);margin:0 0 0.5rem;line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;"><%= d.description %></p>
          <% } %>
          <div style="display:flex;align-items:center;justify-content:space-between;margin-top:auto;">
            <div>
              <strong style="color:var(--secondary);font-size:1rem;"><%= d.price %></strong> <span style="font-size:0.75rem;color:var(--text-muted);">ر.س</span>
              <% if (d.insuranceSupported && d.insurancePrice != null) { %>
              <div style="font-size:0.7rem;color:var(--secondary);"><i class="fas fa-shield-alt"></i> بالتأمين: <%= d.insurancePrice %> ر.س</div>
              <% } %>
              <% if (d.originalPrice && d.originalPrice > d.price) { %>
              <span style="text-decoration:line-through;color:var(--text-muted);font-size:0.75rem;margin-right:4px;"><%= d.originalPrice %></span>
              <% } %>
            </div>
            <button class="btn btn-sm" style="background:var(--secondary);color:#fff;" onclick="addToCart('<%= d._id %>','<%= d.name.replace(/'/g,"\\'" ) %>',<%= d.price %>,<%= d.insuranceSupported %>,<%= d.insurancePrice || 0 %>,<%= d.prescription %>)">
              <i class="fas fa-cart-plus"></i>
            </button>
          </div>
          <% if (d.stock <= 10 && d.stock > 0) { %>
          <div style="font-size:0.68rem;color:#f59e0b;margin-top:4px;"><i class="fas fa-exclamation-triangle"></i> متبقي <%= d.stock %> فقط</div>
          <% } %>
        </div>
        <% }) %>
      </div>

      <% if (drugs.length === 0) { %>
      <div class="empty-state-premium">
        <div class="empty-icon"><i class="fas fa-pills"></i></div>
        <h3>لا توجد أدوية متاحة</h3>
      </div>
      <% } %>
    </div>

    <div id="tab-cart" class="tab-content">
      <div id="cartItems" style="display:flex;flex-direction:column;gap:0.75rem;"></div>
      <div id="cartEmpty" class="empty-state-premium">
        <div class="empty-icon"><i class="fas fa-shopping-cart"></i></div>
        <h3>السلة فارغة</h3>
        <p>أضف أدوية من القائمة</p>
      </div>

      <div id="cartCheckout" style="display:none;margin-top:1.25rem;">
        <div class="card" style="padding:1.25rem;border-radius:14px;margin-bottom:1rem;">
          <h3 style="margin:0 0 0.75rem;font-size:0.95rem;"><i class="fas fa-receipt" style="color:var(--secondary);"></i> ملخص الطلب</h3>
          <div id="cartSummary" style="font-size:0.85rem;"></div>
        </div>

        <div class="card" style="padding:1.25rem;border-radius:14px;">
          <h3 style="margin:0 0 1rem;font-size:0.95rem;"><i class="fas fa-truck" style="color:var(--secondary);"></i> معلومات التوصيل</h3>

          <% if (insurance && pharmacy.insuranceSupported) { %>
          <div style="margin-bottom:1rem;padding:0.85rem;border-radius:10px;background:var(--secondary)08;border:1px solid var(--secondary)20;">
            <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;font-size:0.85rem;">
              <input type="checkbox" id="useInsurance" onchange="toggleInsurance()">
              <i class="fas fa-shield-alt" style="color:var(--secondary);"></i>
              <span>استخدام التأمين — <strong><%= insurance.company %></strong> (<%= insurance.type %>)</span>
            </label>
            <div style="font-size:0.75rem;color:var(--text-muted);margin-top:4px;padding-right:1.75rem;">
              الرصيد المتبقي: <strong style="color:var(--secondary);"><%= (insurance.coverageAmount - insurance.usedAmount).toFixed(0) %> ر.س</strong>
            </div>
          </div>
          <% } %>

          <div style="margin-bottom:0.85rem;">
            <label style="font-size:0.82rem;color:var(--text-muted);display:block;margin-bottom:0.3rem;">طريقة الدفع</label>
            <div style="display:flex;gap:0.5rem;flex-wrap:wrap;" id="paymentMethods">
              <label class="payment-method-option selected" onclick="selectPayment('cash', this)">
                <input type="radio" name="payMethod" value="cash" checked style="display:none;">
                <i class="fas fa-money-bill-wave"></i>
                <span>نقد عند الاستلام</span>
              </label>
              <label class="payment-method-option" onclick="selectPayment('card', this)">
                <input type="radio" name="payMethod" value="card" style="display:none;">
                <i class="fas fa-credit-card"></i>
                <span>بطاقة ائتمان</span>
              </label>
              <label class="payment-method-option" onclick="selectPayment('apple_pay', this)">
                <input type="radio" name="payMethod" value="apple_pay" style="display:none;">
                <i class="fab fa-apple"></i>
                <span>Apple Pay</span>
              </label>
            </div>
          </div>

          <div id="cardFormSection" style="display:none;margin-bottom:1rem;">
            <div style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:12px;padding:1rem;">
              <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.85rem;">
                <i class="fas fa-lock" style="color:var(--accent);font-size:0.8rem;"></i>
                <span style="font-size:0.78rem;color:var(--text-muted);">دفع آمن — محاكاة</span>
                <div style="margin-right:auto;display:flex;gap:0.3rem;">
                  <i class="fab fa-cc-visa" style="font-size:1.2rem;color:#1a1f71;"></i>
                  <i class="fab fa-cc-mastercard" style="font-size:1.2rem;color:#eb001b;"></i>
                  <i class="fab fa-cc-amex" style="font-size:1.2rem;color:#006fcf;"></i>
                </div>
              </div>
              <div style="margin-bottom:0.65rem;">
                <label style="font-size:0.78rem;color:var(--text-muted);display:block;margin-bottom:0.25rem;">رقم البطاقة</label>
                <input type="text" id="cardNumber" class="form-control" placeholder="0000 0000 0000 0000" maxlength="19" dir="ltr" style="font-family:monospace;letter-spacing:2px;" oninput="formatCardNumber(this)">
              </div>
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;margin-bottom:0.65rem;">
                <div>
                  <label style="font-size:0.78rem;color:var(--text-muted);display:block;margin-bottom:0.25rem;">تاريخ الانتهاء</label>
                  <input type="text" id="cardExpiry" class="form-control" placeholder="MM/YY" maxlength="5" dir="ltr" style="font-family:monospace;" oninput="formatExpiry(this)">
                </div>
                <div>
                  <label style="font-size:0.78rem;color:var(--text-muted);display:block;margin-bottom:0.25rem;">CVV</label>
                  <input type="password" id="cardCVV" class="form-control" placeholder="•••" maxlength="4" dir="ltr" style="font-family:monospace;">
                </div>
              </div>
              <div>
                <label style="font-size:0.78rem;color:var(--text-muted);display:block;margin-bottom:0.25rem;">اسم حامل البطاقة</label>
                <input type="text" id="cardHolder" class="form-control" placeholder="الاسم كما هو على البطاقة" dir="ltr">
              </div>
            </div>
          </div>

          <div style="margin-bottom:0.85rem;">
            <label style="font-size:0.82rem;color:var(--text-muted);display:block;margin-bottom:0.3rem;">عنوان التوصيل *</label>
            <input type="text" id="orderAddress" class="form-control" placeholder="المدينة - الحي - الشارع" required>
          </div>
          <div style="margin-bottom:1rem;">
            <label style="font-size:0.82rem;color:var(--text-muted);display:block;margin-bottom:0.3rem;">ملاحظات (اختياري)</label>
            <textarea id="orderNotes" class="form-control" rows="2" placeholder="ملاحظات إضافية..."></textarea>
          </div>
          <button class="btn" style="width:100%;background:var(--secondary);color:#fff;padding:0.85rem;font-size:1rem;border-radius:12px;" onclick="submitOrder()" id="submitOrderBtn">
            <i class="fas fa-check-circle"></i> تأكيد الطلب
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
var cart = [];
var pharmacyId = '<%= pharmacy._id %>';
var deliveryFee = <%= pharmacy.deliveryFee || 0 %>;
var freeAbove = <%= pharmacy.freeDeliveryAbove || 0 %>;
var insuranceId = '<%= insurance ? insurance._id : "" %>';
var useIns = false;

function addToCart(drugId, name, price, insSupported, insPrice, prescription) {
  var existing = cart.find(function(i) { return i.drugId === drugId; });
  if (existing) { existing.quantity++; }
  else { cart.push({ drugId: drugId, name: name, price: price, insSupported: insSupported, insPrice: insPrice, prescription: prescription, quantity: 1 }); }
  updateCart();
  document.getElementById('cartCount').textContent = cart.reduce(function(s,i){ return s + i.quantity; }, 0);
}

function removeFromCart(drugId) {
  cart = cart.filter(function(i) { return i.drugId !== drugId; });
  updateCart();
}

function changeQty(drugId, delta) {
  var item = cart.find(function(i) { return i.drugId === drugId; });
  if (!item) return;
  item.quantity += delta;
  if (item.quantity <= 0) { removeFromCart(drugId); return; }
  updateCart();
}

function toggleInsurance() {
  useIns = document.getElementById('useInsurance') ? document.getElementById('useInsurance').checked : false;
  updateCart();
}

function updateCart() {
  document.getElementById('cartCount').textContent = cart.reduce(function(s,i){ return s + i.quantity; }, 0);
  var itemsDiv = document.getElementById('cartItems');
  var emptyDiv = document.getElementById('cartEmpty');
  var checkoutDiv = document.getElementById('cartCheckout');

  if (cart.length === 0) {
    itemsDiv.innerHTML = '';
    emptyDiv.style.display = 'block';
    checkoutDiv.style.display = 'none';
    return;
  }

  emptyDiv.style.display = 'none';
  checkoutDiv.style.display = 'block';

  var subtotal = 0;
  var insDiscount = 0;
  itemsDiv.innerHTML = cart.map(function(item) {
    var itemPrice = item.price;
    var itemTotal = item.price * item.quantity;
    if (useIns && item.insSupported && item.insPrice > 0) {
      insDiscount += (item.price - item.insPrice) * item.quantity;
      itemTotal = item.insPrice * item.quantity;
    }
    subtotal += item.price * item.quantity;
    return '<div class="card" style="padding:0.85rem;border-radius:12px;"><div style="display:flex;align-items:center;gap:0.75rem;">' +
      '<div style="flex:1;min-width:0;"><strong style="font-size:0.88rem;">' + item.name + '</strong>' +
      (item.prescription ? ' <span style="font-size:0.65rem;color:#f59e0b;"><i class="fas fa-file-medical"></i></span>' : '') +
      (useIns && item.insSupported ? ' <span style="font-size:0.65rem;color:var(--secondary);"><i class="fas fa-shield-alt"></i></span>' : '') +
      '<div style="font-size:0.78rem;color:var(--text-muted);">' + item.price + ' ر.س' +
      (useIns && item.insSupported && item.insPrice > 0 ? ' → <span style="color:var(--secondary);">' + item.insPrice + ' ر.س</span>' : '') +
      '</div></div>' +
      '<div style="display:flex;align-items:center;gap:0.4rem;">' +
      '<button class="btn btn-sm btn-outline" onclick="changeQty(\'' + item.drugId + '\',-1)" style="width:28px;height:28px;padding:0;font-size:0.8rem;">−</button>' +
      '<span style="min-width:24px;text-align:center;font-weight:600;">' + item.quantity + '</span>' +
      '<button class="btn btn-sm btn-outline" onclick="changeQty(\'' + item.drugId + '\',1)" style="width:28px;height:28px;padding:0;font-size:0.8rem;">+</button>' +
      '</div>' +
      '<button class="btn btn-sm" style="background:#ef444420;color:#ef4444;border:none;" onclick="removeFromCart(\'' + item.drugId + '\')"><i class="fas fa-trash"></i></button>' +
      '</div></div>';
  }).join('');

  var actualDelivery = (freeAbove > 0 && subtotal >= freeAbove) ? 0 : deliveryFee;
  var finalTotal = subtotal - insDiscount + actualDelivery;

  var summary = '<div style="display:flex;justify-content:space-between;margin-bottom:6px;"><span>المجموع الفرعي</span><span>' + subtotal.toFixed(0) + ' ر.س</span></div>';
  if (insDiscount > 0) summary += '<div style="display:flex;justify-content:space-between;margin-bottom:6px;color:var(--secondary);"><span><i class="fas fa-shield-alt"></i> خصم التأمين</span><span>-' + insDiscount.toFixed(0) + ' ر.س</span></div>';
  if (actualDelivery > 0) summary += '<div style="display:flex;justify-content:space-between;margin-bottom:6px;"><span>التوصيل</span><span>' + actualDelivery + ' ر.س</span></div>';
  else if (deliveryFee > 0) summary += '<div style="display:flex;justify-content:space-between;margin-bottom:6px;color:var(--secondary);"><span>التوصيل</span><span>مجاني</span></div>';
  summary += '<div style="display:flex;justify-content:space-between;padding-top:8px;border-top:1px solid rgba(255,255,255,0.1);font-weight:700;font-size:1.05rem;"><span>الإجمالي</span><span style="color:var(--secondary);">' + finalTotal.toFixed(0) + ' ر.س</span></div>';
  document.getElementById('cartSummary').innerHTML = summary;
}

var selectedPayment = 'cash';

function selectPayment(method, el) {
  selectedPayment = method;
  document.querySelectorAll('.payment-method-option').forEach(function(opt) { opt.classList.remove('selected'); });
  el.classList.add('selected');
  el.querySelector('input').checked = true;
  document.getElementById('cardFormSection').style.display = method === 'card' ? 'block' : 'none';
  var btn = document.getElementById('submitOrderBtn');
  if (method === 'apple_pay') {
    btn.innerHTML = '<i class="fab fa-apple"></i> الدفع بـ Apple Pay';
    btn.style.background = '#000';
  } else if (method === 'card') {
    btn.innerHTML = '<i class="fas fa-credit-card"></i> ادفع الآن';
    btn.style.background = 'var(--secondary)';
  } else {
    btn.innerHTML = '<i class="fas fa-check-circle"></i> تأكيد الطلب';
    btn.style.background = 'var(--secondary)';
  }
}

function formatCardNumber(el) {
  var v = el.value.replace(/\D/g, '').substring(0, 16);
  el.value = v.replace(/(\d{4})(?=\d)/g, '$1 ');
}

function formatExpiry(el) {
  var v = el.value.replace(/\D/g, '').substring(0, 4);
  if (v.length >= 3) v = v.substring(0, 2) + '/' + v.substring(2);
  el.value = v;
}

function validateCard() {
  var num = document.getElementById('cardNumber').value.replace(/\s/g, '');
  var exp = document.getElementById('cardExpiry').value;
  var cvv = document.getElementById('cardCVV').value;
  var holder = document.getElementById('cardHolder').value.trim();
  if (num.length < 13) { alert('رقم البطاقة غير صحيح'); return false; }
  if (!/^\d{2}\/\d{2}$/.test(exp)) { alert('تاريخ الانتهاء غير صحيح'); return false; }
  if (cvv.length < 3) { alert('CVV غير صحيح'); return false; }
  if (!holder) { alert('يرجى إدخال اسم حامل البطاقة'); return false; }
  return true;
}

function simulatePayment(method) {
  return new Promise(function(resolve) {
    var overlay = document.createElement('div');
    overlay.className = 'payment-overlay';
    
    if (method === 'apple_pay') {
      overlay.innerHTML = '<div class="payment-modal apple-pay-modal">' +
        '<div class="apple-pay-header"><i class="fab fa-apple" style="font-size:2rem;"></i><span style="font-size:1.1rem;font-weight:600;">Pay</span></div>' +
        '<div class="payment-amount">' + document.querySelector('#cartSummary div:last-child span:last-child').textContent + '</div>' +
        '<div class="payment-store">صيدلية مفاصل</div>' +
        '<div class="apple-pay-biometric"><i class="fas fa-fingerprint" style="font-size:3rem;color:var(--accent);margin:1rem 0;"></i><p>تأكيد بالبصمة</p></div>' +
        '<button class="btn" style="width:100%;background:#000;color:#fff;padding:0.85rem;border-radius:12px;font-size:1rem;margin-top:1rem;" onclick="this.innerHTML=\'<i class=\\\'fas fa-spinner fa-spin\\\'></i> جاري المعالجة...\';this.disabled=true;setTimeout(function(){document.querySelector(\'.payment-overlay\').remove();window._payResolve(true);},1500);"><i class="fab fa-apple"></i> تأكيد الدفع</button>' +
        '<button class="btn btn-outline" style="width:100%;margin-top:0.5rem;padding:0.65rem;font-size:0.85rem;" onclick="document.querySelector(\'.payment-overlay\').remove();window._payResolve(false);">إلغاء</button>' +
        '</div>';
    } else {
      overlay.innerHTML = '<div class="payment-modal">' +
        '<div style="text-align:center;margin-bottom:1rem;"><i class="fas fa-credit-card" style="font-size:2.5rem;color:var(--accent);"></i></div>' +
        '<h3 style="text-align:center;margin-bottom:0.5rem;">معالجة الدفع</h3>' +
        '<div class="payment-amount">' + document.querySelector('#cartSummary div:last-child span:last-child').textContent + '</div>' +
        '<div class="payment-progress"><div class="payment-progress-bar"></div></div>' +
        '<p style="text-align:center;font-size:0.82rem;color:var(--text-muted);margin-top:0.75rem;" id="payStatus">جاري التحقق من البطاقة...</p>' +
        '</div>';
      setTimeout(function() { 
        var s = document.getElementById('payStatus'); 
        if(s) s.textContent = 'جاري خصم المبلغ...'; 
      }, 1000);
      setTimeout(function() { 
        var s = document.getElementById('payStatus');
        if(s) { s.textContent = 'تمت الموافقة ✓'; s.style.color = '#22c55e'; }
      }, 2000);
      setTimeout(function() { overlay.remove(); resolve(true); }, 2800);
    }
    
    window._payResolve = resolve;
    document.body.appendChild(overlay);
  });
}

async function submitOrder() {
  var address = document.getElementById('orderAddress').value.trim();
  if (!address) { alert('يرجى إدخال عنوان التوصيل'); return; }
  
  var payMethod = useIns ? 'insurance' : selectedPayment;
  
  if (payMethod === 'card' && !validateCard()) return;

  var btn = document.getElementById('submitOrderBtn');
  var orig = btn.innerHTML;

  if (payMethod === 'card' || payMethod === 'apple_pay') {
    var approved = await simulatePayment(payMethod);
    if (!approved) return;
  }

  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري إرسال الطلب...';
  try {
    var payload = {
      pharmacyId: pharmacyId,
      items: cart.map(function(i) { return { drugId: i.drugId, name: i.name, price: i.price, quantity: i.quantity, prescription: i.prescription }; }),
      address: address,
      notes: document.getElementById('orderNotes').value,
      paymentMethod: payMethod,
      insuranceId: useIns ? insuranceId : ''
    };
    var res = await fetch('/pharmacy/order', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    var data = await res.json();
    if (data.success) {
      cart = [];
      updateCart();
      btn.innerHTML = '<i class="fas fa-check"></i> تم إرسال الطلب بنجاح';
      btn.style.background = '#22c55e';
      setTimeout(function() { window.location.href = '/pharmacy'; }, 1500);
    } else {
      alert(data.error || 'فشل إرسال الطلب');
      btn.innerHTML = orig; btn.disabled = false;
    }
  } catch(err) { alert('خطأ في الإرسال'); btn.innerHTML = orig; btn.disabled = false; }
}

function filterCat(cat, btn) {
  document.querySelectorAll('.cat-btn').forEach(function(b) { b.classList.remove('active'); });
  btn.classList.add('active');
  document.querySelectorAll('.drug-card').forEach(function(card) {
    if (cat === 'all' || card.dataset.category === cat) card.style.display = '';
    else card.style.display = 'none';
  });
}

function switchTab(tab, btn) {
  document.querySelectorAll('.tab-content').forEach(function(t){ t.classList.remove('active'); });
  document.querySelectorAll('.tab-btn').forEach(function(b){ b.classList.remove('active'); });
  document.getElementById('tab-' + tab).classList.add('active');
  btn.classList.add('active');
}
</script>
