<%- include('../partials/header') %>
<div class="main-content">
  <div class="container">
    <div class="page-header">
      <h1><i class="fas fa-clinic-medical" style="color:var(--secondary);"></i> الصيدليات</h1>
    </div>

    <div class="tabs">
      <button class="tab-btn active" onclick="switchTab('pharmacies', this)"><i class="fas fa-store"></i> الصيدليات</button>
      <button class="tab-btn" onclick="switchTab('orders', this)"><i class="fas fa-box"></i> طلباتي</button>
    </div>

    <div style="margin-bottom:1.25rem;position:relative;">
      <input type="text" id="drugSearch" class="form-control" placeholder="ابحث عن دواء في جميع الصيدليات..." style="padding-right:2.5rem;border-radius:12px;">
      <i class="fas fa-search" style="position:absolute;right:1rem;top:50%;transform:translateY(-50%);color:var(--text-muted);"></i>
      <div id="searchResults" style="display:none;position:absolute;top:100%;left:0;right:0;z-index:100;background:var(--card-bg,#1a2736);border:1px solid var(--border,#2a3a4a);border-radius:12px;max-height:360px;overflow-y:auto;margin-top:4px;box-shadow:0 8px 32px rgba(0,0,0,0.3);"></div>
    </div>

    <div id="tab-pharmacies" class="tab-content active">
      <% if (pharmacies.length === 0) { %>
      <div class="empty-state-premium">
        <div class="empty-icon"><i class="fas fa-store-slash"></i></div>
        <h3>لا توجد صيدليات متاحة حالياً</h3>
        <p>سيتم إضافة صيدليات قريباً</p>
      </div>
      <% } else { %>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1rem;">
        <% pharmacies.forEach(function(p) { %>
        <a href="/pharmacy/store/<%= p._id %>" class="card" style="padding:0;border-radius:16px;overflow:hidden;text-decoration:none;color:inherit;transition:transform 0.2s,box-shadow 0.2s;display:block;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 8px 24px rgba(0,0,0,0.3)'" onmouseout="this.style.transform='';this.style.boxShadow=''">
          <div style="height:120px;background:linear-gradient(135deg,#0f1923,#1a2736);display:flex;align-items:center;justify-content:center;position:relative;">
            <% if (p.cover) { %>
            <img src="<%= p.cover %>" style="width:100%;height:100%;object-fit:cover;">
            <% } else { %>
            <i class="fas fa-clinic-medical" style="font-size:2.5rem;color:var(--secondary);opacity:0.6;"></i>
            <% } %>
            <% if (p.isFeatured) { %>
            <span style="position:absolute;top:8px;right:8px;background:#f59e0b;color:#000;font-size:0.65rem;padding:3px 8px;border-radius:6px;font-weight:700;"><i class="fas fa-star"></i> مميزة</span>
            <% } %>
            <% if (p.insuranceSupported) { %>
            <span style="position:absolute;top:8px;left:8px;background:var(--secondary);color:#fff;font-size:0.65rem;padding:3px 8px;border-radius:6px;font-weight:600;"><i class="fas fa-shield-alt"></i> تأمين</span>
            <% } %>
          </div>
          <div style="padding:1rem;">
            <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.5rem;">
              <div style="width:42px;height:42px;border-radius:12px;background:var(--secondary)12;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <% if (p.logo) { %>
                <img src="<%= p.logo %>" style="width:42px;height:42px;border-radius:12px;object-fit:cover;">
                <% } else { %>
                <i class="fas fa-prescription-bottle-alt" style="color:var(--secondary);font-size:1.1rem;"></i>
                <% } %>
              </div>
              <div style="min-width:0;">
                <strong style="font-size:1rem;display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= p.name %></strong>
                <small style="color:var(--text-muted);font-size:0.78rem;"><i class="fas fa-map-marker-alt"></i> <%= p.location.city || 'الرياض' %><%= p.location.district ? ' - ' + p.location.district : '' %></small>
              </div>
            </div>
            <% if (p.description) { %>
            <p style="font-size:0.8rem;color:var(--text-muted);margin:0 0 0.5rem;line-height:1.6;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;"><%= p.description %></p>
            <% } %>
            <div style="display:flex;align-items:center;gap:0.75rem;font-size:0.78rem;color:var(--text-muted);">
              <span><i class="fas fa-star" style="color:#f59e0b;"></i> <%= p.rating.toFixed(1) %></span>
              <span><i class="fas fa-clock"></i> <%= p.workingHours %></span>
              <% if (p.deliveryFee > 0) { %>
              <span><i class="fas fa-truck"></i> <%= p.deliveryFee %> ر.س</span>
              <% } else { %>
              <span style="color:var(--secondary);"><i class="fas fa-truck"></i> توصيل مجاني</span>
              <% } %>
            </div>
          </div>
        </a>
        <% }) %>
      </div>
      <% } %>
    </div>

    <div id="tab-orders" class="tab-content">
      <% if (orders.length > 0) { %>
      <div style="display:flex;flex-direction:column;gap:0.75rem;">
        <% orders.forEach(function(o) {
          var statusMap = { pending:'معلق', confirmed:'مؤكد', preparing:'قيد التحضير', delivering:'في الطريق', delivered:'تم التوصيل', cancelled:'ملغي' };
          var statusColor = { pending:'#f59e0b', confirmed:'var(--secondary)', preparing:'#3b82f6', delivering:'#8b5cf6', delivered:'#22c55e', cancelled:'#ef4444' };
        %>
        <div class="card" style="padding:1rem;border-radius:14px;">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:0.5rem;">
            <div>
              <strong style="font-size:0.9rem;"><%= o.trackingNumber %></strong>
              <div style="font-size:0.78rem;color:var(--text-muted);margin-top:2px;"><%= o.pharmacy %> &middot; <%= new Date(o.createdAt).toLocaleDateString('ar-SA', { month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' }) %></div>
            </div>
            <span style="background:<%= statusColor[o.status] || 'var(--secondary)' %>15;color:<%= statusColor[o.status] || 'var(--secondary)' %>;font-size:0.75rem;padding:4px 10px;border-radius:8px;font-weight:600;"><%= statusMap[o.status] || o.status %></span>
          </div>
          <div style="font-size:0.82rem;color:var(--text-muted);margin-bottom:0.5rem;"><%= o.items.map(function(i){ return i.name + ' ×' + i.quantity; }).join('، ') %></div>
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <div>
              <% if (o.paymentMethod === 'insurance') { %>
              <span style="font-size:0.72rem;background:var(--secondary)15;color:var(--secondary);padding:2px 8px;border-radius:6px;"><i class="fas fa-shield-alt"></i> تأمين</span>
              <% } %>
            </div>
            <strong style="color:var(--secondary);"><%= o.totalPrice %> ريال</strong>
          </div>
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <div class="empty-state-premium">
        <div class="empty-icon"><i class="fas fa-shopping-bag"></i></div>
        <h3>لا توجد طلبات</h3>
        <p>اطلب أدويتك من الصيدليات المتاحة</p>
      </div>
      <% } %>
    </div>
  </div>
</div>

<script>
var searchTimeout;
var searchInput = document.getElementById('drugSearch');
var resultsDiv = document.getElementById('searchResults');

searchInput.addEventListener('input', function() {
  clearTimeout(searchTimeout);
  var q = this.value.trim();
  if (q.length < 2) { resultsDiv.style.display = 'none'; return; }
  searchTimeout = setTimeout(function() { searchDrugs(q); }, 300);
});

async function searchDrugs(q) {
  try {
    var res = await fetch('/pharmacy/search?q=' + encodeURIComponent(q));
    var data = await res.json();
    if (!data.drugs || !data.drugs.length) {
      resultsDiv.innerHTML = '<div style="padding:1.25rem;text-align:center;color:var(--text-muted);font-size:0.85rem;"><i class="fas fa-pills"></i> لا توجد نتائج</div>';
      resultsDiv.style.display = 'block';
      return;
    }
    var html = '';
    data.drugs.forEach(function(d) {
      var phName = d.pharmacyId ? d.pharmacyId.name : '';
      html += '<a href="/pharmacy/store/' + (d.pharmacyId ? d.pharmacyId._id : '') + '" style="display:flex;align-items:center;gap:0.75rem;padding:0.85rem 1rem;border-bottom:1px solid rgba(255,255,255,0.05);text-decoration:none;color:inherit;transition:background 0.15s;" onmouseover="this.style.background=\'rgba(18,169,155,0.08)\'" onmouseout="this.style.background=\'none\'">';
      html += '<div style="width:40px;height:40px;border-radius:10px;background:var(--secondary)12;display:flex;align-items:center;justify-content:center;flex-shrink:0;">';
      if (d.image) html += '<img src="' + d.image + '" style="width:40px;height:40px;border-radius:10px;object-fit:cover;">';
      else html += '<i class="fas fa-capsules" style="color:var(--secondary);"></i>';
      html += '</div><div style="flex:1;min-width:0;">';
      html += '<div style="font-size:0.88rem;font-weight:600;">' + d.name + '</div>';
      html += '<div style="font-size:0.75rem;color:var(--text-muted);">' + phName + ' &middot; ' + d.category + '</div>';
      html += '</div>';
      html += '<strong style="color:var(--secondary);font-size:0.88rem;white-space:nowrap;">' + d.price + ' ر.س</strong>';
      if (d.insuranceSupported) html += '<i class="fas fa-shield-alt" style="color:var(--secondary);font-size:0.7rem;" title="يدعم التأمين"></i>';
      html += '</a>';
    });
    resultsDiv.innerHTML = html;
    resultsDiv.style.display = 'block';
  } catch(e) { resultsDiv.style.display = 'none'; }
}

document.addEventListener('click', function(e) {
  if (!e.target.closest('#drugSearch') && !e.target.closest('#searchResults')) {
    resultsDiv.style.display = 'none';
  }
});

function switchTab(tab, btn) {
  document.querySelectorAll('.tab-content').forEach(function(t){ t.classList.remove('active'); });
  document.querySelectorAll('.tab-btn').forEach(function(b){ b.classList.remove('active'); });
  document.getElementById('tab-' + tab).classList.add('active');
  btn.classList.add('active');
}
</script>
<%- include('../partials/footer') %>
