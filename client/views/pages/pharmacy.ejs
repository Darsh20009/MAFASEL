<%- include('../partials/header') %>
<div class="main-content">
  <div class="container">
    <div class="page-header">
      <h1><i class="fas fa-clinic-medical" style="color:var(--secondary);"></i> الصيدليات</h1>
    </div>

    <div class="tabs">
      <button class="tab-btn active" onclick="switchTab('pharmacies', this)"><i class="fas fa-store"></i> الصيدليات</button>
      <button class="tab-btn" onclick="switchTab('orders', this)"><i class="fas fa-box"></i> طلباتي</button>
    </div>

    <div style="margin-bottom:1.25rem;position:relative;">
      <input type="text" id="drugSearch" class="form-control" placeholder="ابحث عن دواء في جميع الصيدليات..." style="padding-right:2.5rem;border-radius:12px;">
      <i class="fas fa-search" style="position:absolute;right:1rem;top:50%;transform:translateY(-50%);color:var(--text-muted);"></i>
      <div id="searchResults" style="display:none;position:absolute;top:100%;left:0;right:0;z-index:100;background:var(--card-bg,#1a2736);border:1px solid var(--border,#2a3a4a);border-radius:12px;max-height:360px;overflow-y:auto;margin-top:4px;box-shadow:0 8px 32px rgba(0,0,0,0.3);"></div>
    </div>

    <div id="tab-pharmacies" class="tab-content active">
      <% if (pharmacies.length === 0) { %>
      <div class="empty-state-premium">
        <div class="empty-icon"><i class="fas fa-store-slash"></i></div>
        <h3>لا توجد صيدليات متاحة حالياً</h3>
        <p>سيتم إضافة صيدليات قريباً</p>
      </div>
      <% } else { %>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1rem;">
        <% pharmacies.forEach(function(p) { %>
        <a href="/pharmacy/store/<%= p._id %>" class="card" style="padding:0;border-radius:16px;overflow:hidden;text-decoration:none;color:inherit;transition:transform 0.2s,box-shadow 0.2s;display:block;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 8px 24px rgba(0,0,0,0.3)'" onmouseout="this.style.transform='';this.style.boxShadow=''">
          <div style="height:120px;background:linear-gradient(135deg,#0f1923,#1a2736);display:flex;align-items:center;justify-content:center;position:relative;">
            <% if (p.cover) { %>
            <img src="<%= p.cover %>" style="width:100%;height:100%;object-fit:cover;">
            <% } else { %>
            <i class="fas fa-clinic-medical" style="font-size:2.5rem;color:var(--secondary);opacity:0.6;"></i>
            <% } %>
            <% if (p.isFeatured) { %>
            <span style="position:absolute;top:8px;right:8px;background:#f59e0b;color:#000;font-size:0.65rem;padding:3px 8px;border-radius:6px;font-weight:700;"><i class="fas fa-star"></i> مميزة</span>
            <% } %>
            <% if (p.insuranceSupported) { %>
            <span style="position:absolute;top:8px;left:8px;background:var(--secondary);color:#fff;font-size:0.65rem;padding:3px 8px;border-radius:6px;font-weight:600;"><i class="fas fa-shield-alt"></i> تأمين</span>
            <% } %>
          </div>
          <div style="padding:1rem;">
            <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.5rem;">
              <div style="width:42px;height:42px;border-radius:12px;background:var(--secondary)12;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <% if (p.logo) { %>
                <img src="<%= p.logo %>" style="width:42px;height:42px;border-radius:12px;object-fit:cover;">
                <% } else { %>
                <i class="fas fa-prescription-bottle-alt" style="color:var(--secondary);font-size:1.1rem;"></i>
                <% } %>
              </div>
              <div style="min-width:0;">
                <strong style="font-size:1rem;display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= p.name %></strong>
                <small style="color:var(--text-muted);font-size:0.78rem;"><i class="fas fa-map-marker-alt"></i> <%= p.location.city || 'الرياض' %><%= p.location.district ? ' - ' + p.location.district : '' %></small>
              </div>
            </div>
            <% if (p.description) { %>
            <p style="font-size:0.8rem;color:var(--text-muted);margin:0 0 0.5rem;line-height:1.6;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;"><%= p.description %></p>
            <% } %>
            <div style="display:flex;align-items:center;gap:0.75rem;font-size:0.78rem;color:var(--text-muted);">
              <span><i class="fas fa-star" style="color:#f59e0b;"></i> <%= p.rating.toFixed(1) %></span>
              <span><i class="fas fa-clock"></i> <%= p.workingHours %></span>
              <% if (p.deliveryFee > 0) { %>
              <span><i class="fas fa-truck"></i> <%= p.deliveryFee %> ر.س</span>
              <% } else { %>
              <span style="color:var(--secondary);"><i class="fas fa-truck"></i> توصيل مجاني</span>
              <% } %>
            </div>
          </div>
        </a>
        <% }) %>
      </div>
      <% } %>
    </div>

    <% if (insurance) { %>
    <div class="card" style="padding:1rem 1.25rem;border-radius:14px;margin-bottom:1.25rem;border:1px solid rgba(18,169,155,0.15);background:linear-gradient(135deg,rgba(18,169,155,0.05),transparent);">
      <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.75rem;">
        <div style="width:38px;height:38px;border-radius:10px;background:var(--secondary)15;display:flex;align-items:center;justify-content:center;">
          <i class="fas fa-shield-alt" style="color:var(--secondary);"></i>
        </div>
        <div style="flex:1;">
          <strong style="font-size:0.9rem;"><%= insurance.company %></strong>
          <div style="font-size:0.72rem;color:var(--text-muted);">بوليصة: <%= insurance.policyNumber %> &middot; <%= insurance.type === 'vip' ? 'VIP' : insurance.type === 'premium' ? 'بريميوم' : 'أساسي' %></div>
        </div>
        <span style="background:#22c55e15;color:#22c55e;font-size:0.7rem;padding:3px 8px;border-radius:6px;font-weight:600;">فعّال</span>
      </div>
      <div style="margin-bottom:0.5rem;">
        <div style="display:flex;justify-content:space-between;font-size:0.78rem;color:var(--text-muted);margin-bottom:4px;">
          <span>المستخدم: <strong style="color:var(--secondary);"><%= insurance.usedAmount.toFixed(0) %> ر.س</strong></span>
          <span>الحد: <strong><%= insurance.coverageAmount.toFixed(0) %> ر.س</strong></span>
        </div>
        <div style="height:6px;border-radius:3px;background:rgba(255,255,255,0.08);overflow:hidden;">
          <div style="height:100%;border-radius:3px;background:linear-gradient(90deg,var(--secondary),#0d8a7e);width:<%= Math.min(100, (insurance.usedAmount / insurance.coverageAmount * 100)).toFixed(0) %>%;transition:width 0.5s;"></div>
        </div>
        <div style="font-size:0.72rem;color:var(--text-muted);margin-top:4px;text-align:center;">
          المتبقي: <strong style="color:var(--secondary);"><%= (insurance.coverageAmount - insurance.usedAmount).toFixed(0) %> ر.س</strong>
          (<%= (100 - insurance.usedAmount / insurance.coverageAmount * 100).toFixed(0) %>%)
        </div>
      </div>
      <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-top:0.5rem;">
        <% if (insurance.coverageDetails.medications) { %><span style="font-size:0.65rem;background:var(--secondary)10;color:var(--secondary);padding:2px 6px;border-radius:4px;"><i class="fas fa-pills"></i> أدوية</span><% } %>
        <% if (insurance.coverageDetails.consultations) { %><span style="font-size:0.65rem;background:var(--secondary)10;color:var(--secondary);padding:2px 6px;border-radius:4px;"><i class="fas fa-stethoscope"></i> استشارات</span><% } %>
        <% if (insurance.coverageDetails.dental) { %><span style="font-size:0.65rem;background:var(--secondary)10;color:var(--secondary);padding:2px 6px;border-radius:4px;"><i class="fas fa-tooth"></i> أسنان</span><% } %>
        <% if (insurance.coverageDetails.optical) { %><span style="font-size:0.65rem;background:var(--secondary)10;color:var(--secondary);padding:2px 6px;border-radius:4px;"><i class="fas fa-eye"></i> بصريات</span><% } %>
      </div>
    </div>
    <% } %>

    <div id="tab-orders" class="tab-content">
      <% if (orders.length > 0) { %>
      <div style="display:flex;flex-direction:column;gap:0.75rem;">
        <% orders.forEach(function(o) {
          var statusMap = { pending:'معلق', confirmed:'مؤكد', preparing:'قيد التحضير', delivering:'في الطريق', delivered:'تم التوصيل', cancelled:'ملغي' };
          var statusColor = { pending:'#f59e0b', confirmed:'var(--secondary)', preparing:'#3b82f6', delivering:'#8b5cf6', delivered:'#22c55e', cancelled:'#ef4444' };
          var statusIcon = { pending:'fa-clock', confirmed:'fa-check-circle', preparing:'fa-mortar-pestle', delivering:'fa-shipping-fast', delivered:'fa-check-double', cancelled:'fa-times-circle' };
          var payMethodMap = { cash:'نقد', insurance:'تأمين', card:'بطاقة', apple_pay:'Apple Pay', health_card:'البطاقة الصحية' };
          var payMethodIcon = { cash:'fa-money-bill-wave', insurance:'fa-shield-alt', card:'fa-credit-card', apple_pay:'fab fa-apple', health_card:'fa-id-card' };
          var steps = ['pending','confirmed','preparing','delivering','delivered'];
          var currentStep = steps.indexOf(o.status);
          var isCancelled = o.status === 'cancelled';
          var phLogo = o.pharmacyId && o.pharmacyId.logo ? o.pharmacyId.logo : '';
        %>
        <div class="card" style="padding:1.15rem;border-radius:14px;border:1px solid rgba(255,255,255,0.04);">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:0.65rem;">
            <div style="display:flex;align-items:center;gap:0.65rem;">
              <% if (phLogo) { %>
              <img src="<%= phLogo %>" style="width:36px;height:36px;border-radius:10px;object-fit:cover;">
              <% } else { %>
              <div style="width:36px;height:36px;border-radius:10px;background:var(--secondary)12;display:flex;align-items:center;justify-content:center;"><i class="fas fa-prescription-bottle-alt" style="color:var(--secondary);font-size:0.9rem;"></i></div>
              <% } %>
              <div>
                <strong style="font-size:0.88rem;"><%= o.pharmacy %></strong>
                <div style="font-size:0.72rem;color:var(--text-muted);margin-top:1px;"><%= o.trackingNumber %> &middot; <%= new Date(o.createdAt).toLocaleDateString('ar-SA', { month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' }) %></div>
              </div>
            </div>
            <span style="background:<%= isCancelled ? '#ef4444' : (statusColor[o.status] || 'var(--secondary)') %>15;color:<%= isCancelled ? '#ef4444' : (statusColor[o.status] || 'var(--secondary)') %>;font-size:0.72rem;padding:4px 10px;border-radius:8px;font-weight:600;">
              <i class="fas <%= statusIcon[o.status] || 'fa-circle' %>"></i> <%= statusMap[o.status] || o.status %>
            </span>
          </div>

          <% if (!isCancelled) { %>
          <div style="display:flex;align-items:center;gap:0;margin:0.75rem 0;padding:0 0.5rem;">
            <% steps.forEach(function(step, idx) {
              var done = idx <= currentStep;
              var isActive = idx === currentStep;
            %>
            <div style="flex:0 0 auto;display:flex;flex-direction:column;align-items:center;position:relative;z-index:1;">
              <div style="width:<%= isActive ? '22px' : '14px' %>;height:<%= isActive ? '22px' : '14px' %>;border-radius:50%;background:<%= done ? 'var(--secondary)' : 'rgba(255,255,255,0.1)' %>;<%= isActive ? 'box-shadow:0 0 0 4px rgba(18,169,155,0.2);' : '' %>display:flex;align-items:center;justify-content:center;">
                <% if (isActive) { %><i class="fas fa-check" style="font-size:0.5rem;color:#fff;"></i><% } %>
              </div>
            </div>
            <% if (idx < steps.length - 1) { %>
            <div style="flex:1;height:2px;background:<%= idx < currentStep ? 'var(--secondary)' : 'rgba(255,255,255,0.08)' %>;min-width:20px;"></div>
            <% } %>
            <% }) %>
          </div>
          <% } %>

          <div style="font-size:0.8rem;color:var(--text-muted);margin-bottom:0.5rem;line-height:1.7;">
            <%= o.items.map(function(i){ return i.name + ' <span style="color:var(--secondary);">×' + i.quantity + '</span>'; }).join('، ') %>
          </div>

          <div style="display:flex;justify-content:space-between;align-items:center;padding-top:0.5rem;border-top:1px solid rgba(255,255,255,0.05);">
            <div style="display:flex;gap:0.4rem;align-items:center;">
              <span style="font-size:0.7rem;background:rgba(255,255,255,0.05);padding:3px 8px;border-radius:6px;display:flex;align-items:center;gap:4px;">
                <i class="<%= payMethodIcon[o.paymentMethod] || 'fas fa-money-bill-wave' %>" style="font-size:0.65rem;color:var(--secondary);"></i>
                <span style="color:var(--text-muted);"><%= payMethodMap[o.paymentMethod] || o.paymentMethod %></span>
              </span>
              <% if (o.insuranceDiscount > 0) { %>
              <span style="font-size:0.68rem;color:var(--secondary);">خصم: <%= o.insuranceDiscount %> ر.س</span>
              <% } %>
            </div>
            <strong style="color:var(--secondary);font-size:1rem;"><%= o.totalPrice %> <span style="font-size:0.72rem;font-weight:400;">ريال</span></strong>
          </div>
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <div class="empty-state-premium">
        <div class="empty-icon"><i class="fas fa-shopping-bag"></i></div>
        <h3>لا توجد طلبات</h3>
        <p>اطلب أدويتك من الصيدليات المتاحة</p>
      </div>
      <% } %>
    </div>
  </div>
</div>

<script>
var searchTimeout;
var searchInput = document.getElementById('drugSearch');
var resultsDiv = document.getElementById('searchResults');

searchInput.addEventListener('input', function() {
  clearTimeout(searchTimeout);
  var q = this.value.trim();
  if (q.length < 2) { resultsDiv.style.display = 'none'; return; }
  searchTimeout = setTimeout(function() { searchDrugs(q); }, 300);
});

async function searchDrugs(q) {
  try {
    var res = await fetch('/pharmacy/search?q=' + encodeURIComponent(q));
    var data = await res.json();
    if (!data.drugs || !data.drugs.length) {
      resultsDiv.innerHTML = '<div style="padding:1.25rem;text-align:center;color:var(--text-muted);font-size:0.85rem;"><i class="fas fa-pills"></i> لا توجد نتائج</div>';
      resultsDiv.style.display = 'block';
      return;
    }
    var html = '';
    data.drugs.forEach(function(d) {
      var phName = d.pharmacyId ? d.pharmacyId.name : '';
      html += '<a href="/pharmacy/store/' + (d.pharmacyId ? d.pharmacyId._id : '') + '" style="display:flex;align-items:center;gap:0.75rem;padding:0.85rem 1rem;border-bottom:1px solid rgba(255,255,255,0.05);text-decoration:none;color:inherit;transition:background 0.15s;" onmouseover="this.style.background=\'rgba(18,169,155,0.08)\'" onmouseout="this.style.background=\'none\'">';
      html += '<div style="width:40px;height:40px;border-radius:10px;background:var(--secondary)12;display:flex;align-items:center;justify-content:center;flex-shrink:0;">';
      if (d.image) html += '<img src="' + d.image + '" style="width:40px;height:40px;border-radius:10px;object-fit:cover;">';
      else html += '<i class="fas fa-capsules" style="color:var(--secondary);"></i>';
      html += '</div><div style="flex:1;min-width:0;">';
      html += '<div style="font-size:0.88rem;font-weight:600;">' + d.name + '</div>';
      html += '<div style="font-size:0.75rem;color:var(--text-muted);">' + phName + ' &middot; ' + d.category + '</div>';
      html += '</div>';
      html += '<strong style="color:var(--secondary);font-size:0.88rem;white-space:nowrap;">' + d.price + ' ر.س</strong>';
      if (d.insuranceSupported) html += '<i class="fas fa-shield-alt" style="color:var(--secondary);font-size:0.7rem;" title="يدعم التأمين"></i>';
      html += '</a>';
    });
    resultsDiv.innerHTML = html;
    resultsDiv.style.display = 'block';
  } catch(e) { resultsDiv.style.display = 'none'; }
}

document.addEventListener('click', function(e) {
  if (!e.target.closest('#drugSearch') && !e.target.closest('#searchResults')) {
    resultsDiv.style.display = 'none';
  }
});

function switchTab(tab, btn) {
  document.querySelectorAll('.tab-content').forEach(function(t){ t.classList.remove('active'); });
  document.querySelectorAll('.tab-btn').forEach(function(b){ b.classList.remove('active'); });
  document.getElementById('tab-' + tab).classList.add('active');
  btn.classList.add('active');
}
</script>
<%- include('../partials/footer') %>
