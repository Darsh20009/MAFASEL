<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'ar' %>" dir="<%= typeof dir !== 'undefined' ? dir : 'rtl' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof t === 'function' ? t('site_name') : 'مفاصل' %> | <%= typeof t === 'function' ? t('site_desc') : 'منصة طبية رقمية متكاملة' %></title>
  <meta name="description" content="<%= typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : 'منصة مفاصل الطبية الرقمية المتكاملة - استشارات طبية، صيدلية إلكترونية، تأمين صحي، مساعد ذكي بالذكاء الاصطناعي' %>">
  <meta name="keywords" content="مفاصل, منصة طبية, استشارات طبية, صيدلية إلكترونية, تأمين صحي, مواعيد طبية, تذكير أدوية, أخصائي, صيدلي, السعودية, رعاية صحية رقمية">
  <meta name="author" content="مفاصل">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="<%= typeof canonicalUrl !== 'undefined' && canonicalUrl ? canonicalUrl : '' %>">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="مفاصل - منصة طبية رقمية">
  <meta property="og:title" content="مفاصل | منصة طبية رقمية متكاملة">
  <meta property="og:description" content="منصة مفاصل الطبية الرقمية المتكاملة في السعودية - استشارات طبية متخصصة، صيدلية إلكترونية، تأمين صحي، مساعد ذكي">
  <meta property="og:image" content="/icons/icon-512.png">
  <meta property="og:locale" content="ar_SA">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="مفاصل | منصة طبية رقمية متكاملة">
  <meta name="twitter:description" content="منصة مفاصل الطبية الرقمية المتكاملة - استشارات طبية، صيدلية إلكترونية، تأمين صحي">
  <meta name="twitter:image" content="/icons/icon-512.png">
  <meta name="theme-color" content="#101d23">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/icons/icon-192.png">
  <link rel="icon" href="/icons/logo.png">
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <% if (typeof schemaMarkup !== 'undefined' && schemaMarkup) { %>
  <script type="application/ld+json"><%- JSON.stringify(schemaMarkup) %></script>
  <% } %>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --accent: #12a99b;
      --accent2: #0d8a7e;
      --primary: #101d23;
      --card: #152028;
      --surface: #1a2a34;
      --text: #e2e8f0;
      --muted: #94a3b8;
      --border: rgba(255,255,255,0.06);
      --glow: rgba(18,169,155,0.15);
    }

    html {
      scroll-behavior: smooth;
      overflow-x: hidden;
    }
    body {
      font-family: 'Tajawal', sans-serif;
      background: var(--primary);
      color: var(--text);
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }
    html[dir="ltr"] body { font-family: 'Inter', 'Segoe UI', sans-serif; }

    .landing-nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0.85rem 2rem;
      background: rgba(16,29,35,0.7);
      backdrop-filter: blur(20px) saturate(1.4);
      border-bottom: 1px solid var(--border);
      transition: background 0.3s;
    }
    .nav-brand { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; }
    .nav-brand img { width: 34px; height: 34px; }
    .nav-brand span { font-size: 1.2rem; font-weight: 800; color: #fff; }
    .nav-links { display: flex; align-items: center; gap: 0.5rem; }
    .nav-links a, .nav-links button {
      font-family: inherit; font-size: 0.82rem; font-weight: 600; padding: 0.45rem 1.1rem; border-radius: 8px;
      text-decoration: none; cursor: pointer; border: none; transition: all 0.2s;
    }
    .nav-link-ghost { background: transparent; color: var(--muted); }
    .nav-link-ghost:hover { color: #fff; }
    .nav-link-primary { background: var(--accent); color: #fff; }
    .nav-link-primary:hover { background: var(--accent2); transform: translateY(-1px); }
    .nav-link-outline { background: transparent; border: 1px solid rgba(255,255,255,0.15); color: #fff; }
    .nav-link-outline:hover { border-color: var(--accent); color: var(--accent); }

    .hero {
      position: relative;
      min-height: 100vh;
      display: flex; align-items: center; justify-content: center;
      overflow: hidden;
    }
    .hero-video-bg {
      position: absolute; inset: 0; z-index: 0;
    }
    .hero-video-bg video {
      width: 100%; height: 100%; object-fit: cover;
      opacity: 0.25; filter: brightness(0.6);
    }
    .hero-overlay {
      position: absolute; inset: 0; z-index: 1;
      background: linear-gradient(180deg, rgba(16,29,35,0.5) 0%, rgba(16,29,35,0.85) 60%, var(--primary) 100%);
    }
    .hero-grid-pattern {
      position: absolute; inset: 0; z-index: 1;
      background-image:
        linear-gradient(rgba(18,169,155,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(18,169,155,0.03) 1px, transparent 1px);
      background-size: 60px 60px;
    }
    .hero-content {
      position: relative; z-index: 2;
      text-align: center; padding: 8rem 1.5rem 4rem;
      max-width: 720px;
    }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 0.4rem;
      background: rgba(18,169,155,0.1); border: 1px solid rgba(18,169,155,0.2);
      color: var(--accent); font-size: 0.78rem; font-weight: 700;
      padding: 0.35rem 1rem; border-radius: 50px; margin-bottom: 1.5rem;
      animation: fadeInUp 0.8s ease both;
    }
    .hero-logo {
      width: 90px; height: 90px; margin: 0 auto 1.5rem;
      animation: floatLogo 4s ease-in-out infinite, fadeInUp 0.8s ease 0.15s both;
      filter: drop-shadow(0 10px 30px rgba(18,169,155,0.3));
    }
    .hero-title {
      font-size: clamp(2rem, 5.5vw, 3.2rem);
      font-weight: 900; line-height: 1.25;
      margin-bottom: 1rem;
      animation: fadeInUp 0.8s ease 0.3s both;
    }
    .hero-title .accent { color: var(--accent); }
    .hero-desc {
      font-size: clamp(0.95rem, 2vw, 1.12rem);
      color: var(--muted); line-height: 1.8;
      max-width: 560px; margin: 0 auto 2rem;
      animation: fadeInUp 0.8s ease 0.45s both;
    }
    .hero-actions {
      display: flex; align-items: center; justify-content: center; gap: 0.75rem; flex-wrap: wrap;
      animation: fadeInUp 0.8s ease 0.6s both;
    }
    .btn-hero {
      display: inline-flex; align-items: center; gap: 0.5rem;
      font-family: inherit; font-size: 1rem; font-weight: 700;
      padding: 0.85rem 2rem; border-radius: 12px;
      text-decoration: none; cursor: pointer; border: none;
      transition: all 0.25s;
    }
    .btn-hero-primary {
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      color: #fff; box-shadow: 0 6px 24px rgba(18,169,155,0.35);
    }
    .btn-hero-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 36px rgba(18,169,155,0.45); }
    .btn-hero-outline {
      background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.15); color: #fff;
    }
    .btn-hero-outline:hover { border-color: var(--accent); color: var(--accent); }
    .hero-scroll-hint {
      position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%); z-index: 3;
      display: flex; flex-direction: column; align-items: center; gap: 0.4rem;
      color: var(--muted); font-size: 0.72rem; animation: bounceDown 2s ease infinite;
    }
    .hero-scroll-hint .scroll-line { width: 1px; height: 28px; background: linear-gradient(to bottom, var(--accent), transparent); }

    @keyframes floatLogo { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-10px)} }
    @keyframes fadeInUp { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:translateY(0)} }
    @keyframes bounceDown { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(8px)} }

    section { padding: 5rem 1.5rem; position: relative; }
    .section-inner { max-width: 1100px; margin: 0 auto; }
    .section-label {
      display: inline-flex; align-items: center; gap: 0.4rem;
      font-size: 0.75rem; font-weight: 700; color: var(--accent);
      padding: 0.3rem 0.85rem; border-radius: 50px;
      background: rgba(18,169,155,0.08); border: 1px solid rgba(18,169,155,0.15);
      margin-bottom: 1rem;
    }
    .section-title {
      font-size: clamp(1.6rem, 4vw, 2.4rem);
      font-weight: 900; line-height: 1.3;
      margin-bottom: 0.75rem;
    }
    .section-title .accent { color: var(--accent); }
    .section-desc {
      font-size: 1rem; color: var(--muted);
      line-height: 1.8; max-width: 600px; margin-bottom: 2.5rem;
    }

    .features-section { background: var(--primary); }
    .features-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 1.25rem;
    }
    .feature-card {
      background: var(--card); border: 1px solid var(--border);
      border-radius: 18px; padding: 1.75rem 1.5rem;
      transition: all 0.3s; position: relative; overflow: hidden;
    }
    .feature-card::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
      background: linear-gradient(90deg, transparent, var(--accent), transparent);
      opacity: 0; transition: opacity 0.3s;
    }
    .feature-card:hover { transform: translateY(-4px); border-color: rgba(18,169,155,0.2); }
    .feature-card:hover::before { opacity: 1; }
    .feature-icon {
      width: 52px; height: 52px; border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 1.1rem; font-size: 1.3rem;
    }
    .fi-teal { background: rgba(18,169,155,0.1); color: var(--accent); }
    .fi-blue { background: rgba(59,130,246,0.1); color: #60a5fa; }
    .fi-purple { background: rgba(139,92,246,0.1); color: #a78bfa; }
    .fi-amber { background: rgba(245,158,11,0.1); color: #fbbf24; }
    .fi-rose { background: rgba(244,63,94,0.1); color: #fb7185; }
    .fi-emerald { background: rgba(16,185,129,0.1); color: #34d399; }
    .feature-card h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 0.4rem; }
    .feature-card p { font-size: 0.85rem; color: var(--muted); line-height: 1.7; }

    .banner-section {
      background: transparent;
      border: none;
      overflow: hidden;
    }
    .banner-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: center;
    }
    .banner-visual {
      position: relative; display: flex; align-items: center; justify-content: center;
      isolation: isolate;
    }
    .banner-img-stack {
      position: relative; width: 100%; max-width: 420px;
    }
    .banner-img-stack img {
      width: 100%; border-radius: 0; border: none;
      box-shadow: none;
      filter: drop-shadow(0 10px 30px rgba(0,0,0,0.3));
    }
    .banner-float-logo {
      position: absolute; top: -20px; right: -15px;
      width: 56px; height: 56px;
      background: transparent; border: none;
      border-radius: 16px; display: flex; align-items: center; justify-content: center;
      box-shadow: none;
      animation: floatLogo 3s ease-in-out infinite;
    }
    .banner-float-logo img { width: 36px; height: 36px; filter: drop-shadow(0 0 12px rgba(18,169,155,0.4)); }
    .banner-text h2 { font-size: clamp(1.4rem, 3.5vw, 2rem); font-weight: 900; line-height: 1.3; margin-bottom: 1rem; }
    .banner-text h2 .accent { color: var(--accent); }
    .banner-text p { font-size: 0.95rem; color: var(--muted); line-height: 1.8; margin-bottom: 1.5rem; }
    .banner-stats {
      display: flex; gap: 2rem; flex-wrap: wrap;
    }
    .stat-item { text-align: center; }
    .stat-num { font-size: 1.6rem; font-weight: 900; color: var(--accent); }
    .stat-label { font-size: 0.75rem; color: var(--muted); margin-top: 2px; }

    .pharmacies-section { background: var(--primary); }
    .pharmacy-scroll {
      display: flex; gap: 1.25rem; overflow-x: auto; padding-bottom: 1rem;
      scrollbar-width: none; -ms-overflow-style: none;
    }
    .pharmacy-scroll::-webkit-scrollbar { display: none; }
    .pharmacy-card {
      flex: 0 0 220px; background: var(--card); border: 1px solid var(--border);
      border-radius: 18px; padding: 1.5rem 1.25rem; text-align: center;
      transition: all 0.3s; cursor: pointer; text-decoration: none; color: inherit;
    }
    .pharmacy-card:hover { transform: translateY(-4px); border-color: rgba(18,169,155,0.2); }
    .pharmacy-card img {
      width: 64px; height: 64px; border-radius: 16px; object-fit: cover;
      margin-bottom: 0.85rem; border: 2px solid var(--border);
    }
    .pharmacy-card h4 { font-size: 0.95rem; font-weight: 700; margin-bottom: 0.3rem; }
    .pharmacy-card p { font-size: 0.75rem; color: var(--muted); }

    .ai-section {
      background: linear-gradient(180deg, var(--primary), #0c171d);
      overflow: hidden;
    }
    .ai-showcase {
      display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center;
    }
    .ai-visual {
      position: relative; display: flex; align-items: center; justify-content: center;
    }
    .ai-orb {
      width: 240px; height: 240px; border-radius: 50%;
      background: radial-gradient(circle, rgba(18,169,155,0.2), transparent 70%);
      display: flex; align-items: center; justify-content: center;
      animation: orbPulse 4s ease-in-out infinite;
      position: relative;
    }
    .ai-orb::before {
      content: ''; position: absolute; inset: -20px;
      border-radius: 50%; border: 1px solid rgba(18,169,155,0.1);
      animation: orbPulse 4s ease-in-out infinite reverse;
    }
    .ai-orb::after {
      content: ''; position: absolute; inset: -40px;
      border-radius: 50%; border: 1px dashed rgba(18,169,155,0.06);
    }
    .ai-orb img { width: 80px; height: 80px; filter: drop-shadow(0 0 20px rgba(18,169,155,0.4)); }
    @keyframes orbPulse { 0%,100%{transform:scale(1);opacity:1} 50%{transform:scale(1.05);opacity:0.85} }
    .ai-text h2 { font-size: clamp(1.4rem, 3.5vw, 2rem); font-weight: 900; line-height: 1.3; margin-bottom: 0.75rem; }
    .ai-text h2 .accent { color: var(--accent); }
    .ai-text p { font-size: 0.95rem; color: var(--muted); line-height: 1.8; margin-bottom: 1.25rem; }
    .ai-features { display: flex; flex-direction: column; gap: 0.65rem; }
    .ai-feat {
      display: flex; align-items: center; gap: 0.65rem;
      background: rgba(18,169,155,0.04); border: 1px solid rgba(18,169,155,0.08);
      border-radius: 10px; padding: 0.7rem 1rem;
    }
    .ai-feat i { color: var(--accent); font-size: 0.85rem; flex-shrink: 0; }
    .ai-feat span { font-size: 0.88rem; font-weight: 500; }

    .cta-section {
      padding: 5rem 1.5rem; text-align: center;
      background: linear-gradient(180deg, #0c171d, var(--primary));
      position: relative;
    }
    .cta-glow {
      position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
      width: 400px; height: 400px; border-radius: 50%;
      background: radial-gradient(circle, rgba(18,169,155,0.08), transparent 70%);
      pointer-events: none;
    }
    .cta-content { position: relative; z-index: 1; }
    .cta-logo { width: 56px; height: 56px; margin: 0 auto 1.25rem; opacity: 0.8; }
    .cta-title {
      font-size: clamp(1.5rem, 4vw, 2.2rem);
      font-weight: 900; margin-bottom: 0.75rem;
    }
    .cta-title .accent { color: var(--accent); }
    .cta-desc { font-size: 1rem; color: var(--muted); line-height: 1.8; max-width: 480px; margin: 0 auto 2rem; }
    .cta-actions { display: flex; justify-content: center; gap: 0.75rem; flex-wrap: wrap; }

    .landing-footer {
      background: #0a1218; border-top: 1px solid var(--border);
      padding: 2rem 1.5rem; text-align: center;
    }
    .footer-brand { display: flex; align-items: center; justify-content: center; gap: 0.4rem; margin-bottom: 0.75rem; }
    .footer-brand img { width: 28px; height: 28px; opacity: 0.6; }
    .footer-brand span { font-size: 1rem; font-weight: 700; color: var(--muted); }
    .footer-copy { font-size: 0.75rem; color: rgba(255,255,255,0.25); }

    .reveal { opacity: 0; transform: translateY(30px); transition: all 0.7s cubic-bezier(0.16,1,0.3,1); }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    @media (max-width: 768px) {
      .banner-grid, .ai-showcase { grid-template-columns: 1fr; text-align: center; }
      .banner-visual { order: -1; }
      .ai-visual { order: -1; }
      .banner-stats { justify-content: center; }
      .ai-features { align-items: center; }
      .ai-feat { width: 100%; max-width: 360px; }
      .hero-content { padding: 7rem 1.25rem 3rem; }
      .landing-nav { padding: 0.75rem 1rem; }
    }

    @media (max-width: 420px) {
      .hero-logo { width: 70px; height: 70px; }
      .features-grid { grid-template-columns: 1fr; }
      .nav-link-outline { display: none; }
    }
  </style>
</head>
<body>

<nav class="landing-nav">
  <a href="/" class="nav-brand">
    <img src="/icons/logo.png" alt="<%= typeof t === 'function' ? t('site_name') : 'مفاصل' %>">
    <span><%= typeof t === 'function' ? t('site_name') : 'مفاصل' %></span>
  </a>
  <div class="nav-links">
    <button class="nav-link-ghost" onclick="toggleLandingLang()">
      <i class="fas fa-globe" style="margin-inline-end:3px;"></i>
      <%= (typeof lang !== 'undefined' && lang === 'en') ? 'العربية' : 'EN' %>
    </button>
    <a href="/login" class="nav-link-outline"><%= typeof t === 'function' ? t('landing.login_btn') : 'تسجيل الدخول' %></a>
    <a href="/register" class="nav-link-primary"><%= typeof t === 'function' ? t('landing.register_btn') : 'إنشاء حساب' %></a>
  </div>
</nav>

<section class="hero">
  <div class="hero-video-bg">
    <video autoplay muted loop playsinline preload="auto" id="heroVideo">
      <source src="/splash-video.mp4" type="video/mp4">
    </video>
  </div>
  <div class="hero-overlay"></div>
  <div class="hero-grid-pattern"></div>
  <div class="hero-content">
    <div class="hero-badge">
      <i class="fas fa-sparkles"></i>
      <%= (typeof lang !== 'undefined' && lang === 'en') ? 'The Future of Healthcare in Saudi Arabia' : 'مستقبل الرعاية الصحية في السعودية' %>
    </div>
    <img src="/icons/logo.png" alt="<%= typeof t === 'function' ? t('site_name') : 'مفاصل' %>" class="hero-logo">
    <h1 class="hero-title">
      <% if (typeof lang !== 'undefined' && lang === 'en') { %>
        All Your Health Care<br><span class="accent">In One Place</span>
      <% } else { %>
        كل رعايتك الصحية<br><span class="accent">في مكان واحد</span>
      <% } %>
    </h1>
    <p class="hero-desc">
      <% if (typeof lang !== 'undefined' && lang === 'en') { %>
        An integrated digital platform that combines specialist consultations, e-pharmacy, health insurance, and an AI assistant — all at your fingertips.
      <% } else { %>
        منصة رقمية متكاملة تجمع بين استشارات الأخصائيين، الصيدلية الإلكترونية، التأمين الصحي، والمساعد الذكي — كل ذلك بلمسة واحدة.
      <% } %>
    </p>
    <div class="hero-actions">
      <a href="/register" class="btn-hero btn-hero-primary">
        <i class="fas fa-rocket"></i>
        <%= typeof t === 'function' ? t('landing.register_btn') : 'ابدأ مجاناً' %>
      </a>
      <a href="/login" class="btn-hero btn-hero-outline">
        <i class="fas fa-sign-in-alt"></i>
        <%= typeof t === 'function' ? t('landing.login_btn') : 'تسجيل الدخول' %>
      </a>
    </div>
  </div>
  <div class="hero-scroll-hint">
    <span><%= (typeof lang !== 'undefined' && lang === 'en') ? 'Scroll down' : 'اسحب للأسفل' %></span>
    <div class="scroll-line"></div>
    <i class="fas fa-chevron-down" style="font-size:0.65rem;"></i>
  </div>
</section>

<section class="features-section" id="features">
  <div class="section-inner reveal">
    <div class="section-label"><i class="fas fa-grid-2"></i> <%= (typeof lang !== 'undefined' && lang === 'en') ? 'Platform Features' : 'خدمات المنصة' %></div>
    <h2 class="section-title"><%= (typeof lang !== 'undefined' && lang === 'en') ? 'Everything you need for your' : 'كل ما تحتاجه لـ' %> <span class="accent"><%= (typeof lang !== 'undefined' && lang === 'en') ? 'health' : 'صحتك' %></span></h2>
    <p class="section-desc"><%= (typeof lang !== 'undefined' && lang === 'en') ? 'An integrated digital platform that brings together medical consultations, pharmacy, insurance, and AI assistant — all in one place.' : 'منصة رقمية متكاملة تجمع بين الاستشارات الطبية والصيدلية الإلكترونية وإدارة التأمين والمساعد الذكي — كلها في مكان واحد.' %></p>
    <div class="features-grid">
      <div class="feature-card reveal">
