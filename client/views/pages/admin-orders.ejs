<%- include('../partials/header') %>
<div class="main-content">
  <div class="container">
    <div class="page-header">
      <h1><i class="fas fa-pills"></i> إدارة الطلبات</h1>
      <a href="/admin" class="btn btn-outline">العودة</a>
    </div>
    <div class="table-responsive">
      <table class="table">
        <thead><tr><th>الرقم</th><th>المريض</th><th>الأصناف</th><th>الإجمالي</th><th>الحالة</th><th>إجراء</th></tr></thead>
        <tbody>
          <% orders.forEach(o => { %>
          <tr>
            <td><%= o.trackingNumber %></td>
            <td><%= o.patient ? o.patient.name : '-' %></td>
            <td><%= o.items.map(i => i.name).join('، ') %></td>
            <td><%= o.totalPrice %> ريال</td>
            <td><span class="badge badge-<%= o.status === 'delivered' ? 'success' : o.status === 'cancelled' ? 'error' : 'primary' %>"><%= o.status %></span></td>
            <td>
              <form method="POST" action="/admin/orders/<%= o._id %>/status" style="display:inline">
                <select name="status" onchange="this.form.submit()" class="select-sm">
                  <option value="pending" <%= o.status==='pending'?'selected':'' %>>معلق</option>
                  <option value="confirmed" <%= o.status==='confirmed'?'selected':'' %>>مؤكد</option>
                  <option value="preparing" <%= o.status==='preparing'?'selected':'' %>>تحضير</option>
                  <option value="delivering" <%= o.status==='delivering'?'selected':'' %>>توصيل</option>
                  <option value="delivered" <%= o.status==='delivered'?'selected':'' %>>تم</option>
                  <option value="cancelled" <%= o.status==='cancelled'?'selected':'' %>>ملغي</option>
                </select>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
