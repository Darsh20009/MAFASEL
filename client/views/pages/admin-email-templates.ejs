<%- include('../partials/header') %>
<div class="main-content">
  <div class="container" style="max-width:1400px;">
    <div class="admin-layout">
      <%- include('../partials/admin-sidebar') %>
      <div class="admin-main">
  <div class="page-header" style="margin-bottom:1.5rem;">
    <h2 style="margin:0;font-size:1.3rem;"><i class="fas fa-envelope" style="color:var(--secondary);"></i> قوالب البريد الإلكتروني</h2>
    <p style="color:var(--text-muted);font-size:0.85rem;margin:0.25rem 0 0;">معاينة وإرسال تجريبي للقوالب البريدية وإرسال بريد مخصص</p>
  </div>

  <div class="card" style="padding:1.5rem;border-radius:14px;margin-bottom:1.5rem;border:1px solid var(--secondary)20;">
    <h3 style="margin:0 0 1.25rem;font-size:1.05rem;display:flex;align-items:center;gap:0.5rem;">
      <div style="width:36px;height:36px;border-radius:10px;background:var(--secondary)15;display:flex;align-items:center;justify-content:center;">
        <i class="fas fa-pen-fancy" style="color:var(--secondary);font-size:0.95rem;"></i>
      </div>
      إرسال بريد مخصص
    </h3>

    <form id="composeForm" onsubmit="sendCompose(event)">
      <div style="margin-bottom:1rem;position:relative;">
        <label style="font-size:0.82rem;color:var(--text-muted);display:block;margin-bottom:0.3rem;">إلى (بريد إلكتروني)</label>
        <input type="text" id="composeToInput" class="form-control" placeholder="اكتب اسم أو بريد مستخدم أو أدخل بريد جديد..." autocomplete="off" required style="padding-left:2.5rem;">
        <i class="fas fa-search" style="position:absolute;left:0.85rem;top:50%;transform:translateY(20%);color:var(--text-muted);font-size:0.85rem;"></i>
        <input type="hidden" id="composeToEmail" name="to">
        <div id="userSearchResults" style="display:none;position:absolute;top:100%;left:0;right:0;z-index:100;background:var(--card-bg,#1a2736);border:1px solid var(--border,#2a3a4a);border-radius:10px;max-height:260px;overflow-y:auto;margin-top:4px;box-shadow:0 8px 24px rgba(0,0,0,0.3);"></div>
      </div>

      <div style="margin-bottom:1rem;">
        <label style="font-size:0.82rem;color:var(--text-muted);display:block;margin-bottom:0.3rem;">الموضوع</label>
        <input type="text" name="subject" class="form-control" placeholder="عنوان البريد..." required>
      </div>

      <div style="margin-bottom:1rem;">
        <label style="font-size:0.82rem;color:var(--text-muted);display:block;margin-bottom:0.3rem;">الرسالة</label>
        <textarea name="message" class="form-control" rows="5" placeholder="اكتب محتوى الرسالة هنا..." required style="resize:vertical;min-height:100px;"></textarea>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">
        <div>
          <label style="font-size:0.82rem;color:var(--text-muted);display:block;margin-bottom:0.3rem;">نص الزر (اختياري)</label>
          <input type="text" name="ctaText" class="form-control" placeholder="مثال: فتح المنصة">
        </div>
        <div>
          <label style="font-size:0.82rem;color:var(--text-muted);display:block;margin-bottom:0.3rem;">رابط الزر (اختياري)</label>
          <input type="url" name="ctaLink" class="form-control" placeholder="https://...">
        </div>
      </div>

      <div id="selectedRecipient" style="display:none;margin-bottom:1rem;padding:0.75rem;border-radius:10px;background:var(--secondary)10;border:1px solid var(--secondary)30;"></div>

      <button type="submit" class="btn" style="background:var(--secondary);color:#fff;min-width:180px;" id="composeSendBtn">
        <i class="fas fa-paper-plane"></i> إرسال البريد
      </button>
    </form>
  </div>

  <h3 style="font-size:1rem;margin-bottom:1rem;display:flex;align-items:center;gap:0.5rem;">
    <i class="fas fa-swatchbook" style="color:var(--secondary);"></i> القوالب الجاهزة
  </h3>

  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;margin-bottom:2rem;">
    <% var templateInfo = {
      'welcome': { icon: 'fa-hand-sparkles', label: 'ترحيب', desc: 'يُرسل عند تسجيل حساب جديد', color: '#22c55e' },
      'otp': { icon: 'fa-key', label: 'رمز التحقق', desc: 'رمز OTP للتحقق من الهوية', color: '#f59e0b' },
      'password-reset': { icon: 'fa-lock-open', label: 'إعادة تعيين كلمة المرور', desc: 'رابط استعادة كلمة المرور', color: '#ef4444' },
      'consultation': { icon: 'fa-stethoscope', label: 'حجز استشارة', desc: 'تأكيد حجز استشارة طبية', color: '#3b82f6' },
      'order': { icon: 'fa-pills', label: 'تأكيد طلب', desc: 'تأكيد طلب صيدلية', color: '#8b5cf6' },
      'support': { icon: 'fa-headset', label: 'رد الدعم', desc: 'إشعار برد من فريق الدعم', color: '#06b6d4' },
      'notification': { icon: 'fa-bell', label: 'إشعار عام', desc: 'إشعار عام مخصص', color: '#78716c' }
    }; %>
    <% templates.forEach(function(t) { var info = templateInfo[t]; %>
    <div class="card" style="padding:1.25rem;border-radius:14px;position:relative;overflow:hidden;">
      <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.75rem;">
        <div style="width:40px;height:40px;border-radius:10px;background:<%= info.color %>15;display:flex;align-items:center;justify-content:center;">
          <i class="fas <%= info.icon %>" style="color:<%= info.color %>;font-size:1.1rem;"></i>
        </div>
        <div>
          <strong style="display:block;font-size:0.9rem;"><%= info.label %></strong>
          <small style="color:var(--text-muted);font-size:0.75rem;"><%= info.desc %></small>
        </div>
      </div>
      <div style="display:flex;gap:0.5rem;">
        <a href="/email/preview/<%= t %>" target="_blank" class="btn btn-outline btn-sm" style="flex:1;text-align:center;font-size:0.8rem;">
          <i class="fas fa-eye"></i> معاينة
        </a>
        <button onclick="sendTest('<%= t %>')" class="btn btn-sm" style="flex:1;background:var(--secondary);color:#fff;font-size:0.8rem;" id="btn-<%= t %>">
          <i class="fas fa-paper-plane"></i> إرسال تجريبي
        </button>
      </div>
    </div>
    <% }) %>
  </div>

  <div class="card" style="padding:1.25rem;border-radius:14px;">
    <h3 style="margin:0 0 1rem;font-size:1rem;"><i class="fas fa-paper-plane" style="color:var(--secondary);"></i> إرسال قالب لبريد محدد</h3>
    <form id="customEmailForm" onsubmit="sendCustomTemplate(event)">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">
        <div>
          <label style="font-size:0.82rem;color:var(--text-muted);display:block;margin-bottom:0.3rem;">البريد الإلكتروني</label>
          <input type="email" name="to" class="form-control" placeholder="example@email.com" required>
        </div>
        <div>
          <label style="font-size:0.82rem;color:var(--text-muted);display:block;margin-bottom:0.3rem;">القالب</label>
          <select name="template" class="form-control">
            <% templates.forEach(function(t) { var info = templateInfo[t]; %>
            <option value="<%= t %>"><%= info.label %></option>
            <% }) %>
          </select>
        </div>
      </div>
      <button type="submit" class="btn" style="background:var(--secondary);color:#fff;" id="customSendBtn">
        <i class="fas fa-paper-plane"></i> إرسال
      </button>
    </form>
  </div>

<script>
var searchTimeout = null;
var toInput = document.getElementById('composeToInput');
var toEmail = document.getElementById('composeToEmail');
var resultsDiv = document.getElementById('userSearchResults');
var selectedDiv = document.getElementById('selectedRecipient');

toInput.addEventListener('input', function() {
  clearTimeout(searchTimeout);
  var val = toInput.value.trim();
  if (val.includes('@') && val.includes('.')) {
    toEmail.value = val;
    selectedDiv.style.display = 'block';
    selectedDiv.innerHTML = '<div style="display:flex;align-items:center;gap:0.5rem;"><i class="fas fa-envelope" style="color:var(--secondary);"></i><span style="font-size:0.85rem;">سيُرسل إلى: <strong>' + val + '</strong></span><button type="button" onclick="clearRecipient()" style="margin-right:auto;background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:0.9rem;"><i class="fas fa-times"></i></button></div>';
    resultsDiv.style.display = 'none';
    return;
  } else {
    toEmail.value = '';
    selectedDiv.style.display = 'none';
  }
  if (val.length < 2) { resultsDiv.style.display = 'none'; return; }
  searchTimeout = setTimeout(function() { searchUsers(val); }, 300);
});

async function searchUsers(q) {
  try {
    var res = await fetch('/email/users-search?q=' + encodeURIComponent(q));
    var data = await res.json();
    if (!data.users || !data.users.length) {
      resultsDiv.innerHTML = '<div style="padding:1rem;text-align:center;color:var(--text-muted);font-size:0.85rem;"><i class="fas fa-info-circle"></i> لا توجد نتائج — يمكنك كتابة بريد مباشرة</div>';
      resultsDiv.style.display = 'block';
      return;
    }
    var html = '';
    data.users.forEach(function(u) {
      var roleLabel = { admin:'مدير', doctor:'طبيب', pharmacist:'صيدلي', patient:'مريض', moderator:'مشرف', employee:'موظف' };
      html += '<div onclick="selectUser(\'' + (u.email||'') + '\',\'' + (u.name||'') + '\',\'' + (u.role||'') + '\')" style="padding:0.75rem 1rem;cursor:pointer;display:flex;align-items:center;gap:0.75rem;border-bottom:1px solid var(--border,#2a3a4a)20;transition:background 0.15s;" onmouseover="this.style.background=\'var(--secondary)10\'" onmouseout="this.style.background=\'none\'">';
      html += '<div style="width:36px;height:36px;border-radius:50%;background:var(--secondary)15;display:flex;align-items:center;justify-content:center;">';
      if (u.avatar) {
        html += '<img src="' + u.avatar + '" style="width:36px;height:36px;border-radius:50%;object-fit:cover;">';
      } else {
        html += '<i class="fas fa-user" style="color:var(--secondary);font-size:0.85rem;"></i>';
      }
      html += '</div><div style="flex:1;min-width:0;">';
      html += '<div style="font-size:0.88rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + (u.name || 'بدون اسم') + ' <span style="font-size:0.7rem;color:var(--text-muted);font-weight:400;">' + (roleLabel[u.role] || u.role || '') + '</span></div>';
      if (u.email) html += '<div style="font-size:0.75rem;color:var(--text-muted);direction:ltr;text-align:right;">' + u.email + '</div>';
      if (u.phone) html += '<div style="font-size:0.72rem;color:var(--text-muted);">' + u.phone + '</div>';
      html += '</div></div>';
    });
    resultsDiv.innerHTML = html;
    resultsDiv.style.display = 'block';
  } catch(e) { resultsDiv.style.display = 'none'; }
}

function selectUser(email, name, role) {
  if (!email) { alert('هذا المستخدم ليس لديه بريد إلكتروني'); return; }
  toInput.value = name + ' (' + email + ')';
  toEmail.value = email;
  resultsDiv.style.display = 'none';
  selectedDiv.style.display = 'block';
  var roleLabel = { admin:'مدير', doctor:'طبيب', pharmacist:'صيدلي', patient:'مريض', moderator:'مشرف', employee:'موظف' };
  selectedDiv.innerHTML = '<div style="display:flex;align-items:center;gap:0.5rem;"><i class="fas fa-user-check" style="color:var(--secondary);"></i><span style="font-size:0.85rem;">سيُرسل إلى: <strong>' + name + '</strong> — <span style="direction:ltr;display:inline;">' + email + '</span> <span style="font-size:0.72rem;color:var(--text-muted);">(' + (roleLabel[role]||'') + ')</span></span><button type="button" onclick="clearRecipient()" style="margin-right:auto;background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:0.9rem;"><i class="fas fa-times"></i></button></div>';
}

function clearRecipient() {
  toInput.value = '';
  toEmail.value = '';
  selectedDiv.style.display = 'none';
  toInput.focus();
}

document.addEventListener('click', function(e) {
  if (!e.target.closest('#composeToInput') && !e.target.closest('#userSearchResults')) {
    resultsDiv.style.display = 'none';
  }
});

async function sendCompose(e) {
  e.preventDefault();
  var form = document.getElementById('composeForm');
  var fd = new FormData(form);
  var email = toEmail.value || toInput.value.trim();
  if (!email || (!email.includes('@'))) { alert('الرجاء اختيار مستلم أو كتابة بريد إلكتروني صحيح'); return; }
  var btn = document.getElementById('composeSendBtn');
  var orig = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري الإرسال...';
  try {
    var res = await fetch('/email/send-custom', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        to: email,
        subject: fd.get('subject'),
        message: fd.get('message'),
        ctaText: fd.get('ctaText'),
        ctaLink: fd.get('ctaLink')
      })
    });
    var data = await res.json();
    if (data.success) {
      btn.innerHTML = '<i class="fas fa-check"></i> تم الإرسال بنجاح';
      btn.style.background = '#22c55e';
      setTimeout(function(){ btn.innerHTML = orig; btn.style.background = ''; btn.disabled = false; }, 3000);
    } else {
      alert(data.error || 'فشل الإرسال');
      btn.innerHTML = orig; btn.disabled = false;
    }
  } catch(err) { alert('خطأ في الإرسال'); btn.innerHTML = orig; btn.disabled = false; }
}

async function sendTest(template) {
  var btn = document.getElementById('btn-' + template);
  if (!btn) return;
  var orig = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري...';
  try {
    var res = await fetch('/email/send-test', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ template: template })
    });
    var data = await res.json();
    if (data.success) {
      btn.innerHTML = '<i class="fas fa-check"></i> تم';
      btn.style.background = '#22c55e';
      setTimeout(function(){ btn.innerHTML = orig; btn.style.background = ''; btn.disabled = false; }, 3000);
    } else {
      alert(data.error || 'فشل الإرسال');
      btn.innerHTML = orig; btn.disabled = false;
    }
  } catch(err) { alert('خطأ في الإرسال'); btn.innerHTML = orig; btn.disabled = false; }
}

async function sendCustomTemplate(e) {
  e.preventDefault();
  var form = document.getElementById('customEmailForm');
  var fd = new FormData(form);
  var btn = document.getElementById('customSendBtn');
  var orig = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري الإرسال...';
  try {
    var res = await fetch('/email/send-test', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ to: fd.get('to'), template: fd.get('template') })
    });
    var data = await res.json();
    if (data.success) {
      btn.innerHTML = '<i class="fas fa-check"></i> تم الإرسال بنجاح';
      btn.style.background = '#22c55e';
      setTimeout(function(){ btn.innerHTML = orig; btn.style.background = ''; btn.disabled = false; }, 3000);
    } else {
      alert(data.error || 'فشل الإرسال');
      btn.innerHTML = orig; btn.disabled = false;
    }
  } catch(err) { alert('خطأ'); btn.innerHTML = orig; btn.disabled = false; }
}
</script>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
