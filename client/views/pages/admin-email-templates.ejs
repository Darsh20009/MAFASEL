<%- include('../partials/header') %>

<div class="page-container" style="max-width:1000px;margin:0 auto;padding:1.5rem;">
  <div class="page-header" style="margin-bottom:1.5rem;">
    <h2 style="margin:0;font-size:1.3rem;"><i class="fas fa-envelope" style="color:var(--secondary);"></i> قوالب البريد الإلكتروني</h2>
    <p style="color:var(--text-muted);font-size:0.85rem;margin:0.25rem 0 0;">معاينة وإرسال تجريبي للقوالب البريدية</p>
  </div>

  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;margin-bottom:2rem;">
    <% var templateInfo = {
      'welcome': { icon: 'fa-hand-sparkles', label: 'ترحيب', desc: 'يُرسل عند تسجيل حساب جديد', color: '#22c55e' },
      'otp': { icon: 'fa-key', label: 'رمز التحقق', desc: 'رمز OTP للتحقق من الهوية', color: '#f59e0b' },
      'password-reset': { icon: 'fa-lock-open', label: 'إعادة تعيين كلمة المرور', desc: 'رابط استعادة كلمة المرور', color: '#ef4444' },
      'consultation': { icon: 'fa-stethoscope', label: 'حجز استشارة', desc: 'تأكيد حجز استشارة طبية', color: '#3b82f6' },
      'order': { icon: 'fa-pills', label: 'تأكيد طلب', desc: 'تأكيد طلب صيدلية', color: '#8b5cf6' },
      'support': { icon: 'fa-headset', label: 'رد الدعم', desc: 'إشعار برد من فريق الدعم', color: '#06b6d4' },
      'notification': { icon: 'fa-bell', label: 'إشعار عام', desc: 'إشعار عام مخصص', color: '#78716c' }
    }; %>
    <% templates.forEach(function(t) { var info = templateInfo[t]; %>
    <div class="card" style="padding:1.25rem;border-radius:14px;position:relative;overflow:hidden;">
      <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.75rem;">
        <div style="width:40px;height:40px;border-radius:10px;background:<%= info.color %>15;display:flex;align-items:center;justify-content:center;">
          <i class="fas <%= info.icon %>" style="color:<%= info.color %>;font-size:1.1rem;"></i>
        </div>
        <div>
          <strong style="display:block;font-size:0.9rem;"><%= info.label %></strong>
          <small style="color:var(--text-muted);font-size:0.75rem;"><%= info.desc %></small>
        </div>
      </div>
      <div style="display:flex;gap:0.5rem;">
        <a href="/email/preview/<%= t %>" target="_blank" class="btn btn-outline btn-sm" style="flex:1;text-align:center;font-size:0.8rem;">
          <i class="fas fa-eye"></i> معاينة
        </a>
        <button onclick="sendTest('<%= t %>')" class="btn btn-sm" style="flex:1;background:var(--secondary);color:#fff;font-size:0.8rem;" id="btn-<%= t %>">
          <i class="fas fa-paper-plane"></i> إرسال تجريبي
        </button>
      </div>
    </div>
    <% }) %>
  </div>

  <div class="card" style="padding:1.25rem;border-radius:14px;">
    <h3 style="margin:0 0 1rem;font-size:1rem;"><i class="fas fa-paper-plane" style="color:var(--secondary);"></i> إرسال بريد مخصص</h3>
    <form id="customEmailForm" onsubmit="sendCustom(event)">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">
        <div>
          <label style="font-size:0.82rem;color:var(--text-muted);display:block;margin-bottom:0.3rem;">البريد الإلكتروني</label>
          <input type="email" name="to" class="form-control" placeholder="example@email.com" required>
        </div>
        <div>
          <label style="font-size:0.82rem;color:var(--text-muted);display:block;margin-bottom:0.3rem;">القالب</label>
          <select name="template" class="form-control">
            <% templates.forEach(function(t) { var info = templateInfo[t]; %>
            <option value="<%= t %>"><%= info.label %></option>
            <% }) %>
          </select>
        </div>
      </div>
      <button type="submit" class="btn" style="background:var(--secondary);color:#fff;" id="customSendBtn">
        <i class="fas fa-paper-plane"></i> إرسال
      </button>
    </form>
  </div>
</div>

<script>
async function sendTest(template) {
  var btn = document.getElementById('btn-' + template);
  if (!btn) return;
  var orig = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري الإرسال...';
  try {
    var res = await fetch('/email/send-test', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ template: template })
    });
    var data = await res.json();
    if (data.success) {
      btn.innerHTML = '<i class="fas fa-check"></i> تم الإرسال';
      btn.style.background = '#22c55e';
      setTimeout(function(){ btn.innerHTML = orig; btn.style.background = ''; btn.disabled = false; }, 3000);
    } else {
      alert(data.error || 'فشل الإرسال');
      btn.innerHTML = orig; btn.disabled = false;
    }
  } catch(err) { alert('خطأ في الإرسال'); btn.innerHTML = orig; btn.disabled = false; }
}

async function sendCustom(e) {
  e.preventDefault();
  var form = document.getElementById('customEmailForm');
  var fd = new FormData(form);
  var btn = document.getElementById('customSendBtn');
  var orig = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> جاري الإرسال...';
  try {
    var res = await fetch('/email/send-test', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ to: fd.get('to'), template: fd.get('template') })
    });
    var data = await res.json();
    if (data.success) {
      btn.innerHTML = '<i class="fas fa-check"></i> تم الإرسال بنجاح';
      btn.style.background = '#22c55e';
      setTimeout(function(){ btn.innerHTML = orig; btn.style.background = ''; btn.disabled = false; }, 3000);
    } else {
      alert(data.error || 'فشل الإرسال');
      btn.innerHTML = orig; btn.disabled = false;
    }
  } catch(err) { alert('خطأ'); btn.innerHTML = orig; btn.disabled = false; }
}
</script>

<%- include('../partials/footer') %>
