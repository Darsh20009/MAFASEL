<%- include('../partials/header') %>
<div class="main-content">
  <div class="container">
    <div class="page-header">
      <h1><i class="fas fa-comments"></i> المحادثات</h1>
    </div>
    <% if (rooms && rooms.length > 0) { %>
    <div class="list-items">
      <% rooms.forEach(room => { %>
      <a href="/chat/room/<%= room._id %>" class="list-item">
        <div class="list-item-info">
          <strong><%= room.participants.filter(p => p._id.toString() !== user._id.toString()).map(p => p.name).join('، ') || 'محادثة' %></strong>
          <p><%= room.lastMessage || 'لا توجد رسائل بعد' %></p>
        </div>
        <span class="text-muted"><%= room.lastMessageAt ? new Date(room.lastMessageAt).toLocaleDateString('ar-SA') : '' %></span>
      </a>
      <% }) %>
    </div>
    <% } else { %>
    <div class="empty-state-lg">
      <i class="fas fa-comments"></i>
      <h3>لا توجد محادثات</h3>
      <p>ستظهر المحادثات هنا عند بدء استشارة طبية</p>
    </div>
    <% } %>
  </div>
</div>
<%- include('../partials/footer') %>
