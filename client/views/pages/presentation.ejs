<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>مفاصل | الدراسة التكاملية</title>
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="icon" href="/icons/logo.png">
  <style>
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    :root{
      --dark:#0b1520;--dark2:#101d23;--dark3:#1a2e38;
      --teal:#12a99b;--teal2:#0d8a7e;--teal-glow:rgba(18,169,155,0.25);
      --gold:#f0a500;--gold2:#d97706;
      --blue:#2563eb;--purple:#7c3aed;--green:#16a34a;--red:#dc2626;
      --text:#1a1a2e;--muted:#64748b;--border:#e2e8f0;
      --bg:#f8fafc;--card:#fff;
      --grad-teal:linear-gradient(135deg,#12a99b,#0d8a7e);
      --grad-dark:linear-gradient(170deg,#0b1520,#1a2e38);
      --grad-gold:linear-gradient(135deg,#f0a500,#d97706);
    }
    html{scroll-behavior:smooth;overflow-x:hidden}
    body{font-family:'Tajawal',sans-serif;background:var(--bg);color:#101d23;overflow-x:hidden}
    .text-\[\#101d23\]{color:#101d23}

    /* ====== BACK BTN ====== */
    .back-btn{
      position:fixed;top:1.2rem;right:1.2rem;z-index:999;
      display:flex;align-items:center;gap:0.4rem;
      background:rgba(255,255,255,0.9);backdrop-filter:blur(12px);
      border:1px solid var(--border);border-radius:50px;
      padding:0.5rem 1rem;text-decoration:none;
      color:var(--dark2);font-size:0.82rem;font-weight:700;
      box-shadow:0 2px 16px rgba(0,0,0,0.08);transition:all 0.3s;
    }
    .back-btn:hover{background:var(--dark2);color:#fff}

    /* ====== HERO ====== */
    .hero{
      min-height:100vh;display:flex;align-items:center;justify-content:center;
      background:var(--grad-dark);position:relative;overflow:hidden;
    }
    .hero-orbs{position:absolute;inset:0;pointer-events:none}
    .orb{position:absolute;border-radius:50%;filter:blur(80px);opacity:0.2}
    .orb-1{width:400px;height:400px;background:var(--teal);top:-100px;left:-100px;animation:orbFloat 10s ease-in-out infinite}
    .orb-2{width:300px;height:300px;background:#2563eb;bottom:5%;right:5%;animation:orbFloat 14s ease-in-out infinite reverse}
    .orb-3{width:250px;height:250px;background:#7c3aed;top:50%;left:60%;animation:orbFloat 12s ease-in-out infinite}
    @keyframes orbFloat{0%,100%{transform:translate(0,0)}50%{transform:translate(30px,-30px)}}

    .hero-inner{text-align:center;position:relative;z-index:2;padding:2rem 1.5rem;max-width:900px;margin:0 auto}
    .hero-logo{width:110px;height:110px;margin:0 auto 1.5rem;animation:floatY 4s ease-in-out infinite;filter:drop-shadow(0 8px 32px var(--teal-glow))}
    @keyframes floatY{0%,100%{transform:translateY(0)}50%{transform:translateY(-14px)}}

    .hero-tag{
      display:inline-flex;align-items:center;gap:0.5rem;
      padding:0.45rem 1.2rem;border-radius:50px;
      background:rgba(18,169,155,0.15);border:1px solid rgba(18,169,155,0.3);
      color:var(--teal);font-size:0.82rem;font-weight:700;margin-bottom:1.5rem;
    }
    .hero h1{font-size:clamp(3rem,8vw,5.5rem);font-weight:900;color:#fff;line-height:1.05;margin-bottom:0.8rem}
    .hero h1 .accent{color:var(--teal)}
    .hero-sub{font-size:clamp(1rem,2.5vw,1.3rem);color:rgba(255,255,255,0.65);margin-bottom:2.5rem;line-height:1.8;max-width:680px;margin-left:auto;margin-right:auto}

    .hero-kpis{
      display:flex;justify-content:center;gap:2rem;flex-wrap:wrap;margin-bottom:3rem;
    }
    .kpi{text-align:center}
    .kpi-num{font-size:2.8rem;font-weight:900;color:var(--teal);line-height:1;display:block}
    .kpi-label{font-size:0.78rem;color:rgba(255,255,255,0.5);margin-top:0.3rem;font-weight:600}

    .hero-chips{display:flex;gap:0.6rem;justify-content:center;flex-wrap:wrap}
    .chip{
      display:inline-flex;align-items:center;gap:0.4rem;padding:0.45rem 1rem;
      border-radius:50px;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);
      color:rgba(255,255,255,0.8);font-size:0.78rem;font-weight:600;
    }

    .scroll-cue{
      position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);
      display:flex;flex-direction:column;align-items:center;gap:0.4rem;
      color:rgba(255,255,255,0.35);font-size:0.75rem;animation:bounce 2s infinite;
    }
    @keyframes bounce{0%,100%{transform:translateX(-50%) translateY(0)}50%{transform:translateX(-50%) translateY(8px)}}

    /* ====== SECTIONS ====== */
    section{padding:5rem 0;position:relative}
    section.dark-sec{background:var(--dark2);color:#fff}
    section.dark-sec .section-title{color:#fff}
    section.dark-sec .section-title span{color:var(--teal)}
    section.light-sec{background:var(--bg)}
    section.white-sec{background:#fff}
    .container{max-width:1100px;margin:0 auto;padding:0 1.5rem}

    .reveal{opacity:0;transform:translateY(32px);transition:opacity 0.65s ease,transform 0.65s ease}
    .reveal.visible{opacity:1;transform:translateY(0)}

    .sec-badge{
      display:inline-flex;align-items:center;gap:0.5rem;
      padding:0.4rem 1rem;border-radius:50px;font-size:0.75rem;font-weight:800;
      margin-bottom:1rem;
    }
    .badge-teal{background:#e6faf8;color:var(--teal);border:1px solid #b2f0ea}
    .badge-gold{background:#fef3c7;color:var(--gold2);border:1px solid #fde68a}
    .badge-blue{background:#dbeafe;color:var(--blue);border:1px solid #bfdbfe}
    .badge-purple{background:#ede9fe;color:var(--purple);border:1px solid #ddd6fe}
    .badge-green{background:#dcfce7;color:var(--green);border:1px solid #bbf7d0}
    .badge-red{background:#fee2e2;color:var(--red);border:1px solid #fecaca}
    .badge-orange{background:#ffedd5;color:#ea580c;border:1px solid #fed7aa}

    .badge-dark{background:rgba(18,169,155,0.15);color:var(--teal);border:1px solid rgba(18,169,155,0.3)}

    .section-title{font-size:clamp(1.7rem,4vw,2.4rem);font-weight:900;color:var(--dark2);margin-bottom:0.5rem;line-height:1.25}
    .section-title span{color:var(--teal)}
    .section-sub{font-size:0.95rem;color:var(--muted);line-height:1.8;margin-bottom:2rem;max-width:650px}
    .divider{width:56px;height:4px;border-radius:2px;margin:0.7rem 0 1.5rem;background:var(--grad-teal)}

    /* ====== CARDS ====== */
    .card{background:#fff;border:1px solid var(--border);border-radius:18px;padding:1.6rem;transition:all 0.3s;position:relative;overflow:hidden}
    .card:hover{transform:translateY(-4px);box-shadow:0 16px 48px rgba(0,0,0,0.08)}
    .card-icon{width:50px;height:50px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.15rem;margin-bottom:0.9rem}
    .card h3{font-size:1rem;font-weight:800;color:var(--dark2);margin-bottom:0.35rem}
    .card p{font-size:0.85rem;color:var(--muted);line-height:1.7}

    .ic-teal{background:#e6faf8;color:var(--teal)}
    .ic-blue{background:#dbeafe;color:var(--blue)}
    .ic-purple{background:#ede9fe;color:var(--purple)}
    .ic-gold{background:#fef3c7;color:var(--gold2)}
    .ic-green{background:#dcfce7;color:var(--green)}
    .ic-red{background:#fee2e2;color:var(--red)}
    .ic-orange{background:#ffedd5;color:#ea580c}

    .grid-2{display:grid;grid-template-columns:1fr 1fr;gap:1.4rem}
    .grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:1.2rem}
    .grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem}

    /* ====== PLATFORM DEFINITION ====== */
    .platform-type{
      display:inline-flex;align-items:center;gap:0.6rem;
      padding:0.7rem 1.5rem;border-radius:12px;
      background:linear-gradient(135deg,rgba(18,169,155,0.12),rgba(18,169,155,0.06));
      border:1px solid rgba(18,169,155,0.25);margin:1.5rem 0 2rem;
    }
    .platform-type .pt-icon{font-size:1.3rem}
    .platform-type .pt-text{font-size:1.1rem;font-weight:800;color:var(--dark2)}
    .platform-type .pt-sub{font-size:0.82rem;color:var(--muted)}

    .connect-grid{
      display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;
      margin:1.5rem 0;
    }
    .connect-card{
      text-align:center;padding:1.4rem 1rem;
      background:#fff;border:1px solid var(--border);border-radius:16px;transition:all 0.3s;
    }
    .connect-card:hover{border-color:var(--teal);box-shadow:0 8px 24px var(--teal-glow)}
    .connect-card i{font-size:1.8rem;margin-bottom:0.6rem;display:block}
    .connect-card h4{font-size:0.9rem;font-weight:800;margin-bottom:0.2rem}
    .connect-card p{font-size:0.75rem;color:var(--muted)}

    /* ====== BIG STAT ====== */
    .big-stat-row{display:flex;gap:2rem;flex-wrap:wrap;justify-content:center;margin:2.5rem 0}
    .big-stat{text-align:center;min-width:150px}
    .big-num{
      font-size:3.5rem;font-weight:900;line-height:1;
      background:var(--grad-teal);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
    }
    .big-label{font-size:0.82rem;color:var(--muted);font-weight:600;margin-top:0.4rem}

    .dark-sec .big-label{color:rgba(255,255,255,0.5)}
    .dark-sec .big-num{font-size:3.5rem;font-weight:900;background:var(--grad-teal);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}

    /* ====== LICENSE CARDS ====== */
    .license-item{
      background:#fff;border:1px solid var(--border);border-radius:16px;
      padding:1.4rem;display:flex;align-items:flex-start;gap:1rem;
      transition:all 0.3s;margin-bottom:1rem;
    }
    .license-item:hover{border-color:var(--teal);box-shadow:0 8px 24px var(--teal-glow)}
    .lic-icon{
      width:48px;height:48px;border-radius:12px;flex-shrink:0;
      display:flex;align-items:center;justify-content:center;font-size:1.1rem;
    }
    .lic-body{flex:1}
    .lic-body h4{font-size:0.95rem;font-weight:800;color:var(--dark2);margin-bottom:0.3rem}
    .lic-body p{font-size:0.8rem;color:var(--muted);line-height:1.6}
    .lic-cost{
      display:inline-block;margin-top:0.5rem;padding:0.3rem 0.8rem;
      border-radius:8px;background:#fef3c7;color:var(--gold2);
      font-size:0.8rem;font-weight:800;
    }
    .lic-total{
      background:linear-gradient(135deg,#0b1520,#1a2e38);
      color:#fff;border-radius:16px;padding:1.5rem 2rem;
      display:flex;align-items:center;justify-content:space-between;
      margin-top:1.5rem;
    }
    .lic-total h3{font-size:1rem;font-weight:700}
    .lic-total .amount{font-size:1.8rem;font-weight:900;color:var(--teal)}

    /* ====== MARKET ====== */
    .market-highlight{
      background:linear-gradient(135deg,var(--dark2),var(--dark3));
      border-radius:20px;padding:2.5rem;text-align:center;color:#fff;margin:2rem 0;
    }
    .market-highlight .mh-val{font-size:5rem;font-weight:900;color:var(--teal);line-height:1;display:block}
    .market-highlight .mh-label{font-size:1rem;color:rgba(255,255,255,0.65);margin-top:0.5rem}
    .market-highlight .mh-sub{font-size:0.85rem;color:rgba(255,255,255,0.4);margin-top:0.4rem}

    /* ====== CONDITIONS ====== */
    .condition-bar{margin-bottom:1rem}
    .condition-bar .cb-top{display:flex;justify-content:space-between;margin-bottom:0.35rem}
    .condition-bar .cb-name{font-size:0.9rem;font-weight:700;color:var(--dark2)}
    .condition-bar .cb-pct{font-size:0.9rem;font-weight:800;color:var(--teal)}
    .bar-track{height:10px;background:#f1f5f9;border-radius:5px;overflow:hidden}
    .bar-fill{height:100%;border-radius:5px;background:var(--grad-teal);transition:width 1.2s ease}

    /* ====== REVENUE MODEL ====== */
    .rev-card{
      background:#fff;border:1px solid var(--border);border-radius:16px;
      padding:1.4rem;display:flex;align-items:center;gap:1rem;transition:all 0.3s;
    }
    .rev-card:hover{border-color:var(--teal);transform:translateX(-4px);box-shadow:0 8px 24px var(--teal-glow)}
    .rev-icon{width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0}
    .rev-body{flex:1}
    .rev-body h4{font-size:0.95rem;font-weight:800;color:var(--dark2)}
    .rev-body p{font-size:0.82rem;color:var(--muted)}
    .rev-rate{font-size:1.1rem;font-weight:900;color:var(--teal);white-space:nowrap}

    /* ====== CAPITAL TABLE ====== */
    .cap-table{width:100%;border-collapse:collapse;border-radius:16px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.06)}
    .cap-table thead{background:var(--dark2);color:#fff}
    .cap-table thead th{padding:1rem 1.2rem;font-size:0.88rem;font-weight:800;text-align:right}
    .cap-table tbody tr{border-bottom:1px solid var(--border);background:#fff;transition:background 0.2s}
    .cap-table tbody tr:hover{background:#f0fdf9}
    .cap-table tbody td{padding:0.9rem 1.2rem;font-size:0.88rem;color:var(--dark2)}
    .cap-table tbody td:last-child{font-weight:800;color:var(--teal);text-align:left}
    .cap-table tfoot td{padding:1rem 1.2rem;font-weight:900;font-size:1rem;background:linear-gradient(135deg,#0b1520,#1a2e38);color:#fff}
    .cap-table tfoot td:last-child{color:var(--teal);font-size:1.2rem}

    /* ====== TEAM ====== */
    .team-card{
      background:#fff;border:1px solid var(--border);border-radius:16px;
      padding:1.2rem;text-align:center;transition:all 0.3s;
    }
    .team-card:hover{transform:translateY(-4px);box-shadow:0 12px 32px rgba(0,0,0,0.08)}
    .team-avatar{
      width:60px;height:60px;border-radius:50%;margin:0 auto 0.8rem;
      display:flex;align-items:center;justify-content:center;font-size:1.4rem;
    }
    .team-card h4{font-size:0.92rem;font-weight:800;color:var(--dark2);margin-bottom:0.2rem}
    .team-card .salary{font-size:0.95rem;font-weight:900;color:var(--teal)}
    .team-card p{font-size:0.75rem;color:var(--muted)}

    /* ====== GROWTH TABLE ====== */
    .growth-table{width:100%;border-collapse:collapse;border-radius:18px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.06)}
    .growth-table thead{background:linear-gradient(135deg,#0b1520,#1a2e38)}
    .growth-table thead th{padding:1rem 1.2rem;color:#fff;font-size:0.85rem;font-weight:800;text-align:right}
    .growth-table tbody tr{background:#fff;border-bottom:1px solid var(--border);transition:all 0.2s}
    .growth-table tbody tr:hover{background:#f0fdf9}
    .growth-table tbody td{padding:0.85rem 1.2rem;font-size:0.88rem}
    .growth-table .year-cell{font-weight:900;color:var(--teal);font-size:1rem}
    .growth-table .rev-cell{font-weight:800;color:var(--dark2)}
    .growth-table .growth-cell{
      display:inline-flex;align-items:center;gap:0.3rem;
      padding:0.25rem 0.6rem;border-radius:6px;font-weight:800;font-size:0.82rem;
      background:#dcfce7;color:var(--green);
    }

    /* ====== SECTOR PIE (CSS) ====== */
    .sector-list{display:flex;flex-direction:column;gap:1rem;margin:1.5rem 0}
    .sector-item{display:flex;align-items:center;gap:1rem}
    .sector-dot{width:14px;height:14px;border-radius:50%;flex-shrink:0}
    .sector-label{flex:1;font-size:0.9rem;font-weight:700;color:var(--dark2)}
    .sector-pct{font-size:1.1rem;font-weight:900}
    .sector-bar-wrap{flex:2}
    .sector-bar{height:8px;border-radius:4px}

    /* ====== COMPETITORS ====== */
    .vs-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1rem;margin:1.5rem 0}
    .vs-card{border-radius:16px;padding:1.4rem;text-align:center;border:2px solid transparent;transition:all 0.3s}
    .vs-card.competitor{background:#f8fafc;border-color:var(--border)}
    .vs-card.us{background:linear-gradient(135deg,#0b1520,#1a2e38);color:#fff;border-color:var(--teal)}
    .vs-card h4{font-size:1rem;font-weight:800;margin-bottom:0.8rem}
    .vs-card .feat-list{list-style:none;display:flex;flex-direction:column;gap:0.4rem}
    .vs-card .feat-list li{font-size:0.78rem;padding:0.3rem 0;border-bottom:1px solid rgba(0,0,0,0.05);color:var(--muted)}
    .vs-card.us .feat-list li{color:rgba(255,255,255,0.7);border-bottom-color:rgba(255,255,255,0.08)}
    .vs-card .feat-list li.yes{color:var(--teal);font-weight:700}
    .vs-badge{
      display:inline-block;padding:0.3rem 0.8rem;border-radius:8px;
      font-size:0.72rem;font-weight:800;margin-bottom:0.5rem;
      background:rgba(18,169,155,0.2);color:var(--teal);
    }

    /* ====== TIMELINE RECOVERY ====== */
    .recovery-line{
      display:flex;align-items:center;gap:0;margin:2rem 0;position:relative;
      overflow:hidden;border-radius:12px;
    }
    .rec-step{
      flex:1;padding:1.4rem 1rem;text-align:center;position:relative;
    }
    .rec-step h4{font-size:0.88rem;font-weight:800;margin-bottom:0.3rem}
    .rec-step p{font-size:0.76rem;color:var(--muted)}
    .rec-step.active p{color:rgba(255,255,255,0.7)}

    /* ====== CLOSING STATEMENT ====== */
    .closing{
      background:var(--grad-dark);min-height:60vh;
      display:flex;flex-direction:column;align-items:center;justify-content:center;
      text-align:center;padding:5rem 2rem;position:relative;overflow:hidden;
    }
    .closing::before{
      content:'';position:absolute;inset:0;
      background:radial-gradient(circle at 50% 50%,rgba(18,169,155,0.15),transparent 60%);
    }
    .closing-inner{position:relative;z-index:2;max-width:800px;margin:0 auto}
    .closing h2{font-size:clamp(1.5rem,4vw,2.5rem);color:rgba(255,255,255,0.5);font-weight:400;margin-bottom:1.5rem;line-height:1.6}
    .closing .highlight{color:#fff;font-weight:900}
    .closing .punch{
      font-size:clamp(1.4rem,4vw,2.2rem);font-weight:900;
      color:var(--teal);margin-top:2rem;line-height:1.4;
    }
    .closing .punch span{color:#fff}
    .closing-chips{display:flex;gap:0.8rem;justify-content:center;flex-wrap:wrap;margin-top:2.5rem}
    .closing-chip{
      padding:0.6rem 1.4rem;border-radius:50px;
      background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);
      color:rgba(255,255,255,0.8);font-size:0.85rem;font-weight:700;
    }

    /* ====== VISION BADGE ====== */
    .vision-box{
      background:linear-gradient(135deg,rgba(18,169,155,0.1),rgba(37,99,235,0.08));
      border:1px solid rgba(18,169,155,0.2);border-radius:16px;
      padding:1.5rem 2rem;margin:1.5rem 0;
    }
    .vision-box h4{font-size:1rem;font-weight:800;color:var(--dark2);margin-bottom:0.8rem}
    .vision-box .vb-row{display:flex;gap:1.5rem;flex-wrap:wrap}
    .vision-box .vb-item{display:flex;align-items:center;gap:0.5rem;font-size:0.88rem;color:var(--muted)}
    .vision-box .vb-item i{color:var(--teal)}

    /* ====== LOCATION CARDS ====== */
    .location-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:1rem;margin:1.5rem 0}
    .loc-card{
      background:#fff;border:1px solid var(--border);border-radius:14px;
      padding:1.2rem 0.8rem;text-align:center;transition:all 0.3s;
    }
    .loc-card:hover{border-color:var(--teal);transform:translateY(-3px);box-shadow:0 8px 24px var(--teal-glow)}
    .loc-card i{font-size:1.5rem;color:var(--teal);margin-bottom:0.5rem;display:block}
    .loc-card h4{font-size:0.88rem;font-weight:800;color:var(--dark2)}

    /* ====== TADAWUL ====== */
    .tadawul-box{
      background:linear-gradient(135deg,#0b1520,#1a2e38);
      border-radius:20px;padding:2rem 2.5rem;color:#fff;
      display:flex;align-items:center;justify-content:space-between;gap:2rem;
      flex-wrap:wrap;margin-top:2rem;
    }
    .tadawul-box h3{font-size:1.3rem;font-weight:900;margin-bottom:0.5rem}
    .tadawul-box p{color:rgba(255,255,255,0.6);font-size:0.9rem}
    .tadawul-badge{
      display:flex;flex-direction:column;align-items:center;gap:0.3rem;
      padding:1.2rem 2rem;border-radius:14px;
