<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>مفاصل | العرض التقديمي</title>
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="icon" href="/icons/logo.png">
  <style>
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    :root{
      --accent:#12a99b;--accent2:#0d8a7e;--primary:#101d23;
      --text:#1a1a2e;--muted:#6b7280;--border:#e2e8f0;
      --bg:#f8fafc;--card:#fff;--shadow:0 4px 24px rgba(0,0,0,0.08);
    }
    html,body{width:100%;height:100%;font-family:'Tajawal',sans-serif;background:#e8ecf0;overflow:hidden;user-select:none}

    .book-wrap{
      width:100%;height:100%;display:flex;align-items:center;justify-content:center;
      background:linear-gradient(135deg,#e8ecf0 0%,#d1d5db 100%);
      position:relative;
    }

    .book{
      width:min(95vw,900px);height:min(90vh,640px);position:relative;
      perspective:2000px;
    }

    .page{
      position:absolute;inset:0;
      background:#fff;
      border-radius:4px 16px 16px 4px;
      box-shadow:var(--shadow);
      padding:2.5rem 3rem;
      display:flex;flex-direction:column;
      transform-origin:left center;
      transition:transform 0.7s cubic-bezier(0.645,0.045,0.355,1),opacity 0.4s,box-shadow 0.7s;
      backface-visibility:hidden;
      overflow-y:auto;overflow-x:hidden;
      -webkit-overflow-scrolling:touch;
    }
    .page::before{
      content:'';position:absolute;top:0;left:0;bottom:0;width:3px;
      background:linear-gradient(to bottom,var(--accent),var(--accent2));
      border-radius:4px 0 0 4px;
    }
    .page::after{
      content:'';position:absolute;bottom:12px;right:12px;
      width:28px;height:28px;
      background:linear-gradient(135deg,transparent 50%,rgba(0,0,0,0.04) 50%);
      border-radius:0 0 8px 0;pointer-events:none;
    }

    .page.current{z-index:10;transform:rotateY(0deg);opacity:1}
    .page.prev{z-index:5;transform:rotateY(30deg);opacity:0;pointer-events:none}
    .page.next{z-index:5;transform:rotateY(-8deg) scale(0.97);opacity:0;pointer-events:none}
    .page.hidden{display:none}

    .page-num{
      position:absolute;bottom:1rem;left:50%;transform:translateX(-50%);
      font-size:0.72rem;color:var(--muted);font-weight:600;
    }

    .nav-btn{
      position:absolute;top:50%;transform:translateY(-50%);z-index:50;
      width:48px;height:48px;border-radius:50%;border:none;
      background:var(--card);box-shadow:0 2px 12px rgba(0,0,0,0.12);
      cursor:pointer;display:flex;align-items:center;justify-content:center;
      font-size:1.1rem;color:var(--primary);transition:all 0.2s;
    }
    .nav-btn:hover{background:var(--accent);color:#fff;box-shadow:0 4px 20px rgba(18,169,155,0.3)}
    .nav-btn:disabled{opacity:0.3;cursor:default;background:var(--card);color:var(--muted)}
    #prevBtn{right:calc(50% + min(48vw,460px) + 16px)}
    #nextBtn{left:calc(50% + min(48vw,460px) + 16px)}

    .progress-bar{
      position:absolute;bottom:12px;left:50%;transform:translateX(-50%);
      width:min(80vw,700px);height:4px;background:var(--border);border-radius:2px;z-index:50;
    }
    .progress-fill{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent2));border-radius:2px;transition:width 0.5s}

    .page-counter{
      position:absolute;bottom:20px;left:50%;transform:translateX(-50%);z-index:50;
      font-size:0.8rem;font-weight:700;color:var(--muted);
    }

    h1{font-size:clamp(1.6rem,4vw,2.4rem);font-weight:900;color:var(--primary);line-height:1.3;margin-bottom:0.5rem}
    h2{font-size:clamp(1.2rem,3vw,1.6rem);font-weight:800;color:var(--primary);line-height:1.35;margin-bottom:0.4rem}
    h3{font-size:0.95rem;font-weight:700;color:var(--primary);margin-bottom:0.3rem}
    .accent{color:var(--accent)}
    .sub{font-size:clamp(0.85rem,2vw,0.95rem);color:var(--muted);line-height:1.75;margin-bottom:1rem}
    .badge{display:inline-flex;align-items:center;gap:0.35rem;font-size:0.72rem;font-weight:700;padding:0.3rem 0.8rem;border-radius:50px;margin-bottom:0.6rem}
    .b-teal{background:#e6faf8;color:var(--accent);border:1px solid #b2f0ea}
    .b-blue{background:#dbeafe;color:#2563eb;border:1px solid #bfdbfe}
    .b-purple{background:#ede9fe;color:#7c3aed;border:1px solid #ddd6fe}
    .b-gold{background:#fef3c7;color:#d97706;border:1px solid #fde68a}
    .b-pink{background:#fce7f3;color:#db2777;border:1px solid #fbcfe8}
    .b-green{background:#dcfce7;color:#16a34a;border:1px solid #bbf7d0}
    .b-red{background:#fee2e2;color:#dc2626;border:1px solid #fecaca}
    .b-orange{background:#ffedd5;color:#ea580c;border:1px solid #fed7aa}

    .g2{display:grid;grid-template-columns:1fr 1fr;gap:0.8rem}
    .g3{display:grid;grid-template-columns:repeat(3,1fr);gap:0.7rem}
    .g4{display:grid;grid-template-columns:repeat(4,1fr);gap:0.6rem}

    .card{background:var(--bg);border:1px solid var(--border);border-radius:12px;padding:0.9rem;transition:transform 0.2s,box-shadow 0.2s}
    .card:hover{transform:translateY(-2px);box-shadow:0 4px 16px rgba(0,0,0,0.06)}

    .ic{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1rem;margin-bottom:0.5rem;flex-shrink:0}
    .ic-teal{background:#e6faf8;color:var(--accent)}
    .ic-blue{background:#dbeafe;color:#2563eb}
    .ic-purple{background:#ede9fe;color:#7c3aed}
    .ic-pink{background:#fce7f3;color:#db2777}
    .ic-gold{background:#fef3c7;color:#d97706}
    .ic-green{background:#dcfce7;color:#16a34a}
    .ic-red{background:#fee2e2;color:#dc2626}
    .ic-orange{background:#ffedd5;color:#ea580c}

    .tag{display:inline-block;font-size:0.68rem;font-weight:600;padding:0.2rem 0.5rem;border-radius:4px;margin:0.15rem}
    .t-teal{background:#e6faf8;color:var(--accent)}
    .t-blue{background:#dbeafe;color:#2563eb}

    .divider{width:50px;height:3px;background:linear-gradient(90deg,var(--accent),var(--accent2));border-radius:2px;margin:0.5rem 0 0.8rem}

    .phone-mock{
      width:160px;height:300px;background:#fff;border-radius:24px;
      border:2px solid var(--border);box-shadow:0 8px 32px rgba(0,0,0,0.1);
      overflow:hidden;flex-shrink:0;position:relative;
    }
    .phone-mock::before{content:'';position:absolute;top:8px;left:50%;transform:translateX(-50%);width:50px;height:16px;background:var(--bg);border-radius:8px;z-index:2}
    .phone-inner{padding:1.5rem 0.6rem 0.6rem;height:100%;display:flex;flex-direction:column;gap:0.3rem;font-size:0.6rem;overflow:hidden}
    .phone-item{background:var(--bg);border-radius:6px;padding:0.35rem 0.5rem;display:flex;align-items:center;gap:0.3rem}
    .phone-item i{font-size:0.55rem}

    .flex-row{display:flex;gap:1.5rem;align-items:flex-start}
    .flex-1{flex:1;min-width:0}

    .code-block{background:var(--primary);color:#e6faf8;border-radius:8px;padding:0.7rem 0.9rem;font-size:0.68rem;font-family:monospace;line-height:1.6;direction:ltr;text-align:left;overflow-x:auto}

    .tl{position:relative;padding-right:1.5rem}
    .tl::before{content:'';position:absolute;right:0;top:0;bottom:0;width:2px;background:linear-gradient(to bottom,var(--accent),#2563eb,#7c3aed);border-radius:1px}
    .tl-item{position:relative;padding:0.5rem 1rem 0.8rem 0;margin-bottom:0.3rem}
    .tl-item::before{content:'';position:absolute;right:-0.35rem;top:0.75rem;width:8px;height:8px;border-radius:50%;background:var(--accent);border:2px solid #fff}
    .tl-item:nth-child(2)::before{background:#2563eb}
    .tl-item:nth-child(3)::before{background:#7c3aed}
    .tl-item:nth-child(4)::before{background:#d97706}

    .stat{text-align:center;padding:0.6rem}
    .stat-num{font-size:1.6rem;font-weight:900;line-height:1}
    .stat-label{font-size:0.68rem;color:var(--muted);margin-top:0.15rem}

    .endpoint{font-size:0.68rem;font-family:monospace;background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:0.3rem 0.6rem;margin:0.15rem 0;display:flex;gap:0.4rem;direction:ltr;text-align:left}
    .endpoint .method{font-weight:700;flex-shrink:0}
    .method-post{color:#16a34a}
    .method-get{color:#2563eb}

    .chat-bubble{padding:0.4rem 0.6rem;border-radius:10px;font-size:0.7rem;max-width:80%;line-height:1.5;margin-bottom:0.3rem}
    .chat-user{align-self:flex-end;background:var(--accent);color:#fff;border-radius:10px 10px 4px 10px}
    .chat-bot{align-self:flex-start;background:var(--bg);color:var(--text);border-radius:10px 10px 10px 4px}

    @media(max-width:768px){
      .page{padding:1.5rem 1.25rem;border-radius:2px 10px 10px 2px}
      .g2,.g3,.g4{grid-template-columns:1fr}
      .flex-row{flex-direction:column}
      .phone-mock{width:120px;height:220px;align-self:center}
      #prevBtn{right:auto;left:8px;top:auto;bottom:40px;transform:none}
      #nextBtn{left:auto;right:8px;top:auto;bottom:40px;transform:none}
      .nav-btn{width:40px;height:40px;font-size:0.9rem}
    }

    @keyframes fadeSlide{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
    .page.current>*{animation:fadeSlide 0.4s ease forwards}
    .page.current>*:nth-child(2){animation-delay:0.08s}
    .page.current>*:nth-child(3){animation-delay:0.14s}
    .page.current>*:nth-child(4){animation-delay:0.2s}
  </style>
</head>
<body>
<div class="book-wrap">
  <div class="book" id="book">

    <!-- PAGE 1: COVER -->
    <div class="page current" data-page="1">
      <div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center">
        <img src="/icons/logo.png" alt="مفاصل" style="width:80px;height:80px;margin-bottom:1.2rem;filter:drop-shadow(0 4px 16px rgba(18,169,155,0.25))">
        <h1 style="font-size:clamp(2rem,5vw,3rem)"><span class="accent">مفاصل</span></h1>
        <p style="font-size:1.1rem;color:var(--muted);font-weight:600;margin-bottom:0.5rem">Mafasel Medical Platform</p>
        <div class="divider" style="margin:0.5rem auto 1rem;width:80px"></div>
        <p class="sub" style="max-width:500px;margin:0 auto 1.5rem">منصة طبية رقمية متكاملة تُعيد تعريف تجربة الرعاية الصحية في المملكة العربية السعودية</p>
        <div style="display:flex;gap:0.5rem;flex-wrap:wrap;justify-content:center">
          <span class="badge b-teal"><i class="fas fa-heartbeat"></i> 18 مرحلة تطوير</span>
          <span class="badge b-blue"><i class="fas fa-code"></i> Full-Stack</span>
          <span class="badge b-purple"><i class="fas fa-shield-alt"></i> رؤية 2030</span>
        </div>
      </div>
      <div style="text-align:center;margin-top:auto;padding-top:1rem;border-top:1px solid var(--border)">
        <p style="font-size:0.75rem;color:var(--muted)">العرض التقديمي الشامل — جميع المراحل والتفاصيل التقنية</p>
      </div>
      <span class="page-num">1</span>
    </div>

    <!-- PAGE 2: BRAND IDENTITY -->
    <div class="page hidden" data-page="2">
      <span class="badge b-gold"><i class="fas fa-palette"></i> الهوية البصرية</span>
      <h2>براند <span class="accent">مفاصل</span></h2>
      <div class="divider"></div>
      <p class="sub">اسم "مفاصل" مستوحى من مفاصل الجسم — النقاط التي تربط وتمنح الحركة. منصتنا تربط المرضى بكل الخدمات الصحية.</p>
      <div class="g2">
        <div>
          <div class="g2" style="gap:0.5rem">
            <div class="card" style="text-align:center;padding:0.7rem">
              <div style="width:36px;height:36px;border-radius:8px;background:var(--primary);margin:0 auto 0.4rem"></div>
              <h3 style="font-size:0.78rem">اللون الأساسي</h3>
              <code style="font-size:0.68rem;color:var(--muted)">#101d23</code>
            </div>
            <div class="card" style="text-align:center;padding:0.7rem">
              <div style="width:36px;height:36px;border-radius:8px;background:var(--accent);margin:0 auto 0.4rem"></div>
              <h3 style="font-size:0.78rem">اللون المميز</h3>
              <code style="font-size:0.68rem;color:var(--muted)">#12a99b</code>
            </div>
            <div class="card" style="text-align:center;padding:0.7rem">
              <div style="width:36px;height:36px;border-radius:8px;background:#fff;border:2px solid var(--border);margin:0 auto 0.4rem;display:flex;align-items:center;justify-content:center"><span style="font-weight:900;color:var(--primary)">ت</span></div>
              <h3 style="font-size:0.78rem">خط Tajawal</h3>
              <code style="font-size:0.68rem;color:var(--muted)">Arabic</code>
            </div>
            <div class="card" style="text-align:center;padding:0.7rem">
              <div style="width:36px;height:36px;border-radius:8px;background:var(--bg);border:2px solid var(--border);margin:0 auto 0.4rem;display:flex;align-items:center;justify-content:center"><i class="fas fa-arrow-right" style="color:var(--accent);transform:scaleX(-1)"></i></div>
              <h3 style="font-size:0.78rem">RTL</h3>
              <code style="font-size:0.68rem;color:var(--muted)">يمين ← يسار</code>
            </div>
          </div>
        </div>
        <div style="display:flex;align-items:center;justify-content:center">
          <div style="width:180px;height:180px;border-radius:50%;background:linear-gradient(135deg,#e6faf8,#dbeafe);display:flex;align-items:center;justify-content:center;border:2px solid var(--border)">
            <img src="/icons/logo.png" alt="" style="width:100px;height:100px;filter:drop-shadow(0 4px 16px rgba(18,169,155,0.2))">
          </div>
        </div>
      </div>
      <span class="page-num">2</span>
    </div>

    <!-- PAGE 3: VISION & MISSION -->
    <div class="page hidden" data-page="3">
      <span class="badge b-blue"><i class="fas fa-bullseye"></i> الرؤية والرسالة</span>
      <h2>نحو مستقبل <span style="color:#2563eb">صحي رقمي</span></h2>
      <div class="divider" style="background:linear-gradient(90deg,#2563eb,transparent)"></div>
      <div class="g2" style="margin-bottom:0.8rem">
        <div class="card" style="border-right:3px solid #2563eb">
          <div class="ic ic-blue" style="margin-bottom:0.4rem"><i class="fas fa-eye"></i></div>
          <h3>الرؤية</h3>
          <p style="font-size:0.78rem;color:var(--muted);line-height:1.7">أن نكون المنصة الطبية الرقمية الرائدة في المملكة والشرق الأوسط — بما يتماشى مع رؤية 2030 في التحول الرقمي الصحي.</p>
        </div>
        <div class="card" style="border-right:3px solid var(--accent)">
          <div class="ic ic-teal" style="margin-bottom:0.4rem"><i class="fas fa-bullseye"></i></div>
          <h3>الرسالة</h3>
          <p style="font-size:0.78rem;color:var(--muted);line-height:1.7">تقديم منصة شاملة تجمع الاستشارات، الصيدلية، التأمين، والذكاء الاصطناعي في تجربة واحدة سلسة وآمنة.</p>
        </div>
      </div>
      <div class="g4">
        <div class="card" style="text-align:center;padding:0.7rem"><div class="stat-num accent">18</div><div class="stat-label">مرحلة تطوير</div></div>
        <div class="card" style="text-align:center;padding:0.7rem"><div class="stat-num" style="color:#2563eb">24/7</div><div class="stat-label">مساعد ذكي</div></div>
        <div class="card" style="text-align:center;padding:0.7rem"><div class="stat-num" style="color:#7c3aed">8</div><div class="stat-label">أدوار مستخدمين</div></div>
        <div class="card" style="text-align:center;padding:0.7rem"><div class="stat-num" style="color:#d97706">6</div><div class="stat-label">طرق مصادقة</div></div>
      </div>
      <span class="page-num">3</span>
    </div>

    <!-- PAGE 4: INFRASTRUCTURE (Phase 1) -->
    <div class="page hidden" data-page="4">
      <span class="badge b-teal"><i class="fas fa-server"></i> المرحلة 1</span>
      <h2>البنية <span class="accent">التحتية</span></h2>
      <div class="divider"></div>
      <div class="flex-row">
        <div class="flex-1">
          <p class="sub">إعداد كامل للبيئة التطوير والإنتاج مع أفضل الممارسات الأمنية.</p>
          <div class="g2" style="gap:0.5rem">
            <div class="card" style="padding:0.7rem">
              <div class="ic ic-green" style="width:32px;height:32px;font-size:0.8rem;margin-bottom:0.3rem"><i class="fab fa-node-js"></i></div>
              <h3 style="font-size:0.8rem">Node.js + Express</h3>
              <p style="font-size:0.68rem;color:var(--muted)">Backend سريع وقابل للتوسع</p>
            </div>
            <div class="card" style="padding:0.7rem">
              <div class="ic ic-green" style="width:32px;height:32px;font-size:0.8rem;margin-bottom:0.3rem"><i class="fas fa-database"></i></div>
              <h3 style="font-size:0.8rem">MongoDB Atlas</h3>
              <p style="font-size:0.68rem;color:var(--muted)">قاعدة بيانات سحابية</p>
            </div>
            <div class="card" style="padding:0.7rem">
              <div class="ic ic-purple" style="width:32px;height:32px;font-size:0.8rem;margin-bottom:0.3rem"><i class="fas fa-plug"></i></div>
              <h3 style="font-size:0.8rem">Socket.io</h3>
              <p style="font-size:0.68rem;color:var(--muted)">WebSocket للاتصال الحي</p>
            </div>
            <div class="card" style="padding:0.7rem">
              <div class="ic ic-blue" style="width:32px;height:32px;font-size:0.8rem;margin-bottom:0.3rem"><i class="fas fa-file-code"></i></div>
              <h3 style="font-size:0.8rem">EJS Templates</h3>
              <p style="font-size:0.68rem;color:var(--muted)">واجهات SSR ديناميكية</p>
            </div>
          </div>
        </div>
        <div style="min-width:200px">
          <h3 style="font-size:0.8rem;margin-bottom:0.5rem"><i class="fas fa-shield-alt" style="color:var(--accent)"></i> إعدادات النظام</h3>
          <div style="display:flex;flex-direction:column;gap:0.3rem">
            <div class="card" style="padding:0.5rem 0.7rem;display:flex;align-items:center;gap:0.4rem;font-size:0.72rem"><i class="fas fa-check" style="color:var(--accent);font-size:0.6rem"></i> Rate Limiting</div>
            <div class="card" style="padding:0.5rem 0.7rem;display:flex;align-items:center;gap:0.4rem;font-size:0.72rem"><i class="fas fa-check" style="color:var(--accent);font-size:0.6rem"></i> CORS Policy</div>
            <div class="card" style="padding:0.5rem 0.7rem;display:flex;align-items:center;gap:0.4rem;font-size:0.72rem"><i class="fas fa-check" style="color:var(--accent);font-size:0.6rem"></i> Helmet Security</div>
            <div class="card" style="padding:0.5rem 0.7rem;display:flex;align-items:center;gap:0.4rem;font-size:0.72rem"><i class="fas fa-check" style="color:var(--accent);font-size:0.6rem"></i> Error Handling</div>
            <div class="card" style="padding:0.5rem 0.7rem;display:flex;align-items:center;gap:0.4rem;font-size:0.72rem"><i class="fas fa-check" style="color:var(--accent);font-size:0.6rem"></i> Logger System</div>
            <div class="card" style="padding:0.5rem 0.7rem;display:flex;align-items:center;gap:0.4rem;font-size:0.72rem"><i class="fas fa-check" style="color:var(--accent);font-size:0.6rem"></i> Compression</div>
          </div>
        </div>
      </div>
      <span class="page-num">4</span>
    </div>

    <!-- PAGE 5: AUTH SYSTEM (Phase 2) -->
    <div class="page hidden" data-page="5">
      <span class="badge b-purple"><i class="fas fa-lock"></i> المرحلة 2</span>
      <h2>نظام <span style="color:#7c3aed">المصادقة</span> الكامل</h2>
      <div class="divider" style="background:linear-gradient(90deg,#7c3aed,transparent)"></div>
      <div class="flex-row">
        <div class="flex-1">
          <div class="g3" style="gap:0.5rem">
            <div class="card" style="padding:0.7rem;text-align:center">
              <i class="fas fa-mobile-alt" style="color:var(--accent);font-size:1.4rem;margin-bottom:0.3rem;display:block"></i>
