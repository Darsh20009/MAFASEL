<footer>
  <div>منصة <span>مفاصل</span> الطبية — الدراسة التكاملية &copy; 2026</div>
</footer>

<script>
  // ===== REVEAL ON SCROLL =====
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.12 });
  reveals.forEach(el => observer.observe(el));

  // ===== ANIMATE BARS =====
  const barObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const fills = entry.target.querySelectorAll('.bar-fill');
        fills.forEach(f => {
          const w = f.getAttribute('data-w');
          setTimeout(() => f.style.width = w + '%', 200);
        });
        barObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.3 });
  document.querySelectorAll('.grid-2').forEach(g => barObserver.observe(g));

  // ===== COUNTER ANIMATION =====
  function animateCounter(el, target, suffix, decimals) {
    const duration = 2000;
    const start = performance.now();
    const update = (time) => {
      const progress = Math.min((time - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      const current = (target * eased).toFixed(decimals || 0);
      el.textContent = current + (suffix || '');
      if (progress < 1) requestAnimationFrame(update);
    };
    requestAnimationFrame(update);
  }
  const marketEl = document.getElementById('marketVal');
  if (marketEl) {
    const counterObserver = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          animateCounter(marketEl, 9.72, '', 2);
          counterObserver.unobserve(e.target);
        }
      });
    }, { threshold: 0.5 });
    counterObserver.observe(marketEl);
  }
</script>
