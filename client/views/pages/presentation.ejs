<script>
var slideEls = document.querySelectorAll('.slide');
var totalSlides = slideEls.length;
var dotsContainer = document.getElementById('navDots');

for (var i = 0; i < totalSlides; i++) {
  var dot = document.createElement('button');
  dot.className = 'nav-dot';
  dot.dataset.index = i;
  dot.onclick = function() {
    slideEls[this.dataset.index].scrollIntoView({ behavior: 'smooth' });
  };
  dotsContainer.appendChild(dot);
}

var allDots = document.querySelectorAll('.nav-dot');

function revealVisible() {
  document.querySelectorAll('.fade-up').forEach(function(el) {
    var rect = el.getBoundingClientRect();
    if (rect.top < window.innerHeight * 1.1 && rect.bottom > -50) {
      el.classList.add('visible');
    }
  });
  slideEls.forEach(function(s, idx) {
    var rect = s.getBoundingClientRect();
    if (rect.top < window.innerHeight * 0.6 && rect.bottom > window.innerHeight * 0.3) {
      allDots.forEach(function(d, i) { d.classList.toggle('active', i === idx); });
    }
  });
}

document.addEventListener('scroll', revealVisible, { passive: true });
window.addEventListener('load', revealVisible);
revealVisible();
setTimeout(revealVisible, 100);
setTimeout(revealVisible, 500);

document.addEventListener('keydown', function(e) {
  var currentIdx = 0;
  allDots.forEach(function(d, i) { if (d.classList.contains('active')) currentIdx = i; });
  if (e.key === 'ArrowDown' || e.key === ' ') {
    e.preventDefault();
    if (currentIdx < totalSlides - 1) slideEls[currentIdx + 1].scrollIntoView({ behavior: 'smooth' });
  }
  if (e.key === 'ArrowUp') {
    e.preventDefault();
    if (currentIdx > 0) slideEls[currentIdx - 1].scrollIntoView({ behavior: 'smooth' });
  }
});
</script>
