<script>
var pages = document.querySelectorAll('.page');
var total = pages.length;
var current = 0;
var prevBtn = document.getElementById('prevBtn');
var nextBtn = document.getElementById('nextBtn');
var counter = document.getElementById('pageCounter');
var progress = document.getElementById('progressFill');

function updateBook() {
  pages.forEach(function(p, i) {
    p.classList.remove('current', 'prev', 'next', 'hidden');
    if (i === current) p.classList.add('current');
    else if (i < current) p.classList.add('prev');
    else p.classList.add('next');
  });
  prevBtn.disabled = current === 0;
  nextBtn.disabled = current === total - 1;
  counter.textContent = (current + 1) + ' / ' + total;
  progress.style.width = ((current + 1) / total * 100) + '%';
}

function flipPage(dir) {
  var next = current + dir;
  if (next < 0 || next >= total) return;
  current = next;
  updateBook();
}

document.addEventListener('keydown', function(e) {
  if (e.key === 'ArrowLeft' || e.key === 'ArrowDown' || e.key === ' ') { e.preventDefault(); flipPage(1); }
  if (e.key === 'ArrowRight' || e.key === 'ArrowUp') { e.preventDefault(); flipPage(-1); }
});

var sx = 0;
document.addEventListener('touchstart', function(e) { sx = e.touches[0].clientX; }, { passive: true });
document.addEventListener('touchend', function(e) {
  var dx = e.changedTouches[0].clientX - sx;
  if (Math.abs(dx) > 50) { dx < 0 ? flipPage(1) : flipPage(-1); }
}, { passive: true });

updateBook();
</script>
