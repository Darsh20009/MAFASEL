<%- include('../partials/header') %>
<div class="main-content">
  <div class="container" style="max-width:1400px;">
    <div class="admin-layout">
      <%- include('../partials/admin-sidebar') %>
      <div class="admin-main">
        <% if (success) { %><div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success %></div><% } %>
        <% if (error) { %><div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div><% } %>

        <div class="page-header">
          <div>
            <h1><i class="fas fa-building"></i> إدارة الشركات</h1>
            <p style="color:var(--text-muted);margin-top:0.25rem;font-size:0.85rem;">إدارة حسابات الشركات وموظفيها</p>
          </div>
          <a href="/admin/invitations" class="btn btn-primary"><i class="fas fa-plus"></i> دعوة شركة جديدة</a>
        </div>

        <%
          const active = companies.filter(c => c.isActive !== false).length;
          const suspended = companies.filter(c => c.isActive === false).length;
        %>
        <div class="admin-stats-row" style="margin-bottom:1.5rem;">
          <div class="admin-stat-card">
            <div class="admin-stat-icon teal"><i class="fas fa-building"></i></div>
            <div class="admin-stat-info"><h3><%= companies.length %></h3><p>إجمالي الشركات</p></div>
          </div>
          <div class="admin-stat-card">
            <div class="admin-stat-icon green"><i class="fas fa-check-circle"></i></div>
            <div class="admin-stat-info"><h3><%= active %></h3><p>شركات نشطة</p></div>
          </div>
          <div class="admin-stat-card">
            <div class="admin-stat-icon red"><i class="fas fa-ban"></i></div>
            <div class="admin-stat-info"><h3><%= suspended %></h3><p>موقوفة</p></div>
          </div>
          <div class="admin-stat-card">
            <div class="admin-stat-icon blue"><i class="fas fa-users"></i></div>
            <div class="admin-stat-info"><h3><%= employees.length %></h3><p>إجمالي الموظفين</p></div>
          </div>
        </div>

        <div class="admin-section" style="margin-bottom:1.25rem;">
          <div class="admin-section-body" style="padding:1rem;">
            <form method="GET" action="/admin/companies" style="display:flex;flex-wrap:wrap;gap:0.75rem;align-items:flex-end;">
              <div style="flex:2;min-width:200px;">
                <label style="display:block;font-size:0.78rem;color:var(--text-muted);margin-bottom:0.3rem;">بحث</label>
                <div style="position:relative;">
                  <i class="fas fa-search" style="position:absolute;right:0.75rem;top:50%;transform:translateY(-50%);color:var(--text-muted);font-size:0.85rem;"></i>
                  <input type="text" name="q" value="<%= query.q || '' %>" placeholder="اسم الشركة، البريد، القطاع..." style="width:100%;padding:0.5rem 2rem 0.5rem 0.75rem;border:1px solid var(--border);border-radius:8px;background:var(--input-bg);color:var(--text);font-family:inherit;font-size:0.85rem;">
                </div>
              </div>
              <div style="flex:1;min-width:130px;">
                <label style="display:block;font-size:0.78rem;color:var(--text-muted);margin-bottom:0.3rem;">الحالة</label>
                <select name="status" style="width:100%;padding:0.5rem;border:1px solid var(--border);border-radius:8px;background:var(--input-bg);color:var(--text);font-family:inherit;font-size:0.85rem;">
                  <option value="" <%= !query.status ? 'selected' : '' %>>الكل</option>
                  <option value="active" <%= query.status === 'active' ? 'selected' : '' %>>نشطة</option>
                  <option value="suspended" <%= query.status === 'suspended' ? 'selected' : '' %>>موقوفة</option>
                </select>
              </div>
              <div style="display:flex;gap:0.5rem;">
                <button type="submit" class="btn btn-primary" style="padding:0.5rem 1rem;font-size:0.82rem;"><i class="fas fa-search"></i> بحث</button>
                <a href="/admin/companies" class="btn btn-outline" style="padding:0.5rem 1rem;font-size:0.82rem;">مسح</a>
              </div>
            </form>
          </div>
        </div>

        <% if (companies.length === 0) { %>
        <div style="text-align:center;padding:3rem;color:var(--text-muted);">
          <i class="fas fa-building" style="font-size:3rem;margin-bottom:1rem;display:block;opacity:0.3;"></i>
          <p>لا توجد شركات مسجلة حتى الآن</p>
          <a href="/admin/invitations" class="btn btn-primary" style="margin-top:1rem;">دعوة شركة</a>
        </div>
        <% } else { %>
        <div style="display:grid;gap:1rem;">
          <% companies.forEach(company => {
            const profile = company.companyProfile || {};
            const isActive = company.isActive !== false;
          %>
          <div class="admin-section" style="border:1px solid var(--border);border-radius:12px;overflow:hidden;">
            <div style="display:flex;align-items:center;gap:1rem;padding:1rem 1.25rem;background:var(--card-bg);flex-wrap:wrap;">
              <div style="width:52px;height:52px;border-radius:12px;background:linear-gradient(135deg,rgba(18,169,155,0.15),rgba(18,169,155,0.05));border:1px solid rgba(18,169,155,0.2);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <% if (company.avatar) { %>
                  <img src="<%= company.avatar %>" style="width:100%;height:100%;border-radius:12px;object-fit:cover;">
                <% } else { %>
                  <i class="fas fa-building" style="color:var(--secondary);font-size:1.4rem;"></i>
                <% } %>
              </div>
              <div style="flex:1;min-width:200px;">
                <div style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;">
                  <strong style="font-size:1rem;"><%= profile.companyName || company.name %></strong>
                  <span style="font-size:0.7rem;padding:2px 8px;border-radius:6px;font-weight:600;background:<%= isActive ? 'rgba(34,197,94,0.12)' : 'rgba(239,68,68,0.12)' %>;color:<%= isActive ? '#22c55e' : '#ef4444' %>;">
                    <i class="fas fa-<%= isActive ? 'check-circle' : 'ban' %>"></i> <%= isActive ? 'نشط' : 'موقوف' %>
                  </span>
                </div>
                <div style="font-size:0.8rem;color:var(--text-muted);margin-top:0.2rem;display:flex;gap:1rem;flex-wrap:wrap;">
                  <% if (company.email) { %><span><i class="fas fa-envelope"></i> <%= company.email %></span><% } %>
                  <% if (company.phone) { %><span dir="ltr"><i class="fas fa-phone"></i> <%= company.phone %></span><% } %>
                  <% if (profile.sector) { %><span><i class="fas fa-industry"></i> <%= profile.sector %></span><% } %>
                </div>
              </div>
              <div style="display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap;">
                <button class="btn btn-outline" style="padding:0.35rem 0.75rem;font-size:0.78rem;" onclick="toggleDetails('<%= company._id %>')">
                  <i class="fas fa-eye"></i> التفاصيل
                </button>
                <form method="POST" action="/admin/users/<%= company._id %>/toggle?from=companies" style="display:inline;" onsubmit="return confirm('<%= isActive ? 'تأكيد تعليق الشركة؟' : 'تأكيد تفعيل الشركة؟' %>')">
                  <button type="submit" class="btn <%= isActive ? 'btn-warning' : 'btn-success' %>" style="padding:0.35rem 0.75rem;font-size:0.78rem;background:<%= isActive ? 'rgba(245,158,11,0.12)' : 'rgba(34,197,94,0.12)' %>;color:<%= isActive ? '#f59e0b' : '#22c55e' %>;border:1px solid <%= isActive ? 'rgba(245,158,11,0.3)' : 'rgba(34,197,94,0.3)' %>;">
                    <i class="fas fa-<%= isActive ? 'ban' : 'check' %>"></i> <%= isActive ? 'تعليق' : 'تفعيل' %>
                  </button>
                </form>
                <form method="POST" action="/admin/users/<%= company._id %>/delete?from=companies" style="display:inline;" onsubmit="return confirm('تحذير! سيتم حذف الشركة نهائياً. هل أنت متأكد؟')">
                  <button type="submit" class="btn" style="padding:0.35rem 0.75rem;font-size:0.78rem;background:rgba(239,68,68,0.1);color:#ef4444;border:1px solid rgba(239,68,68,0.25);">
                    <i class="fas fa-trash"></i>
                  </button>
                </form>
              </div>
            </div>
            <div id="details-<%= company._id %>" style="display:none;padding:1rem 1.25rem;border-top:1px solid var(--border);background:rgba(0,0,0,0.02);">
              <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem;margin-bottom:1rem;">
                <div>
                  <div style="font-size:0.73rem;color:var(--text-muted);margin-bottom:0.2rem;">اسم التواصل</div>
                  <div style="font-size:0.88rem;"><%= profile.contactPerson || '—' %></div>
                </div>
                <div>
                  <div style="font-size:0.73rem;color:var(--text-muted);margin-bottom:0.2rem;">السجل التجاري</div>
                  <div style="font-size:0.88rem;" dir="ltr"><%= profile.commercialRegister || '—' %></div>
                </div>
                <div>
                  <div style="font-size:0.73rem;color:var(--text-muted);margin-bottom:0.2rem;">عدد الموظفين المتوقع</div>
                  <div style="font-size:0.88rem;"><%= profile.employeeCount ? profile.employeeCount + ' موظف' : '—' %></div>
                </div>
                <div>
                  <div style="font-size:0.73rem;color:var(--text-muted);margin-bottom:0.2rem;">تاريخ التسجيل</div>
                  <div style="font-size:0.88rem;"><%= new Date(company.createdAt).toLocaleDateString('ar-SA') %></div>
                </div>
                <div>
                  <div style="font-size:0.73rem;color:var(--text-muted);margin-bottom:0.2rem;">آخر دخول</div>
                  <div style="font-size:0.88rem;"><%= company.lastLogin ? new Date(company.lastLogin).toLocaleDateString('ar-SA', {month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) : 'لم يسجل دخول' %></div>
                </div>
                <div>
                  <div style="font-size:0.73rem;color:var(--text-muted);margin-bottom:0.2rem;">طريقة التسجيل</div>
                  <div style="font-size:0.88rem;"><%= {local:'بريد',google:'Google',apple:'Apple',nafath:'نفاذ',phone:'جوال'}[company.authProvider] || 'بريد' %></div>
                </div>
              </div>
              <% const companyEmployees = employees.filter(e => false); %>
              <div style="font-size:0.8rem;color:var(--text-muted);font-weight:600;margin-bottom:0.5rem;"><i class="fas fa-users"></i> الموظفون (<%= employees.length %> إجمالي في النظام)</div>
              <% if (employees.length === 0) { %>
              <p style="font-size:0.82rem;color:var(--text-muted);">لا يوجد موظفون مسجلون في النظام حتى الآن</p>
              <% } else { %>
              <div style="display:flex;flex-wrap:wrap;gap:0.5rem;">
                <% employees.slice(0,8).forEach(e => { %>
                <div style="font-size:0.78rem;padding:4px 10px;border-radius:20px;background:rgba(18,169,155,0.08);border:1px solid rgba(18,169,155,0.15);color:var(--secondary);">
                  <i class="fas fa-user"></i> <%= e.name %>
                </div>
                <% }) %>
                <% if (employees.length > 8) { %>
                <div style="font-size:0.78rem;padding:4px 10px;border-radius:20px;background:var(--border);color:var(--text-muted);">+<%= employees.length - 8 %> آخرين</div>
                <% } %>
              </div>
              <% } %>
            </div>
          </div>
          <% }) %>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<script>
function toggleDetails(id) {
  const el = document.getElementById('details-' + id);
  if (el.style.display === 'none') {
    el.style.display = 'block';
  } else {
    el.style.display = 'none';
  }
}
</script>
<%- include('../partials/footer') %>
