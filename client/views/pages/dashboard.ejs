<%- include('../partials/header') %>
<div class="main-content">

  <section class="hero-banner-wrap">
    <% if (banners && banners.length > 0) { %>
    <div class="hero-banner" id="heroBanner">
      <div class="banner-slides">
        <% banners.forEach(function(b, i) { %>
        <div class="banner-slide <%= i === 0 ? 'active' : '' %>" <% if (b.link) { %>data-link="<%= b.link %>"<% } %>>
          <% if (b.type === 'video') { %>
          <video src="<%= b.filePath %>" muted autoplay loop playsinline class="banner-media"></video>
          <% } else { %>
          <img src="<%= b.filePath %>" alt="<%= b.title || 'مفاصل' %>" class="banner-media">
          <% } %>
        </div>
        <% }) %>
      </div>
      <div class="banner-gradient-bottom"></div>
    </div>
    <% } else { %>
    <div class="hero-banner-placeholder">
      <div class="hero-placeholder-content">
        <div class="hero-placeholder-icon"><i class="fas fa-hand-holding-medical"></i></div>
        <h2>مرحباً بك في منصة مفاصل</h2>
        <p>نظامك الطبي الرقمي المتكامل</p>
      </div>
      <div class="banner-gradient-bottom"></div>
    </div>
    <% } %>
  </section>

  <div class="container dashboard-container">

    <section class="welcome-section">
      <div class="welcome-card-premium">
        <div class="welcome-card-bg"></div>
        <div class="welcome-info">
          <% if (typeof isGuest !== 'undefined' && isGuest) { %>
          <h1>مرحباً، مستخدم <span class="wave-emoji">&#x1F44B;</span></h1>
          <p>أهلاً بك في منصة مفاصل الطبية. سجّل دخولك للاستفادة من جميع الخدمات.</p>
          <div class="welcome-guest-actions">
            <a href="/login" class="btn btn-primary btn-sm"><i class="fas fa-sign-in-alt"></i> تسجيل الدخول</a>
            <a href="/register" class="btn btn-outline btn-sm"><i class="fas fa-user-plus"></i> إنشاء حساب</a>
          </div>
          <% } else { %>
          <h1>مرحباً، <%= user.name %> <span class="wave-emoji">&#x1F44B;</span></h1>
          <% var roleGreeting = {
            patient: 'نتمنى لك الصحة والعافية',
            doctor: 'مرحباً بك في منصة مفاصل الطبية',
            pharmacist: 'مرحباً بك في قسم الصيدلة',
            admin: 'مرحباً بك في لوحة التحكم',
            moderator: 'مرحباً بك في لوحة الإشراف',
            company: 'مرحباً بشركة ' + user.name,
            employee: 'مرحباً بك في منصة مفاصل',
            insurance_agent: 'مرحباً بك في قسم التأمين'
          }; %>
          <p><%= roleGreeting[user.role] || 'أهلاً بك في منصة مفاصل الطبية' %></p>
          <div class="account-status">
            <span class="status-pill <%= user.isVerified ? 'verified' : 'unverified' %>">
              <i class="fas fa-<%= user.isVerified ? 'check-circle' : 'exclamation-circle' %>"></i>
              <%= user.isVerified ? 'موثّق' : 'غير موثّق' %>
            </span>
            <span class="status-pill role-pill">
              <i class="fas fa-user-tag"></i>
              <% var roleLabels = { patient:'مريض', doctor:'طبيب', pharmacist:'صيدلي', admin:'مدير النظام', moderator:'مشرف', company:'شركة', employee:'موظف', insurance_agent:'وكيل تأمين' }; %>
              <%= roleLabels[user.role] || user.role %>
            </span>
          </div>
          <% } %>
        </div>
        <div class="welcome-avatar">
          <div class="avatar-circle-premium">
            <% if (typeof isGuest !== 'undefined' && isGuest) { %>
            <i class="fas fa-user"></i>
            <% } else { %>
            <% var roleIcon = { patient:'fa-user-circle', doctor:'fa-user-md', pharmacist:'fa-prescription-bottle-alt', admin:'fa-shield-halved', moderator:'fa-user-shield', company:'fa-building', employee:'fa-id-badge', insurance_agent:'fa-file-shield' }; %>
            <i class="fas <%= roleIcon[user.role] || 'fa-user-circle' %>"></i>
            <% } %>
          </div>
        </div>
      </div>
    </section>

    <% if (typeof isGuest === 'undefined' || !isGuest) { %>

    <% var r = user.role; %>

    <% if (r === 'admin' || r === 'moderator') { %>
    <section class="admin-stats-row" style="margin-bottom:1.5rem;">
      <div class="admin-stat-card">
        <div class="admin-stat-icon teal"><i class="fas fa-users"></i></div>
        <div class="admin-stat-info"><h3><%= roleData.totalUsers || 0 %></h3><p>إجمالي المستخدمين</p></div>
      </div>
      <div class="admin-stat-card">
        <div class="admin-stat-icon blue"><i class="fas fa-stethoscope"></i></div>
        <div class="admin-stat-info"><h3><%= stats.consultations %></h3><p>الاستشارات</p></div>
      </div>
      <div class="admin-stat-card">
        <div class="admin-stat-icon green"><i class="fas fa-shopping-bag"></i></div>
        <div class="admin-stat-info"><h3><%= roleData.totalOrders || 0 %></h3><p>الطلبات</p></div>
      </div>
      <div class="admin-stat-card">
        <div class="admin-stat-icon red"><i class="fas fa-exclamation-circle"></i></div>
        <div class="admin-stat-info"><h3><%= roleData.pendingComplaints || 0 %></h3><p>شكاوى مفتوحة</p></div>
      </div>
      <div class="admin-stat-card">
        <div class="admin-stat-icon amber"><i class="fas fa-bell"></i></div>
        <div class="admin-stat-info"><h3><%= stats.unreadNotifs %></h3><p>إشعارات جديدة</p></div>
      </div>
    </section>

    <section class="quick-actions">
      <h2 class="section-heading-inline"><i class="fas fa-bolt"></i> إجراءات سريعة</h2>
      <div class="actions-grid-premium">
        <a href="/admin" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-chart-pie"></i></div><span>لوحة الإدارة</span></a>
        <a href="/admin/users" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-users-cog"></i></div><span>المستخدمين</span></a>
        <a href="/admin/consultations" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-stethoscope"></i></div><span>الاستشارات</span></a>
        <a href="/admin/orders" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-shopping-bag"></i></div><span>الطلبات</span></a>
        <a href="/pharmacy/admin/pharmacies" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-clinic-medical"></i></div><span>الصيدليات</span></a>
        <a href="/admin/support" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-headset"></i></div><span>الدعم الفني</span></a>
      </div>
    </section>

    <% } else if (r === 'doctor') { %>
    <section class="stats-grid">
      <div class="stat-card-premium">
        <div class="stat-card-shine"></div>
        <div class="stat-icon-premium"><i class="fas fa-stethoscope"></i></div>
        <div class="stat-info"><h3><%= stats.consultations %></h3><p>إجمالي الاستشارات</p></div>
      </div>
      <div class="stat-card-premium">
        <div class="stat-card-shine"></div>
        <div class="stat-icon-premium bg-amber"><i class="fas fa-clock"></i></div>
        <div class="stat-info"><h3><%= roleData.pendingConsultations || 0 %></h3><p>استشارات جارية</p></div>
      </div>
      <div class="stat-card-premium">
        <div class="stat-card-shine"></div>
        <div class="stat-icon-premium bg-green"><i class="fas fa-check-circle"></i></div>
        <div class="stat-info"><h3><%= roleData.completedToday || 0 %></h3><p>مكتملة اليوم</p></div>
      </div>
      <div class="stat-card-premium">
        <div class="stat-card-shine"></div>
        <div class="stat-icon-premium"><i class="fas fa-bell"></i></div>
        <div class="stat-info"><h3><%= stats.unreadNotifs %></h3><p>إشعارات جديدة</p></div>
      </div>
    </section>

    <section class="quick-actions">
      <h2 class="section-heading-inline"><i class="fas fa-bolt"></i> إجراءات سريعة</h2>
      <div class="actions-grid-premium">
        <a href="/consultations" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-notes-medical"></i></div><span>الاستشارات</span></a>
        <a href="/meetings" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-video"></i></div><span>الاجتماعات</span></a>
        <a href="/chat" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-comments"></i></div><span>المحادثات</span></a>
        <a href="/profile" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-user-md"></i></div><span>ملفي المهني</span></a>
        <a href="/pharmacy" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-pills"></i></div><span>الصيدلية</span></a>
        <a href="/ai" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-robot"></i></div><span>المساعد الذكي</span></a>
      </div>
    </section>

    <% } else if (r === 'pharmacist') { %>
    <section class="stats-grid">
      <div class="stat-card-premium">
        <div class="stat-card-shine"></div>
        <div class="stat-icon-premium bg-green"><i class="fas fa-pills"></i></div>
        <div class="stat-info"><h3><%= stats.orders %></h3><p>الطلبات</p></div>
      </div>
      <div class="stat-card-premium">
        <div class="stat-card-shine"></div>
        <div class="stat-icon-premium"><i class="fas fa-bell"></i></div>
        <div class="stat-info"><h3><%= stats.unreadNotifs %></h3><p>إشعارات جديدة</p></div>
      </div>
    </section>

    <section class="quick-actions">
      <h2 class="section-heading-inline"><i class="fas fa-bolt"></i> إجراءات سريعة</h2>
      <div class="actions-grid-premium">
        <a href="/pharmacy" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-clinic-medical"></i></div><span>الصيدلية</span></a>
        <a href="/chat" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-comments"></i></div><span>المحادثات</span></a>
        <a href="/meetings" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-video"></i></div><span>الاجتماعات</span></a>
        <a href="/profile" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-user"></i></div><span>ملفي</span></a>
      </div>
    </section>

    <% } else if (r === 'company') { %>
    <section class="stats-grid">
      <div class="stat-card-premium">
        <div class="stat-card-shine"></div>
        <div class="stat-icon-premium"><i class="fas fa-stethoscope"></i></div>
        <div class="stat-info"><h3><%= stats.consultations %></h3><p>الاستشارات</p></div>
      </div>
      <div class="stat-card-premium">
        <div class="stat-card-shine"></div>
        <div class="stat-icon-premium bg-green"><i class="fas fa-shield-alt"></i></div>
        <div class="stat-info"><h3><%= stats.activeInsurance ? 'فعّال' : 'غير فعّال' %></h3><p>التأمين</p></div>
      </div>
      <div class="stat-card-premium">
        <div class="stat-card-shine"></div>
        <div class="stat-icon-premium bg-amber"><i class="fas fa-bell"></i></div>
        <div class="stat-info"><h3><%= stats.unreadNotifs %></h3><p>إشعارات</p></div>
      </div>
    </section>

    <section class="quick-actions">
      <h2 class="section-heading-inline"><i class="fas fa-bolt"></i> إجراءات سريعة</h2>
      <div class="actions-grid-premium">
        <a href="/insurance" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-shield-alt"></i></div><span>التأمين</span></a>
        <a href="/consultations/new" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-plus-circle"></i></div><span>استشارة جديدة</span></a>
        <a href="/pharmacy" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-pills"></i></div><span>الصيدلية</span></a>
        <a href="/chat" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-comments"></i></div><span>المحادثات</span></a>
        <a href="/complaints" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-headset"></i></div><span>الدعم</span></a>
        <a href="/profile" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-building"></i></div><span>ملف الشركة</span></a>
      </div>
    </section>

    <% } else if (r === 'insurance_agent') { %>
    <section class="stats-grid">
      <div class="stat-card-premium">
        <div class="stat-card-shine"></div>
        <div class="stat-icon-premium"><i class="fas fa-shield-alt"></i></div>
        <div class="stat-info"><h3><%= stats.consultations %></h3><p>الطلبات</p></div>
      </div>
      <div class="stat-card-premium">
        <div class="stat-card-shine"></div>
        <div class="stat-icon-premium bg-amber"><i class="fas fa-bell"></i></div>
        <div class="stat-info"><h3><%= stats.unreadNotifs %></h3><p>إشعارات</p></div>
      </div>
    </section>

    <section class="quick-actions">
      <h2 class="section-heading-inline"><i class="fas fa-bolt"></i> إجراءات سريعة</h2>
      <div class="actions-grid-premium">
        <a href="/insurance" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-file-shield"></i></div><span>التأمين</span></a>
        <a href="/chat" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-comments"></i></div><span>المحادثات</span></a>
        <a href="/meetings" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-video"></i></div><span>الاجتماعات</span></a>
        <a href="/profile" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-user"></i></div><span>ملفي</span></a>
      </div>
    </section>

    <% } else { %>
    <section class="stats-grid">
      <div class="stat-card-premium">
        <div class="stat-card-shine"></div>
        <div class="stat-icon-premium"><i class="fas fa-stethoscope"></i></div>
        <div class="stat-info"><h3><%= stats.consultations %></h3><p>الاستشارات</p></div>
      </div>
      <div class="stat-card-premium">
        <div class="stat-card-shine"></div>
        <div class="stat-icon-premium bg-green"><i class="fas fa-pills"></i></div>
        <div class="stat-info"><h3><%= stats.orders %></h3><p>طلبات الصيدلية</p></div>
      </div>
      <div class="stat-card-premium">
        <div class="stat-card-shine"></div>
        <div class="stat-icon-premium bg-amber"><i class="fas fa-bell"></i></div>
        <div class="stat-info"><h3><%= stats.unreadNotifs %></h3><p>إشعارات جديدة</p></div>
      </div>
      <div class="stat-card-premium">
        <div class="stat-card-shine"></div>
        <div class="stat-icon-premium <%= stats.activeInsurance ? 'bg-green' : 'bg-muted' %>"><i class="fas fa-shield-alt"></i></div>
        <div class="stat-info"><h3><%= stats.activeInsurance ? 'فعّال' : 'غير فعّال' %></h3><p>التأمين الصحي</p></div>
      </div>
    </section>

    <section class="quick-actions">
      <h2 class="section-heading-inline"><i class="fas fa-bolt"></i> إجراءات سريعة</h2>
      <div class="actions-grid-premium">
        <a href="/consultations/new" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-plus-circle"></i></div><span>استشارة جديدة</span></a>
        <a href="/pharmacy" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-shopping-cart"></i></div><span>طلب أدوية</span></a>
        <a href="/ai" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-user-md"></i></div><span>فريق الرعاية</span></a>
        <a href="/medical-profile" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-heartbeat"></i></div><span>ملفي الطبي</span></a>
        <a href="/insurance" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-shield-alt"></i></div><span>التأمين</span></a>
        <a href="/complaints" class="action-card-premium"><div class="action-icon-glow"><i class="fas fa-headset"></i></div><span>الدعم</span></a>
      </div>
    </section>
    <% } %>

    <section class="dashboard-grid">
      <div class="dashboard-section-premium">
        <div class="section-header">
          <h2><i class="fas fa-stethoscope"></i> آخر الاستشارات</h2>
          <a href="/consultations" class="view-all-link">عرض الكل <i class="fas fa-arrow-left"></i></a>
        </div>
        <% if (consultations.length > 0) { %>
        <div class="list-items">
          <% consultations.forEach(function(c) { %>
          <a href="/consultations/<%= c._id %>" class="list-item-premium">
            <div class="list-item-icon-premium"><i class="fas fa-notes-medical"></i></div>
            <div class="list-item-info">
              <strong><%= c.specialty %></strong>
              <p><%= c.symptoms ? c.symptoms.substring(0, 60) + '...' : 'بدون تفاصيل' %></p>
            </div>
            <span class="badge badge-<%= c.status === 'completed' ? 'success' : c.status === 'pending' ? 'warning' : 'primary' %>">
              <%= c.status === 'pending' ? 'معلقة' : c.status === 'assigned' ? 'تم التعيين' : c.status === 'in_progress' ? 'جارية' : c.status === 'completed' ? 'مكتملة' : 'ملغاة' %>
            </span>
          </a>
          <% }) %>
        </div>
        <% } else { %>
        <div class="empty-state-premium">
          <div class="empty-icon"><i class="fas fa-stethoscope"></i></div>
          <p>لا توجد استشارات حتى الآن</p>
          <% if (r === 'patient' || r === 'company') { %>
          <a href="/consultations/new" class="btn btn-sm btn-primary">طلب استشارة</a>
          <% } %>
        </div>
        <% } %>
      </div>

      <div class="dashboard-section-premium">
        <div class="section-header">
          <h2><i class="fas fa-bell"></i> الإشعارات</h2>
          <a href="/notifications" class="view-all-link">عرض الكل <i class="fas fa-arrow-left"></i></a>
        </div>
        <% if (notifications.length > 0) { %>
        <div class="list-items">
          <% notifications.slice(0, 5).forEach(function(n) { %>
          <div class="list-item-premium notif-item <%= n.priority === 'high' || n.priority === 'urgent' ? 'notif-important' : '' %>" <% if(n.link) { %>data-href="<%= n.link %>"<% } %> onclick="if(this.dataset.href)window.location=this.dataset.href">
            <div class="list-item-icon-premium notif-icon-<%= n.priority === 'urgent' ? 'urgent' : n.priority === 'high' ? 'high' : 'normal' %>">
              <i class="fas fa-<%= n.priority === 'urgent' ? 'exclamation-triangle' : n.priority === 'high' ? 'exclamation-circle' : 'info-circle' %>"></i>
            </div>
            <div class="list-item-info">
              <strong><%= n.title %></strong>
              <p><%= n.body %></p>
            </div>
            <span class="notif-time"><%= new Date(n.createdAt).toLocaleDateString('ar-SA') %></span>
          </div>
          <% }) %>
        </div>
        <% } else { %>
        <div class="empty-state-premium">
          <div class="empty-icon"><i class="fas fa-bell-slash"></i></div>
          <p>لا توجد إشعارات جديدة</p>
        </div>
        <% } %>
      </div>
    </section>

    <% if (r === 'patient') { %>
    <section class="dashboard-grid">
      <div class="dashboard-section-premium">
        <div class="section-header">
          <h2><i class="fas fa-shopping-bag"></i> آخر الطلبات</h2>
          <a href="/pharmacy" class="view-all-link">عرض الكل <i class="fas fa-arrow-left"></i></a>
        </div>
        <% if (orders.length > 0) { %>
        <div class="list-items">
          <% orders.forEach(function(o) { %>
          <div class="list-item-premium">
            <div class="list-item-icon-premium bg-green"><i class="fas fa-pills"></i></div>
            <div class="list-item-info">
              <strong>طلب #<%= o.trackingNumber || o._id.toString().slice(-6) %></strong>
              <p><%= o.pharmacy || '' %> &middot; <%= o.items ? o.items.length + ' منتج' : '' %></p>
            </div>
            <span class="badge badge-<%= o.status === 'delivered' ? 'success' : o.status === 'pending' ? 'warning' : o.status === 'cancelled' ? 'error' : 'primary' %>">
              <%= o.status === 'pending' ? 'معلق' : o.status === 'confirmed' ? 'مؤكد' : o.status === 'preparing' ? 'تحضير' : o.status === 'delivering' ? 'توصيل' : o.status === 'delivered' ? 'تم' : 'ملغي' %>
            </span>
          </div>
          <% }) %>
        </div>
        <% } else { %>
        <div class="empty-state-premium">
          <div class="empty-icon"><i class="fas fa-shopping-bag"></i></div>
          <p>لا توجد طلبات حتى الآن</p>
          <a href="/pharmacy" class="btn btn-sm btn-primary">تصفح الصيدلية</a>
        </div>
        <% } %>
      </div>

      <div class="dashboard-section-premium care-team-card">
        <div class="care-card-inner">
          <div class="care-card-glow"></div>
          <div class="care-icon-wrap"><i class="fas fa-user-md"></i></div>
          <h3>فريق الرعاية الصحية</h3>
          <p>تحدث مع أطبائنا المتخصصين واحصل على استشارة فورية</p>
          <a href="/ai" class="btn btn-primary btn-glow"><i class="fas fa-comments"></i> ابدأ محادثة</a>
          <div class="care-features">
            <span><i class="fas fa-check-circle"></i> تقييم أولي</span>
            <span><i class="fas fa-check-circle"></i> معلومات الأدوية</span>
            <span><i class="fas fa-check-circle"></i> نصائح صحية</span>
          </div>
        </div>
      </div>
    </section>
    <% } %>

    <% } else { %>
    <section class="guest-info-section">
      <div class="guest-info-card">
        <div class="guest-info-icon"><i class="fas fa-info-circle"></i></div>
        <div class="guest-info-text">
          <h3>سجّل دخولك للاستفادة الكاملة</h3>
          <p>لعرض الاستشارات والطلبات والإشعارات والتحدث مع فريق الرعاية، يرجى تسجيل الدخول أو إنشاء حساب جديد.</p>
        </div>
      </div>
    </section>
    <% } %>

  </div>
</div>

<script>
var currentSlide = 0;
var slides = document.querySelectorAll('.banner-slide');
var bannerInterval;

if (slides.length > 0) {
  slides.forEach(function(s) {
    if (s.dataset.link) {
      s.style.cursor = 'pointer';
      s.addEventListener('click', function(e) {
        if (!e.target.closest('.banner-arrow')) {
          var link = s.dataset.link;
          if (link.startsWith('/') || link.startsWith('http')) { window.location.href = link; }
        }
      });
    }
  });
}

function showSlide(index) {
  slides.forEach(function(s, i) {
    s.classList.toggle('active', i === index);
    var video = s.querySelector('video');
    if (video) { if (i === index) video.play().catch(function(){}); else { video.pause(); video.currentTime = 0; } }
  });
  currentSlide = index;
}

function changeBannerSlide(dir) {
  var next = currentSlide + dir;
  if (next < 0) next = slides.length - 1;
  if (next >= slides.length) next = 0;
  showSlide(next);
  resetBannerTimer();
}

function resetBannerTimer() {
  clearInterval(bannerInterval);
  if (slides.length > 1) bannerInterval = setInterval(function() { changeBannerSlide(1); }, 5000);
}

if (slides.length > 1) bannerInterval = setInterval(function() { changeBannerSlide(1); }, 5000);

var banner = document.getElementById('heroBanner');
if (banner) {
  var touchStartX = 0;
  banner.addEventListener('touchstart', function(e) { touchStartX = e.touches[0].clientX; });
  banner.addEventListener('touchend', function(e) {
    var diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) changeBannerSlide(diff > 0 ? 1 : -1);
  });
}
</script>
