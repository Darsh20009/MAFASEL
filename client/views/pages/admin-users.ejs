<%- include('../partials/header') %>
<div class="main-content">
  <div class="container">
    <div class="page-header">
      <h1><i class="fas fa-users"></i> إدارة المستخدمين</h1>
      <a href="/admin" class="btn btn-outline">العودة</a>
    </div>
    <div class="table-responsive">
      <table class="table">
        <thead><tr><th>الاسم</th><th>البريد</th><th>الهاتف</th><th>الدور</th><th>تاريخ التسجيل</th><th>إجراء</th></tr></thead>
        <tbody>
          <% users.forEach(u => { %>
          <tr>
            <td><%= u.name %></td>
            <td><%= u.email %></td>
            <td><%= u.phone %></td>
            <td><span class="badge badge-primary"><%= u.role %></span></td>
            <td><%= new Date(u.createdAt).toLocaleDateString('ar-SA') %></td>
            <td>
              <form method="POST" action="/admin/users/<%= u._id %>/role" style="display:inline">
                <select name="role" onchange="this.form.submit()" class="select-sm">
                  <option value="patient" <%= u.role==='patient'?'selected':'' %>>مريض</option>
                  <option value="doctor" <%= u.role==='doctor'?'selected':'' %>>طبيب</option>
                  <option value="pharmacist" <%= u.role==='pharmacist'?'selected':'' %>>صيدلي</option>
                  <option value="moderator" <%= u.role==='moderator'?'selected':'' %>>مشرف</option>
                  <option value="admin" <%= u.role==='admin'?'selected':'' %>>مدير</option>
                </select>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
